    <data name="Title_ExportInfo" xml:space="preserve"><value>Was ist im Datenexport enthalten?</value></data>
    <data name="List_Export_1" xml:space="preserve"><value>• Profilinformationen und Einstellungen</value></data>
    <data name="List_Export_2" xml:space="preserve"><value>• Kontoaktivität und Login-Verlauf</value></data>
    <data name="List_Export_3" xml:space="preserve"><value>• Alle hochgeladenen Dateien und Dokumente</value></data>
    <data name="List_Export_4" xml:space="preserve"><value>• Zahlungs- und Abrechnungsinformationen</value></data>
    <data name="List_Export_5" xml:space="preserve"><value>• Support-Konversationen und Tickets</value></data>
