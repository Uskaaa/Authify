@page "/otp"
@using System.ComponentModel.DataAnnotations
@using Microsoft.JSInterop
@using Microsoft.Extensions.Localization

@implements IAsyncDisposable
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject IAuthifyDataService DataService
@inject IStringLocalizer<Otp> Loc
@inject AuthifyNavigationOptions NavOptions

<RedirectToHomeIfAuthenticated RedirectUrl="@NavOptions.PostLoginUrl" />

<div style="min-height:100dvh;background:var(--bg);display:flex;align-items:center;justify-content:center;font-family:'DM Sans',system-ui,sans-serif;padding:2rem 1rem;">
    <div style="width:min(420px,100%);">

        <div style="background:var(--bg-surface);border:1px solid var(--border);border-radius:12px;padding:2rem;">

            <div style="margin-bottom:1.75rem;">
                <h1 style="font-family:'Syne',system-ui,sans-serif;font-weight:400;font-size:1.5rem;color:var(--text-primary);margin:0 0 0.25rem;">@Loc["Title_VerifyEmail"]</h1>
                <p style="font-size:0.875rem;color:var(--text-secondary);margin:0;">@Loc["Subtitle_EnterCode"]</p>
            </div>

            <EditForm Model="this" OnValidSubmit="HandleValidSubmit" FormName="OtpForm" method="post">
                <div @ref="_otpContainer" style="display:flex;flex-direction:column;gap:1rem;">

                    <input type="hidden" @bind="OtpCode" />

                    <div style="display:flex;gap:0.5rem;justify-content:center;">
                        @for (int i = 0; i < 6; i++)
                        {
                            <input class="otp-input" maxlength="1" inputmode="numeric" pattern="[0-9]"
                                   style="width:3rem;height:3.5rem;text-align:center;font-size:1.5rem;background:var(--bg-elevated);border:1px solid var(--border);border-radius:8px;color:var(--text-primary);outline:none;font-family:inherit;" />
                        }
                    </div>

                    @if (_error)
                    {
                        <div style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.25);color:#ef4444;padding:0.75rem 1rem;border-radius:8px;font-size:0.875rem;text-align:center;">
                            @Loc["Error_VerificationFailed"]
                        </div>
                    }

                    <div style="text-align:center;font-size:0.875rem;color:var(--text-secondary);">
                        @if (_timeLeft > 0)
                        {
                            <span>@Loc["Text_ResendCodeIn"] <span style="color:var(--text-primary);font-weight:500;">@FormatTime(_timeLeft)</span></span>
                        }
                        else
                        {
                            <span>@Loc["Text_NoCode"] </span>
                            <button type="button" @onclick="ResendOtp" disabled="@_isResending"
                                    style="background:none;border:none;color:var(--text-primary);font-size:0.875rem;font-weight:500;cursor:pointer;padding:0;font-family:inherit;text-decoration:underline;">
                                @(_isResending ? Loc["Btn_Sending"] : Loc["Btn_Resend"])
                            </button>
                        }
                    </div>

                    <button type="submit" disabled="@(_isVerifying || OtpCode?.Length != 6)"
                            style="width:100%;background:var(--text-primary);color:var(--bg);border:none;border-radius:100px;padding:0.75rem;font-size:0.875rem;font-weight:500;cursor:pointer;font-family:inherit;display:flex;align-items:center;justify-content:center;gap:0.5rem;">
                        @if (_isVerifying)
                        {
                            <i class="fas fa-spinner fa-spin"></i>
                        }
                        <span>@(_isVerifying ? Loc["Btn_Verifying"] : Loc["Btn_Verify"])</span>
                    </button>

                </div>
            </EditForm>

            <p style="text-align:center;margin-top:1.5rem;font-size:0.875rem;">
                <a href="@("login" + (!string.IsNullOrEmpty(_returnUrl) ? "?returnUrl=" + Uri.EscapeDataString(_returnUrl) : ""))"
                   style="color:var(--text-secondary);text-decoration:none;">@Loc["Link_BackToLogin"]</a>
            </p>

        </div>
    </div>
</div>

@code {
    private ElementReference _otpContainer;
    private IJSObjectReference? _module;
    private DotNetObjectReference<Otp>? _objRef;
    private System.Threading.Timer? _timer;

    [Required(ErrorMessage = "Der Code ist erforderlich.")]
    [StringLength(6, MinimumLength = 6, ErrorMessage = "Bitte geben Sie den vollständigen 6-stelligen Code ein.")]
    private string OtpCode { get; set; } = string.Empty;

    private OtpVerificationRequest _request = new OtpVerificationRequest();
    private bool _isVerifying = false;
    private bool _isResending = false;
    private bool _error = false;
    private int _timeLeft = 60;
    private string? _returnUrl;

    protected override Task OnInitializedAsync()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        _request.Token = query.GetValueOrDefault("token")!;
        _returnUrl = query.GetValueOrDefault("returnUrl").ToString();
        if (string.IsNullOrEmpty(_returnUrl)) _returnUrl = null;

        StartTimer();
        return base.OnInitializedAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("applyTheme");
            try
            {
                _module = await JS.InvokeAsync<IJSObjectReference>(
                    "import", "./_content/Authify.UI/js/otp.js");
                _objRef = DotNetObjectReference.Create(this);
                await _module.InvokeVoidAsync("initializeOtpHandler", _otpContainer, _objRef);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Fehler beim Laden des OTP-Scripts: {ex.Message}");
            }
        }
    }

    [JSInvokable]
    public void OnOtpCompleted(string otp)
    {
        OtpCode = otp;
        StateHasChanged();
    }

    private void StartTimer()
    {
        _timeLeft = 60;
        _timer?.Dispose();
        _timer = new System.Threading.Timer(OnTimerElapsed, null, 1000, 1000);
    }

    private async void OnTimerElapsed(object? state)
    {
        if (_timeLeft > 0)
        {
            _timeLeft--;
            await InvokeAsync(StateHasChanged);
        }
        else
        {
            _timer?.Dispose();
        }
    }

    private string FormatTime(int seconds)
    {
        TimeSpan time = TimeSpan.FromSeconds(seconds);
        return time.ToString(@"mm\:ss");
    }

    private async Task ResendOtp()
    {
        _isResending = true;
        await Task.Delay(1000);
        StartTimer();
        _isResending = false;
    }

    private async Task HandleValidSubmit()
    {
        _isVerifying = true;
        _request.OtpCode = OtpCode;

        var jwtResult = await DataService.JwtVerifyOtpAsync(_request);

        if (jwtResult.Success)
        {
            _error = false;
            var redirectUrl = jwtResult.Data?.RedirectUrl;
            if (!string.IsNullOrEmpty(redirectUrl))
            {
                if (!string.IsNullOrEmpty(_returnUrl))
                    redirectUrl += "&returnUrl=" + Uri.EscapeDataString(_returnUrl);
                NavigationManager.NavigateTo(redirectUrl, forceLoad: true);
            }
            else
            {
                NavigationManager.NavigateTo(_returnUrl ?? NavOptions.PostLoginUrl, forceLoad: true);
            }
        }
        else
        {
            var cookieResult = await DataService.CookieVerifyOtpAsync(_request);

            if (cookieResult.Success)
            {
                _error = false;
                NavigationManager.NavigateTo(_returnUrl ?? NavOptions.PostLoginUrl, forceLoad: true);
            }
            else
            {
                _error = true;
            }
        }

        _isVerifying = false;
    }

    public async ValueTask DisposeAsync()
    {
        _timer?.Dispose();
        _objRef?.Dispose();

        if (_module is not null)
            await _module.DisposeAsync();
    }
}
