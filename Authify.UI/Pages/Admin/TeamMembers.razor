@page "/admin/team-members"
@using Microsoft.AspNetCore.Authorization
@using Authify.Core.Features
@using Authify.Core.Interfaces
@using Authify.Core.Models.Teams

@attribute [Authorize]
@layout ProfileLayout

@inject ITeamDataService TeamDataService
@inject TeamFeatureOptions TeamFeature
@inject NavigationManager NavigationManager

<div class="auth-max-w-3xl auth-mx-auto auth-px-4 auth-py-8">

    @if (!TeamFeature.IsEnabled)
    {
        <div class="auth-text-center auth-py-16 auth-text-slate-400">Team-Features sind nicht aktiviert.</div>
        return;
    }

    <div class="auth-flex auth-items-center auth-justify-between auth-mb-8">
        <div>
            <h1 class="auth-text-2xl auth-font-bold auth-text-slate-900 dark:auth-text-slate-100">Mitarbeiter</h1>
            <p class="auth-mt-1 auth-text-sm auth-text-slate-500 dark:auth-text-slate-400">Verwalte die Mitglieder deines Teams</p>
        </div>
        <button @onclick="() => _showAddForm = !_showAddForm"
                class="auth-inline-flex auth-items-center auth-gap-2 auth-px-4 auth-py-2.5 auth-bg-primary-600 hover:auth-bg-primary-700 auth-text-white auth-rounded-xl auth-text-sm auth-font-semibold auth-transition-colors">
            <i class="fa-solid fa-plus"></i>
            Mitarbeiter hinzufügen
        </button>
    </div>

    @if (!_hasTeam)
    {
        <div class="auth-bg-white dark:auth-bg-slate-900 auth-rounded-2xl auth-border auth-border-amber-200 dark:auth-border-amber-900/50 auth-p-8 auth-text-center">
            <i class="fa-solid fa-triangle-exclamation auth-text-3xl auth-text-amber-500 auth-mb-3"></i>
            <h2 class="auth-text-base auth-font-semibold auth-text-slate-900 dark:auth-text-slate-100 auth-mb-2">Kein Team vorhanden</h2>
            <p class="auth-text-sm auth-text-slate-500 dark:auth-text-slate-400 auth-mb-4">Du musst zuerst einen Team-Account erstellen um Mitarbeiter hinzuzufügen.</p>
            <a href="admin/team-settings"
               class="auth-inline-flex auth-items-center auth-gap-2 auth-px-4 auth-py-2.5 auth-bg-primary-600 hover:auth-bg-primary-700 auth-text-white auth-rounded-xl auth-text-sm auth-font-semibold auth-transition-colors">
                <i class="fa-solid fa-building"></i>
                Team erstellen
            </a>
        </div>
        return;
    }

    <!-- Formular: Neuen Mitarbeiter anlegen -->
    @if (_showAddForm)
    {
        <div class="auth-bg-white dark:auth-bg-slate-900 auth-rounded-2xl auth-border auth-border-slate-200 dark:auth-border-slate-800 auth-p-6 auth-mb-6">
            <h3 class="auth-text-base auth-font-semibold auth-text-slate-900 dark:auth-text-slate-100 auth-mb-4">Neuen Mitarbeiter anlegen</h3>
            <EditForm Model="_createRequest" OnValidSubmit="HandleCreate" FormName="CreateMemberForm">
                <DataAnnotationsValidator />
                <div class="auth-grid auth-grid-cols-1 sm:auth-grid-cols-2 auth-gap-4">
                    <div class="auth-space-y-1.5">
                        <label class="auth-block auth-text-sm auth-font-medium auth-text-slate-700 dark:auth-text-slate-300">Vollständiger Name *</label>
                        <InputText @bind-Value="_createRequest.FullName" placeholder="Max Mustermann"
                                   class="auth-w-full auth-px-3 auth-py-2 auth-rounded-xl auth-border auth-border-slate-300 dark:auth-border-slate-700 auth-bg-white dark:auth-bg-slate-800 auth-text-slate-900 dark:auth-text-slate-100 auth-text-sm focus:auth-outline-none focus:auth-ring-2 focus:auth-ring-primary-500" />
                        <ValidationMessage For="@(() => _createRequest.FullName)" />
                    </div>
                    <div class="auth-space-y-1.5">
                        <label class="auth-block auth-text-sm auth-font-medium auth-text-slate-700 dark:auth-text-slate-300">E-Mail-Adresse *</label>
                        <InputText @bind-Value="_createRequest.Email" placeholder="max@unternehmen.de" type="email"
                                   class="auth-w-full auth-px-3 auth-py-2 auth-rounded-xl auth-border auth-border-slate-300 dark:auth-border-slate-700 auth-bg-white dark:auth-bg-slate-800 auth-text-slate-900 dark:auth-text-slate-100 auth-text-sm focus:auth-outline-none focus:auth-ring-2 focus:auth-ring-primary-500" />
                        <ValidationMessage For="@(() => _createRequest.Email)" />
                    </div>
                </div>
                <p class="auth-mt-3 auth-text-xs auth-text-slate-400 dark:auth-text-slate-500">
                    Der Mitarbeiter erhält automatisch eine E-Mail mit einem Link zum Passwort festlegen.
                </p>
                <div class="auth-flex auth-gap-3 auth-mt-4">
                    <button type="submit" disabled="@_isSaving"
                            class="auth-px-5 auth-py-2.5 auth-bg-primary-600 hover:auth-bg-primary-700 auth-text-white auth-rounded-xl auth-text-sm auth-font-semibold auth-transition-colors disabled:auth-opacity-50">
                        @if (_isSaving) { <i class="fa-solid fa-spinner fa-spin auth-mr-2"></i> }
                        Mitarbeiter anlegen
                    </button>
                    <button type="button" @onclick="() => { _showAddForm = false; _errorMessage = null; }"
                            class="auth-px-4 auth-py-2.5 auth-border auth-border-slate-300 dark:auth-border-slate-700 auth-text-slate-600 dark:auth-text-slate-300 auth-rounded-xl auth-text-sm auth-font-medium auth-transition-colors hover:auth-bg-slate-50 dark:hover:auth-bg-slate-800">
                        Abbrechen
                    </button>
                </div>
                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="auth-mt-3 auth-text-sm auth-text-red-500">@_errorMessage</div>
                }
            </EditForm>
        </div>
    }

    <!-- Erfolgs-/Passwort-Banner -->
    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <div class="auth-bg-@(_newMemberTempPassword != null ? "amber" : "green")-50 dark:auth-bg-@(_newMemberTempPassword != null ? "amber" : "green")-900/20 auth-border auth-border-@(_newMemberTempPassword != null ? "amber" : "green")-200 dark:auth-border-@(_newMemberTempPassword != null ? "amber" : "green")-800 auth-rounded-2xl auth-p-5 auth-mb-6">
            <div class="auth-flex auth-items-center auth-gap-2 auth-mb-2">
                <i class="fa-solid @(_newMemberTempPassword != null ? "fa-triangle-exclamation auth-text-amber-500" : "fa-check-circle auth-text-green-500")"></i>
                <span class="auth-text-sm auth-font-semibold @(_newMemberTempPassword != null ? "auth-text-amber-700 dark:auth-text-amber-300" : "auth-text-green-700 dark:auth-text-green-300")">@_successMessage</span>
            </div>
            @if (_newMemberTempPassword != null)
            {
                <div class="auth-flex auth-items-center auth-gap-2 auth-mt-2">
                    <code class="auth-flex-1 auth-bg-white dark:auth-bg-slate-800 auth-px-3 auth-py-2 auth-rounded-lg auth-text-sm auth-font-mono auth-text-slate-800 dark:auth-text-slate-200 auth-border auth-border-amber-200 dark:auth-border-amber-700">
                        @_newMemberTempPassword
                    </code>
                    <button @onclick="() => _newMemberTempPassword = null"
                            class="auth-flex-shrink-0 auth-p-2 auth-text-slate-400 hover:auth-text-slate-600 dark:hover:auth-text-slate-200 auth-transition-colors"
                            title="Schließen">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>
                <p class="auth-mt-2 auth-text-xs auth-text-amber-600 dark:auth-text-amber-400">
                    <i class="fa-solid fa-info-circle auth-mr-1"></i>
                    Dieses Passwort wird nur einmalig angezeigt. Bitte sicher aufbewahren und dem Mitarbeiter mitteilen.
                </p>
            }
        </div>
    }

    <!-- Mitgliederliste -->
    @if (_isLoading)
    {
        <div class="auth-flex auth-items-center auth-justify-center auth-py-12">
            <i class="fa-solid fa-spinner fa-spin auth-text-2xl auth-text-primary-500"></i>
        </div>
    }
    else if (_members.Count == 0)
    {
        <div class="auth-bg-white dark:auth-bg-slate-900 auth-rounded-2xl auth-border auth-border-slate-200 dark:auth-border-slate-800 auth-p-8 auth-text-center">
            <i class="fa-solid fa-users auth-text-3xl auth-text-slate-300 dark:auth-text-slate-600 auth-mb-3"></i>
            <p class="auth-text-sm auth-text-slate-500 dark:auth-text-slate-400">Noch keine Mitarbeiter vorhanden.</p>
        </div>
    }
    else
    {
        <div class="auth-bg-white dark:auth-bg-slate-900 auth-rounded-2xl auth-border auth-border-slate-200 dark:auth-border-slate-800 auth-overflow-hidden">
            @foreach (var member in _members)
            {
                <div class="auth-flex auth-items-center auth-justify-between auth-px-5 auth-py-4 auth-border-b last:auth-border-b-0 auth-border-slate-100 dark:auth-border-slate-800">
                    <div class="auth-flex auth-items-center auth-gap-3">
                        <div class="auth-w-9 auth-h-9 auth-rounded-full auth-bg-primary-100 dark:auth-bg-primary-900/30 auth-flex auth-items-center auth-justify-center auth-flex-shrink-0">
                            <span class="auth-text-sm auth-font-semibold auth-text-primary-600 dark:auth-text-primary-400">
                                @(member.FullName.Length > 0 ? member.FullName[0].ToString().ToUpper() : "?")
                            </span>
                        </div>
                        <div>
                            <div class="auth-text-sm auth-font-medium auth-text-slate-900 dark:auth-text-slate-100">@member.FullName</div>
                            <div class="auth-text-xs auth-text-slate-500 dark:auth-text-slate-400">@member.Email</div>
                        </div>
                    </div>
                    <div class="auth-flex auth-items-center auth-gap-3">
                        <span class="@(member.Role == TeamMemberRole.Admin ? "auth-bg-primary-100 dark:auth-bg-primary-900/30 auth-text-primary-700 dark:auth-text-primary-300" : "auth-bg-slate-100 dark:auth-bg-slate-800 auth-text-slate-600 dark:auth-text-slate-400") auth-px-2.5 auth-py-0.5 auth-rounded-full auth-text-xs auth-font-medium">
                            @(member.Role == TeamMemberRole.Admin ? "Admin" : "Mitglied")
                        </span>
                        @if (member.Role != TeamMemberRole.Admin)
                        {
                            <button @onclick="() => HandleRemove(member.Id)"
                                    class="auth-p-1.5 auth-text-slate-400 hover:auth-text-red-500 dark:auth-text-slate-500 dark:hover:auth-text-red-400 auth-transition-colors auth-rounded-lg hover:auth-bg-red-50 dark:hover:auth-bg-red-900/20"
                                    title="Mitglied entfernen">
                                <i class="fa-solid fa-trash auth-text-xs"></i>
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<TeamMemberDto> _members = [];
    private bool _isLoading = true;
    private bool _isSaving;
    private bool _showAddForm;
    private bool _hasTeam = true;
    private string? _errorMessage;
    private string? _successMessage;
    private string? _newMemberTempPassword; // nur befüllt wenn E-Mail-Versand fehlschlug

    private CreateTeamMemberRequest _createRequest = new();

    protected override async Task OnInitializedAsync()
    {
        if (!TeamFeature.IsEnabled) return;

        // Prüfen ob Team existiert
        var teamResult = await TeamDataService.GetMyTeamAsync();
        _hasTeam = teamResult.Success;

        if (_hasTeam)
            await LoadMembersAsync();
        else
            _isLoading = false;
    }

    private async Task LoadMembersAsync()
    {
        _isLoading = true;
        var result = await TeamDataService.GetMembersAsync();
        if (result.Success && result.Data != null)
            _members = result.Data;
        _isLoading = false;
    }

    private async Task HandleCreate()
    {
        _isSaving = true;
        _errorMessage = null;
        _successMessage = null;
        _newMemberTempPassword = null;
        var result = await TeamDataService.CreateMemberAsync(_createRequest);
        _isSaving = false;

        if (result.Success && result.Data != null)
        {
            _members.Add(result.Data);
            _createRequest = new();
            _showAddForm = false;

            if (!string.IsNullOrEmpty(result.Data.TemporaryPassword))
            {
                // E-Mail konnte nicht gesendet werden – Passwort dem Admin anzeigen
                _newMemberTempPassword = result.Data.TemporaryPassword;
                _successMessage = $"Mitarbeiter \"{result.Data.FullName}\" wurde angelegt. E-Mail-Versand fehlgeschlagen – bitte Passwort manuell weitergeben:";
            }
            else
            {
                _successMessage = $"Mitarbeiter \"{result.Data.FullName}\" wurde angelegt. Eine E-Mail mit dem Passwort-Reset-Link wurde gesendet.";
                await Task.Delay(4000);
                _successMessage = null;
            }
        }
        else
        {
            _errorMessage = result.ErrorMessage;
        }
    }

    private async Task HandleRemove(string memberId)
    {
        var result = await TeamDataService.RemoveMemberAsync(memberId);
        if (result.Success)
            _members.RemoveAll(m => m.Id == memberId);
    }
}
