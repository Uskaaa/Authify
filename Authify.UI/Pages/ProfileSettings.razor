@page "/profile-settings"
@using Microsoft.AspNetCore.Components.Forms
@using System.ComponentModel.DataAnnotations
@using Microsoft.JSInterop
@using Microsoft.Extensions.Localization
@layout ProfileLayout
@inject IJSRuntime JS
@inject IAuthifyDataService DataService
@inject IStringLocalizer<ProfileSettings> Loc

@if (_showNotification)
{
    <div
        class="auth-fixed auth-top-20 auth-right-4 auth-z-[10000] auth-px-4 auth-py-3 auth-rounded-lg auth-shadow-xl auth-max-w-sm auth-transform auth-transition-all auth-duration-300 @_notificationClass auth-animate-fade-in-down auth-border auth-border-white/10">
        <div class="auth-flex auth-items-center auth-font-medium">
            @if (_notificationClass.Contains("auth-bg-green"))
            {
                <i class="fa-solid fa-check-circle auth-mr-2"></i>
            }
            else
            {
                <i class="fa-solid fa-circle-exclamation auth-mr-2"></i>
            }
            @_notificationMessage
        </div>
    </div>
}

<div class="auth-px-4 lg:auth-px-6 auth-py-4 sm:auth-py-6 lg:auth-py-8 auth-min-h-screen" style="background:var(--bg);">
    <div class="auth-max-w-7xl auth-space-y-6" @ref="_rootElement">
        @*<div class="auth-flex auth-flex-col sm:auth-flex-row sm:auth-items-center auth-justify-between auth-gap-4">
            <div>
                    <h1 class="heading-4" style="color:var(--text-primary);">
                        @Loc["Title_Page"]
                    </h1>
                    <p class="auth-mt-1 auth-text-sm" style="color:var(--text-secondary);">
                        @Loc["Subtitle_Page"]
                    </p>
                </div>
            </div>*@

        @if (_isLoading)
        {
            <div class="auth-flex auth-justify-center auth-items-center auth-h-64">
                <i class="fa-solid fa-circle-notch fa-spin auth-text-3xl auth-text-primary-600"></i>
            </div>
        }
        else
        {
            <div class="auth-mb-8 auth-rounded-xl auth-shadow-sm auth-border auth-overflow-hidden"
                 style="background:var(--bg-surface);border-color:var(--border);">

                <div class="auth-px-8 auth-py-6 auth-border-b" style="border-color:var(--border);">
                    <div class="auth-flex auth-items-center auth-justify-between">
                        <div>
                            <h3 class="auth-text-lg auth-font-bold"
                                style="color:var(--text-primary);">@Loc["Title_PersonalInfo"]</h3>
                            <p class="auth-mt-1 auth-text-sm"
                               style="color:var(--text-secondary);">@Loc["Text_PersonalInfoDesc"]</p>
                        </div>
                        <div class="auth-flex-shrink-0">
                            <div
                                class="auth-w-10 auth-h-10 auth-bg-primary-50 dark:auth-bg-primary-900/20 auth-rounded-lg auth-flex auth-items-center auth-justify-center">
                                <i class="fa-solid fa-user auth-text-primary-600 dark:auth-text-primary-400"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="auth-px-8 auth-py-8">
                    <EditForm Model="@_profileModel" OnValidSubmit="SaveProfile" FormName="ProfileForm" method="post">
                        <DataAnnotationsValidator/>

                        <div class="auth-grid auth-grid-cols-1 auth-gap-y-6 auth-gap-x-8 lg:auth-grid-cols-2">

                            <div class="lg:auth-col-span-2">
                                <label class="auth-block auth-text-sm auth-font-semibold auth-mb-2"
                                       style="color:var(--text-secondary);">
                                    @Loc["Label_FullName"] <span class="auth-text-red-500">*</span>
                                </label>
                                <InputText @bind-Value="_profileModel.FullName"
                                           class="auth-block auth-w-full auth-px-4 auth-py-2.5 auth-border auth-rounded-lg focus:auth-ring-2 focus:auth-ring-primary-500/20 focus:auth-border-primary-500 auth-transition-colors auth-outline-none"
                                           style="background:var(--bg-elevated);color:var(--text-primary);border-color:var(--border);"
                                           placeholder="@Loc["Placeholder_FullName"]"/>
                                <ValidationMessage For="@(() => _profileModel.FullName)"
                                                   class="auth-text-red-500 auth-text-xs auth-mt-1"/>
                            </div>

                            <div>
                                <label class="auth-block auth-text-sm auth-font-semibold auth-mb-2"
                                       style="color:var(--text-secondary);">
                                    @Loc["Label_Email"]
                                </label>
                                <div class="auth-relative">
                                    <div
                                        class="auth-absolute auth-inset-y-0 auth-left-0 auth-pl-3 auth-flex auth-items-center auth-pointer-events-none">
                                        <i class="fa-solid fa-envelope auth-text-gray-400"></i>
                                    </div>
                                    <InputText @bind-Value="_profileModel.Email"
                                               class="auth-block auth-w-full auth-pl-10 auth-pr-4 auth-py-2.5 auth-border auth-rounded-lg auth-cursor-not-allowed"
                                               style="background:var(--bg-elevated);color:var(--text-secondary);border-color:var(--border);"
                                               disabled/>
                                </div>
                                <p class="auth-text-xs auth-text-gray-400 auth-mt-1.5">@Loc["Text_EmailChange"]</p>
                            </div>

                            <div>
                                <label class="auth-block auth-text-sm auth-font-semibold auth-mb-2"
                                       style="color:var(--text-secondary);">@Loc["Label_Phone"]</label>
                                <div class="auth-relative">
                                    <div
                                        class="auth-absolute auth-inset-y-0 auth-left-0 auth-pl-3 auth-flex auth-items-center auth-pointer-events-none">
                                        <i class="fa-solid fa-phone auth-text-gray-400"></i>
                                    </div>
                                    <InputText @bind-Value="_profileModel.PhoneNumber"
                                               class="auth-block auth-w-full auth-pl-10 auth-pr-4 auth-py-2.5 auth-border auth-rounded-lg focus:auth-ring-2 focus:auth-ring-primary-500/20 focus:auth-border-primary-500 auth-transition-colors auth-outline-none"
                                               style="background:var(--bg-elevated);color:var(--text-primary);border-color:var(--border);"
                                               placeholder="@Loc["Placeholder_Phone"]"/>
                                </div>
                                @if (!string.IsNullOrEmpty(_profileModel.PhoneNumber))
                                {
                                    <div class="auth-mt-2">
                                        @if (_phoneNumberConfirmed)
                                        {
                                            <span
                                                class="auth-inline-flex auth-items-center auth-gap-1 auth-text-xs auth-font-semibold auth-text-green-700 dark:auth-text-green-400">
                                                <i class="fa-solid fa-circle-check"></i> @Loc["Status_PhoneVerified"]
                                            </span>
                                        }
                                        else
                                        {
                                            <span
                                                class="auth-inline-flex auth-items-center auth-gap-1 auth-text-xs auth-font-semibold auth-text-yellow-600 dark:auth-text-yellow-400">
                                                <i class="fa-solid fa-circle-exclamation"></i> @Loc["Status_PhoneNotVerified"]
                                            </span>
                                        }
                                    </div>
                                    @if (!_phoneNumberConfirmed)
                                    {
                                        <div
                                            class="auth-mt-3 auth-p-4 auth-bg-yellow-50 dark:auth-bg-yellow-900/10 auth-border auth-border-yellow-200 dark:auth-border-yellow-900/30 auth-rounded-lg auth-space-y-3">
                                            <p class="auth-text-xs auth-text-yellow-700 dark:auth-text-yellow-400">@Loc["Text_PhoneVerifyHint"]</p>
                                            @if (!_verificationCodeSent)
                                            {
                                                <button type="button" @onclick="SendPhoneVerificationCode"
                                                        disabled="@_isSendingCode"
                                                        class="auth-inline-flex auth-items-center auth-px-4 auth-py-2 auth-text-sm auth-font-medium auth-rounded-lg disabled:auth-opacity-50 disabled:auth-cursor-not-allowed auth-transition-all"
                                                        style="background:var(--text-primary);color:var(--bg);">
                                                    @if (_isSendingCode)
                                                    {
                                                        <i class="fa-solid fa-circle-notch fa-spin auth-mr-2"></i>
                                                        <span>@Loc["Btn_Sending"]</span>
                                                    }
                                                    else
                                                    {
                                                        <i class="fa-solid fa-paper-plane auth-mr-2"></i>
                                                        <span>@Loc["Btn_SendCode"]</span>
                                                    }
                                                </button>
                                            }
                                            else
                                            {
                                                <div class="auth-flex auth-items-center auth-gap-2">
                                                    <input type="text" @bind="_verificationCode" maxlength="6"
                                                           aria-label="@Loc["Placeholder_Code"]"
                                                           class="auth-block auth-w-32 auth-px-3 auth-py-2 auth-text-center auth-border auth-rounded-lg auth-text-sm auth-tracking-widest focus:auth-ring-2 focus:auth-ring-primary-500/20 focus:auth-border-primary-500 auth-outline-none"
                                                           style="background:var(--bg-elevated);color:var(--text-primary);border-color:var(--border);"
                                                           placeholder="@Loc["Placeholder_Code"]"/>
                                                    <button type="button" @onclick="VerifyPhoneNumber"
                                                            disabled="@_isVerifying"
                                                            class="auth-inline-flex auth-items-center auth-px-4 auth-py-2 auth-text-sm auth-font-medium auth-text-white auth-bg-green-600 auth-rounded-lg hover:auth-bg-green-700 disabled:auth-opacity-50 disabled:auth-cursor-not-allowed auth-transition-all">
                                                        @if (_isVerifying)
                                                        {
                                                            <i class="fa-solid fa-circle-notch fa-spin auth-mr-2"></i>
                                                            <span>@Loc["Btn_Verifying"]</span>
                                                        }
                                                        else
                                                        {
                                                            <span>@Loc["Btn_Verify"]</span>
                                                        }
                                                    </button>
                                                    <button type="button" @onclick="ResendPhoneVerificationCode"
                                                            disabled="@_isSendingCode"
                                                            class="auth-text-xs auth-text-primary-600 dark:auth-text-primary-400 hover:auth-underline disabled:auth-opacity-50">
                                                        @Loc["Btn_Resend"]
                                                    </button>
                                                </div>
                                            }
                                        </div>
                                    }
                                }
                            </div>

                            <div>
                                <label class="auth-block auth-text-sm auth-font-semibold auth-mb-2"
                                       style="color:var(--text-secondary);">@Loc["Label_JobTitle"]</label>
                                <InputText @bind-Value="_profileModel.JobTitle"
                                           class="auth-block auth-w-full auth-px-4 auth-py-2.5 auth-border auth-rounded-lg focus:auth-ring-2 focus:auth-ring-primary-500/20 focus:auth-border-primary-500 auth-transition-colors auth-outline-none"
                                           style="background:var(--bg-elevated);color:var(--text-primary);border-color:var(--border);"
                                           placeholder="@Loc["Placeholder_JobTitle"]"/>
                            </div>

                            <div>
                                <label class="auth-block auth-text-sm auth-font-semibold auth-mb-2"
                                       style="color:var(--text-secondary);">@Loc["Label_Company"]</label>
                                <InputText @bind-Value="_profileModel.Company"
                                           class="auth-block auth-w-full auth-px-4 auth-py-2.5 auth-border auth-rounded-lg focus:auth-ring-2 focus:auth-ring-primary-500/20 focus:auth-border-primary-500 auth-transition-colors auth-outline-none"
                                           style="background:var(--bg-elevated);color:var(--text-primary);border-color:var(--border);"
                                           placeholder="@Loc["Placeholder_Company"]"/>
                            </div>

                            <div class="lg:auth-col-span-2">
                                <label class="auth-block auth-text-sm auth-font-semibold auth-mb-2"
                                       style="color:var(--text-secondary);">@Loc["Label_Bio"]</label>
                                <InputTextArea @bind-Value="_profileModel.Bio" rows="4"
                                               class="auth-block auth-w-full auth-px-4 auth-py-2.5 auth-border auth-rounded-lg focus:auth-ring-2 focus:auth-ring-primary-500/20 focus:auth-border-primary-500 auth-transition-colors auth-outline-none auth-resize-none"
                                               style="background:var(--bg-elevated);color:var(--text-primary);border-color:var(--border);"
                                               placeholder="@Loc["Placeholder_Bio"]"/>
                                <p class="auth-mt-1.5 auth-text-xs"
                                   style="color:var(--text-secondary);">@Loc["Text_BioLimit"]</p>
                            </div>
                        </div>

                        <div
                            class="auth-flex auth-flex-col sm:auth-flex-row sm:auth-items-center sm:auth-justify-between auth-pt-6 auth-border-t auth-mt-8"
                            style="border-color:var(--border);">
                            <div class="auth-flex auth-items-center auth-text-sm auth-mb-4 sm:auth-mb-0"
                                 style="color:var(--text-secondary);">
                                <i class="fa-solid fa-cloud-arrow-up auth-mr-2 auth-text-green-500"></i>
                                @Loc["Text_AutoSave"]
                            </div>
                            <div
                                class="auth-flex auth-flex-col sm:auth-flex-row sm:auth-items-center auth-space-y-3 sm:auth-space-y-0 sm:auth-space-x-3 auth-w-full sm:auth-w-auto">
                                <button type="button" @onclick="ReloadProfile"
                                        class="auth-w-full sm:auth-w-auto auth-px-5 auth-py-2.5 auth-text-sm auth-font-medium auth-border auth-rounded-lg auth-transition-all"
                                        style="background:transparent;border:1px solid var(--border);color:var(--text-primary);">
                                    @Loc["Btn_Reset"]
                                </button>
                                <button type="submit" disabled="@_isSaving"
                                        class="auth-w-full sm:auth-w-auto auth-px-6 auth-py-2.5 auth-text-sm auth-font-semibold auth-border auth-border-transparent auth-rounded-lg focus:auth-outline-none auth-shadow-md auth-transform hover:auth-scale-[1.02] auth-transition-all disabled:auth-opacity-50"
                                        style="background:var(--text-primary);color:var(--bg);">
                                    @if (_isSaving)
                                    {
                                        <span>@Loc["Btn_Saving"]</span>
                                    }
                                    else
                                    {
                                        <span>@Loc["Btn_SaveChanges"]</span>
                                    }
                                </button>
                            </div>
                        </div>
                    </EditForm>
                </div>
            </div>

            <div class="auth-mb-8 auth-rounded-xl auth-shadow-sm auth-border auth-overflow-hidden"
                 style="background:var(--bg-surface);border-color:var(--border);">
                <div class="auth-px-6 auth-py-4 auth-border-b" style="border-color:var(--border);">
                    <h3 class="auth-text-lg auth-font-bold"
                        style="color:var(--text-primary);">@Loc["Title_ProfilePic"]</h3>
                    <p class="auth-mt-1 auth-text-sm"
                       style="color:var(--text-secondary);">@Loc["Text_ProfilePicDesc"]</p>
                </div>
                <div class="auth-px-6 auth-py-6">
                    <div class="auth-flex auth-items-center auth-space-x-6">
                        <div class="auth-flex-shrink-0">
                            <img id="profile-image"
                                 class="auth-w-24 auth-h-24 auth-rounded-full auth-object-cover auth-border-4 auth-border-gray-100 dark:auth-border-gray-800"
                                 src="@_currentProfileImage" alt="Current profile photo">
                        </div>
                        <div class="auth-flex-1">
                            <div class="auth-flex auth-flex-wrap auth-items-center auth-gap-3">
                                <input type="file" id="profile-file-input" accept="image/jpeg,image/png,image/gif"
                                       class="auth-hidden"/>

                                <button id="change-profile-btn" type="button"
                                        class="auth-px-4 auth-py-2 auth-text-sm auth-font-medium auth-border auth-rounded-lg auth-transition-all"
                                        style="background:transparent;border:1px solid var(--border);color:var(--text-primary);">
                                    @Loc["Btn_Change"]
                                </button>
                                <button id="remove-profile-btn" type="button"
                                        class="auth-px-4 auth-py-2 auth-text-sm auth-font-medium auth-text-red-600 dark:auth-text-red-400 auth-bg-white dark:auth-bg-gray-800 auth-border auth-border-red-200 dark:auth-border-red-900/50 auth-rounded-lg hover:auth-bg-red-50 dark:hover:auth-bg-red-900/20 auth-transition-all">
                                    @Loc["Btn_Remove"]
                                </button>
                            </div>
                            <p class="auth-mt-2 auth-text-xs"
                               style="color:var(--text-secondary);">@Loc["Text_FileSpecs"]</p>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div id="crop-dialog" class="auth-fixed auth-inset-0 auth-z-[9999] auth-hidden" role="dialog" aria-modal="true">
            <div class="auth-flex auth-items-center auth-justify-center auth-min-h-screen auth-p-4">
                <div class="auth-fixed auth-inset-0 auth-bg-gray-900/80 auth-backdrop-blur-sm auth-transition-opacity"
                     aria-hidden="true"></div>

                <div
                    class="auth-relative auth-rounded-xl auth-shadow-2xl auth-max-w-lg auth-w-full auth-border auth-transform auth-transition-all"
                    style="background:var(--bg-surface);border-color:var(--border);">
                    <div class="auth-p-6">
                        <h3 class="auth-text-lg auth-font-bold auth-mb-4" id="crop-dialog-title"
                            style="color:var(--text-primary);">
                            @Loc["Title_Crop"]
                        </h3>
                        <div class="auth-flex auth-flex-col auth-items-center auth-space-y-4">
                            <div
                                class="auth-relative auth-bg-gray-100 dark:auth-bg-gray-800 auth-rounded-lg auth-p-2 auth-overflow-hidden">
                                <canvas id="crop-canvas" width="350" height="350"
                                        class="auth-rounded auth-cursor-crosshair"></canvas>
                            </div>
                            <div class="auth-text-xs auth-text-center" style="color:var(--text-secondary);">
                                @Loc["Text_CropInstruction"]
                            </div>
                        </div>
                    </div>
                    <div
                        class="auth-px-6 auth-py-4 auth-flex auth-justify-end auth-space-x-3 auth-border-t auth-rounded-b-xl"
                        style="background:var(--bg-elevated);border-color:var(--border);">
                        <button id="crop-cancel-btn" type="button"
                                class="auth-px-4 auth-py-2 auth-text-sm auth-font-medium auth-border auth-rounded-lg auth-transition-all"
                                style="background:transparent;border:1px solid var(--border);color:var(--text-primary);">
                            @Loc["Btn_Cancel"]
                        </button>
                        <button id="crop-apply-btn" type="button"
                                class="auth-px-4 auth-py-2 auth-text-sm font-semibold auth-border auth-border-transparent auth-rounded-lg auth-transition-all"
                                style="background:var(--text-primary);color:var(--bg);">
                            @Loc["Btn_Apply"]
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {

    // Der Code-Teil bleibt exakt gleich wie vorher, da sich nur das HTML/CSS geändert hat.
    // Ich füge ihn hier der Vollständigkeit halber ein.
    private PersonalInformationUpdateRequest _profileModel = new();
    private string _currentProfileImage = "https://api.dicebear.com/7.x/avataaars/svg?seed";

    private bool _isLoading = true;
    private bool _isSaving = false;
    private bool _showNotification = false;
    private string _notificationMessage = "";
    private string _notificationClass = "auth-bg-green-500 auth-text-white";

    // Phone verification state
    private bool _phoneNumberConfirmed = false;
    private bool _verificationCodeSent = false;
    private string _verificationCode = "";
    private bool _isSendingCode = false;
    private bool _isVerifying = false;

    private IJSObjectReference? _module;
    private DotNetObjectReference<ProfileSettings>? _objRef;
    private ElementReference _rootElement;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JS.InvokeVoidAsync("applyTheme");
                _module = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/Authify.UI/js/profile-settings.js");
                _objRef = DotNetObjectReference.Create(this);
                await _module.InvokeVoidAsync("init", _rootElement, _objRef);
            }
            catch (Exception e)
            {
                Console.WriteLine("JS Init failed: " + e.Message);
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        await LoadProfileData();
        _isLoading = false;
    }

    private async Task LoadProfileData()
    {
        var result = await DataService.GetProfileAsync();
        if (result.Success && result.Data != null)
        {
            var data = result.Data;
            _profileModel = new PersonalInformationUpdateRequest
            {
                FullName = data.FullName,
                Email = data.Email,
                PhoneNumber = data.PhoneNumber,
                JobTitle = data.JobTitle,
                Company = data.Company,
                Bio = data.Bio
            };
            _phoneNumberConfirmed = data.PhoneNumberConfirmed;
            _verificationCodeSent = false;
            _verificationCode = "";

            if (data.ProfileImage != null && data.ProfileImage.Length > 0)
            {
                var base64 = Convert.ToBase64String(data.ProfileImage);
                _currentProfileImage = $"data:image/png;base64,{base64}";
            }
        }
    }

    private async Task SaveProfile()
    {
        _isSaving = true;
        var result = await DataService.UpdatePersonalInformationAsync(_profileModel);
        if (result.Success)
        {
            ShowNotification(Loc["Msg_ProfileUpdated"], "auth-bg-green-500");
            // Reload to get updated PhoneNumberConfirmed status
            await LoadProfileData();
        }
        else ShowNotification(result.ErrorMessage ?? Loc["Msg_UpdateFailed"], "auth-bg-red-500");

        _isSaving = false;
    }

    private async Task ReloadProfile()
    {
        _isLoading = true;
        await LoadProfileData();
        _isLoading = false;
        ShowNotification(Loc["Msg_Reset"], "auth-bg-gray-500");
    }

    [JSInvokable]
    public async Task UpdateProfileImage(string base64DataUrl)
    {
        _currentProfileImage = base64DataUrl;
        StateHasChanged();

        var base64 = base64DataUrl.Substring(base64DataUrl.IndexOf(",") + 1);
        var bytes = Convert.FromBase64String(base64);
        var request = new ProfileImageUpdateRequest { Image = bytes };
        var result = await DataService.UpdateProfileImageAsync(request);

        if (result.Success) ShowNotification(Loc["Msg_PicUpdated"], "auth-bg-green-500");
        else ShowNotification(Loc["Msg_PicUploadFailed"], "auth-bg-red-500");
    }

    [JSInvokable]
    public async Task RemoveProfileImage()
    {
        _currentProfileImage = "https://api.dicebear.com/7.x/avataaars/svg?seed";
        StateHasChanged();

        var request = new ProfileImageUpdateRequest { Image = null };
        var result = await DataService.UpdateProfileImageAsync(request);

        if (result.Success) ShowNotification(Loc["Msg_PicRemoved"], "auth-bg-blue-500");
        else ShowNotification(Loc["Msg_PicRemoveFailed"], "auth-bg-red-500");
    }

    private void ShowNotification(string message, string cssClass)
    {
        _notificationMessage = message;
        _notificationClass = cssClass + " auth-text-white";
        _showNotification = true;
        StateHasChanged();
        var timer = new System.Threading.Timer((_) =>
        {
            _showNotification = false;
            InvokeAsync(StateHasChanged);
        }, null, 3000, System.Threading.Timeout.Infinite);
    }

    private async Task SendPhoneVerificationCode()
    {
        _isSendingCode = true;
        var result = await DataService.SendPhoneVerificationCodeAsync();
        if (result.Success)
        {
            _verificationCodeSent = true;
            ShowNotification(Loc["Msg_CodeSent"], "auth-bg-blue-500");
        }
        else ShowNotification(result.ErrorMessage ?? Loc["Msg_CodeSendFailed"], "auth-bg-red-500");

        _isSendingCode = false;
    }

    private async Task ResendPhoneVerificationCode()
    {
        _verificationCode = "";
        await SendPhoneVerificationCode();
    }

    private async Task VerifyPhoneNumber()
    {
        if (string.IsNullOrWhiteSpace(_verificationCode)) return;
        _isVerifying = true;
        var result = await DataService.VerifyPhoneNumberAsync(_verificationCode);
        if (result.Success)
        {
            _phoneNumberConfirmed = true;
            _verificationCodeSent = false;
            _verificationCode = "";
            ShowNotification(Loc["Msg_PhoneVerified"], "auth-bg-green-500");
        }
        else ShowNotification(result.ErrorMessage ?? Loc["Msg_PhoneVerifyFailed"], "auth-bg-red-500");

        _isVerifying = false;
    }

    public void Dispose()
    {
        _objRef?.Dispose();
    }

}
