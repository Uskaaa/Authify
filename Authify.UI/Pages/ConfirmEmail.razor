@page "/confirm-email"
@using Microsoft.JSInterop
@using Microsoft.Extensions.Localization

@inject NavigationManager NavigationManager
@inject IAuthifyDataService DataService
@inject IJSRuntime JS
@inject IStringLocalizer<ConfirmEmail> Loc

<RedirectToHomeIfAuthenticated />

<div style="min-height:100dvh;background:var(--bg);display:flex;align-items:center;justify-content:center;font-family:'DM Sans',system-ui,sans-serif;padding:2rem 1rem;">
    <div style="width:min(420px,100%);">

        <div style="background:var(--bg-surface);border:1px solid var(--border);border-radius:12px;padding:2rem;text-align:center;">

            @switch (_status)
            {
                case ConfirmStatus.Instruction:
                    <div style="width:4rem;height:4rem;border-radius:50%;background:var(--accent-subtle);display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;">
                        <i class="fas fa-envelope" style="font-size:1.5rem;color:var(--text-primary);"></i>
                    </div>
                    <h1 style="font-family:'Syne',system-ui,sans-serif;font-weight:400;font-size:1.5rem;color:var(--text-primary);margin:0 0 0.75rem;">@Loc["Title_VerifyEmail"]</h1>
                    <p style="font-size:0.875rem;color:var(--text-secondary);margin:0 0 0.25rem;">
                        @Loc["Text_SentTo"]
                    </p>
                    <p style="font-size:0.875rem;color:var(--text-primary);font-weight:500;margin:0 0 0.5rem;">@_email</p>
                    <p style="font-size:0.875rem;color:var(--text-secondary);margin:0 0 1.5rem;">@Loc["Text_Instruction"]</p>
                    <a href="@("login" + (!string.IsNullOrEmpty(_returnUrl) ? "?returnUrl=" + Uri.EscapeDataString(_returnUrl) : ""))"
                       style="display:inline-block;background:transparent;border:1px solid var(--border);border-radius:8px;padding:0.625rem 1.5rem;font-size:0.875rem;color:var(--text-primary);text-decoration:none;font-family:inherit;">
                        @Loc["Btn_BackToLogin"]
                    </a>
                    break;

                case ConfirmStatus.Verifying:
                    <div style="width:4rem;height:4rem;border-radius:50%;background:var(--accent-subtle);display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;">
                        <i class="fas fa-spinner fa-spin" style="font-size:1.5rem;color:var(--text-primary);"></i>
                    </div>
                    <h1 style="font-family:'Syne',system-ui,sans-serif;font-weight:400;font-size:1.5rem;color:var(--text-primary);margin:0 0 0.5rem;">@Loc["Title_Verifying"]</h1>
                    <p style="font-size:0.875rem;color:var(--text-secondary);margin:0;">@Loc["Text_Verifying"]</p>
                    break;

                case ConfirmStatus.Success:
                    <div style="width:4rem;height:4rem;border-radius:50%;background:rgba(16,185,129,0.15);display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;">
                        <i class="fas fa-check-circle" style="font-size:1.5rem;color:#10b981;"></i>
                    </div>
                    <h1 style="font-family:'Syne',system-ui,sans-serif;font-weight:400;font-size:1.5rem;color:var(--text-primary);margin:0 0 0.5rem;">@Loc["Title_Success"]</h1>
                    <p style="font-size:0.875rem;color:var(--text-secondary);margin:0 0 1.5rem;">@Loc["Text_Success"]</p>
                    <button @onclick="NavigateToLogin"
                            style="width:100%;background:var(--text-primary);color:var(--bg);border:none;border-radius:100px;padding:0.75rem;font-size:0.875rem;font-weight:500;cursor:pointer;font-family:inherit;">
                        @Loc["Btn_GoToLogin"]
                    </button>
                    break;

                case ConfirmStatus.Error:
                    <div style="width:4rem;height:4rem;border-radius:50%;background:rgba(239,68,68,0.15);display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;">
                        <i class="fas fa-times-circle" style="font-size:1.5rem;color:#ef4444;"></i>
                    </div>
                    <h1 style="font-family:'Syne',system-ui,sans-serif;font-weight:400;font-size:1.5rem;color:var(--text-primary);margin:0 0 0.5rem;">@Loc["Title_Error"]</h1>
                    <p style="font-size:0.875rem;color:var(--text-secondary);margin:0 0 1.5rem;">@Loc["Text_Error"]</p>
                    <a href="register"
                       style="display:block;width:100%;background:var(--text-primary);color:var(--bg);border:none;border-radius:100px;padding:0.75rem;font-size:0.875rem;font-weight:500;cursor:pointer;font-family:inherit;text-decoration:none;box-sizing:border-box;">
                        @Loc["Btn_RetryRegister"]
                    </a>
                    break;
            }

        </div>
    </div>
</div>

@code {
    private enum ConfirmStatus { Instruction, Verifying, Success, Error }

    private ConfirmStatus _status = ConfirmStatus.Instruction;
    private string _email = "";
    private EmailConfirmationRequest _request = new();
    private string? _returnUrl;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("applyTheme");
    }

    protected override async Task OnInitializedAsync()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        var userId = query.GetValueOrDefault("userId").ToString();
        var token = query.GetValueOrDefault("token").ToString();
        _email = query.GetValueOrDefault("email").ToString() ?? "your email";
        _returnUrl = query.GetValueOrDefault("returnUrl").ToString();
        if (string.IsNullOrEmpty(_returnUrl)) _returnUrl = null;

        if (string.IsNullOrEmpty(userId) || string.IsNullOrEmpty(token))
        {
            _status = ConfirmStatus.Instruction;
        }
        else
        {
            _status = ConfirmStatus.Verifying;
            _request.UserId = userId;
            _request.Token = token;
            await Task.Delay(800);
            await VerifyEmail();
        }
    }

    private async Task VerifyEmail()
    {
        var result = await DataService.ConfirmEmailAsync(_request);
        _status = result.Success ? ConfirmStatus.Success : ConfirmStatus.Error;
    }

    private void NavigateToLogin()
    {
        var loginUrl = "/login";
        if (!string.IsNullOrEmpty(_returnUrl))
            loginUrl += "?returnUrl=" + Uri.EscapeDataString(_returnUrl);
        NavigationManager.NavigateTo(loginUrl);
    }
}
