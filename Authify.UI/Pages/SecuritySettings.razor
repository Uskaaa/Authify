    private async Task ToggleProvider(ExternalProvider provider)
    {
        if (provider.IsConnected)
        {
            var result = await DataService.DisconnectProviderAsync(provider.LoginProvider);
            if (result.Success) 
            {
                provider.IsConnected = false;
                ShowNotification(string.Format(Loc["Msg_ProviderDisconnected"], provider.Name), "auth-bg-blue-500");
            }
            else ShowNotification(result.ErrorMessage ?? Loc["Msg_DisconnectFailed"], "auth-bg-red-500");
        }
        else
        {
            var accessToken = await DataService.GetAccessTokenAsync();
            NavigationManager.NavigateTo($"/auth/external-login?provider={provider.LoginProvider}&returnUrl=/security-settings&mode=connect&access_token={accessToken}", forceLoad: true);
        }
    }

    // --- 2FA LOGIC ---
    private async Task LoadTwoFaStatus()
    {
        var result = await DataService.GetAllAsync();
        _activeTwoFaMethods.Clear();
        _availableTwoFaMethods.Clear();

        if (result.Success && result.Data != null)
        {
            var user2fa = result.Data;

            foreach(var supported in _allSupportedMethods)
            {
                var active = user2fa.FirstOrDefault(u => u.Method == supported.MethodType && u.IsEnabled);
                var model = supported.Clone();
                if (active != null)
                {
                    model.Priority = active.Priority;
                    model.IsEnabled = true;
                    _activeTwoFaMethods.Add(model);
                }
                else
                {
                    model.IsEnabled = false;
                    _availableTwoFaMethods.Add(model);
                }
            }

            _activeTwoFaMethods.Sort((x, y) => x.Priority.CompareTo(y.Priority));
        }
        else
        {
            foreach (var m in _allSupportedMethods)
            {
                var model = m.Clone();
                model.IsEnabled = false;
                _availableTwoFaMethods.Add(model);
            }
        }
        await InvokeAsync(StateHasChanged);
    }


