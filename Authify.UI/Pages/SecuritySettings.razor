        // Updated Classes with auth- prefix
        _providers.Add(new ExternalProvider { Name = "Google",   LoginProvider = "Google",   Icon = "fa-brands fa-google",   BgClass = "auth-bg-red-100 dark:auth-bg-red-900/50",   TextClass = "auth-text-red-600 dark:auth-text-red-400" });
