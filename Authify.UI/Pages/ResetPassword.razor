@page "/reset-password"
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.Extensions.Localization
@inject NavigationManager NavigationManager
@inject IAuthifyDataService DataService
@inject IJSRuntime JS
@inject IStringLocalizer<ResetPassword> Loc

<RedirectToHomeIfAuthenticated />

<div style="min-height:100dvh;background:var(--bg);display:flex;align-items:center;justify-content:center;font-family:'DM Sans',system-ui,sans-serif;padding:2rem 1rem;">
    <div style="width:min(420px,100%);">

        <div style="background:var(--bg-surface);border:1px solid var(--border);border-radius:12px;padding:2rem;">

            @if (!_isSuccess)
            {
                <div style="margin-bottom:1.75rem;">
                    <h1 style="font-family:'Syne',system-ui,sans-serif;font-weight:400;font-size:1.5rem;color:var(--text-primary);margin:0 0 0.25rem;">@Loc["Title_ResetPassword"]</h1>
                    <p style="font-size:0.875rem;color:var(--text-secondary);margin:0;">@Loc["Subtitle_EnterNew"]</p>
                </div>

                @if (string.IsNullOrEmpty(_request.Email) || string.IsNullOrEmpty(_request.Token))
                {
                    <div style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.25);color:#ef4444;padding:0.75rem 1rem;border-radius:8px;font-size:0.875rem;margin-bottom:1.25rem;">
                        @Loc["Error_InvalidLink"]
                    </div>
                }

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.25);color:#ef4444;padding:0.75rem 1rem;border-radius:8px;font-size:0.875rem;margin-bottom:1.25rem;">
                        @_errorMessage
                    </div>
                }

                <EditForm Model="_request" OnValidSubmit="HandleValidSubmit" FormName="ResetPasswordForm" method="post">
                    <DataAnnotationsValidator />

                    <div style="display:flex;flex-direction:column;gap:1rem;">

                        <div>
                            <label style="display:block;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--text-secondary);margin-bottom:0.375rem;">@Loc["Label_NewPassword"]</label>
                            <div style="position:relative;">
                                <InputText id="password" @bind-Value="_request.NewPassword" type="@(_showPassword ? "text" : "password")"
                                           style="width:100%;background:var(--bg-elevated);border:1px solid var(--border);border-radius:8px;padding:0.75rem 3rem 0.75rem 1rem;font-size:0.875rem;color:var(--text-primary);outline:none;box-sizing:border-box;font-family:inherit;" />
                                <button type="button" @onclick="TogglePasswordVisibility" tabindex="-1"
                                        style="position:absolute;right:0.75rem;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--text-muted);cursor:pointer;padding:0;line-height:1;">
                                    <i class="fas @(_showPassword ? "fa-eye-slash" : "fa-eye")"></i>
                                </button>
                            </div>
                            <ValidationMessage For="@(() => _request.NewPassword)" />
                        </div>

                        <div>
                            <label style="display:block;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--text-secondary);margin-bottom:0.375rem;">@Loc["Label_ConfirmPassword"]</label>
                            <div style="position:relative;">
                                <InputText id="confirmPassword" @bind-Value="_request.ConfirmNewPassword" type="@(_showConfirmPassword ? "text" : "password")"
                                           style="width:100%;background:var(--bg-elevated);border:1px solid var(--border);border-radius:8px;padding:0.75rem 3rem 0.75rem 1rem;font-size:0.875rem;color:var(--text-primary);outline:none;box-sizing:border-box;font-family:inherit;" />
                                <button type="button" @onclick="ToggleConfirmPasswordVisibility" tabindex="-1"
                                        style="position:absolute;right:0.75rem;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--text-muted);cursor:pointer;padding:0;line-height:1;">
                                    <i class="fas @(_showConfirmPassword ? "fa-eye-slash" : "fa-eye")"></i>
                                </button>
                            </div>
                            <ValidationMessage For="@(() => _request.ConfirmNewPassword)" />
                        </div>

                        <button type="submit" disabled="@(_isLoading || string.IsNullOrEmpty(_request.Token))"
                                style="width:100%;background:var(--text-primary);color:var(--bg);border:none;border-radius:100px;padding:0.75rem;font-size:0.875rem;font-weight:500;cursor:pointer;font-family:inherit;display:flex;align-items:center;justify-content:center;gap:0.5rem;">
                            @if (_isLoading)
                            {
                                <i class="fas fa-spinner fa-spin"></i>
                            }
                            <span>@(_isLoading ? Loc["Btn_Resetting"] : Loc["Btn_ResetPassword"])</span>
                        </button>

                    </div>
                </EditForm>
            }
            else
            {
                <div style="text-align:center;padding:1rem 0;">
                    <div style="width:4rem;height:4rem;border-radius:50%;background:rgba(16,185,129,0.15);display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;">
                        <i class="fas fa-check-circle" style="font-size:1.5rem;color:#10b981;"></i>
                    </div>
                    <h1 style="font-family:'Syne',system-ui,sans-serif;font-weight:400;font-size:1.5rem;color:var(--text-primary);margin:0 0 0.5rem;">@Loc["Title_Success"]</h1>
                    <p style="font-size:0.875rem;color:var(--text-secondary);margin:0 0 1.5rem;">@Loc["Text_Success"]</p>
                    <button @onclick="NavigateToLogin"
                            style="width:100%;background:var(--text-primary);color:var(--bg);border:none;border-radius:100px;padding:0.75rem;font-size:0.875rem;font-weight:500;cursor:pointer;font-family:inherit;">
                        @Loc["Btn_GoToLogin"]
                    </button>
                </div>
            }

        </div>
    </div>
</div>

@code {
    private ResetPasswordRequest _request = new();
    private bool _isLoading = false;
    private bool _isSuccess = false;
    private bool _showPassword = false;
    private bool _showConfirmPassword = false;
    private string? _errorMessage;

    protected override void OnInitialized()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("email", out var email))
            _request.Email = email!;

        if (query.TryGetValue("token", out var token))
            _request.Token = token!;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("applyTheme");
    }

    private async Task HandleValidSubmit()
    {
        if (string.IsNullOrEmpty(_request.Email) || string.IsNullOrEmpty(_request.Token))
            return;

        _isLoading = true;
        var result = await DataService.ResetPasswordAsync(_request);
        _isLoading = false;

        if (result.Success)
            _isSuccess = true;
        else
            _errorMessage = result.ErrorMessage;
    }

    private void TogglePasswordVisibility() => _showPassword = !_showPassword;
    private void ToggleConfirmPasswordVisibility() => _showConfirmPassword = !_showConfirmPassword;

    private Task NavigateToLogin()
    {
        NavigationManager.NavigateTo("/login");
        return Task.CompletedTask;
    }
}
