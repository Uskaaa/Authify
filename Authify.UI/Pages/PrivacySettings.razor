@page "/privacy-settings"
@using Microsoft.AspNetCore.Components.Web
@using Authify.Core.Common
@using Microsoft.JSInterop
@using Microsoft.Extensions.Localization

@layout ProfileLayout
@inject IJSRuntime JS
@inject IAuthifyDataService DataService
@inject NavigationManager NavigationManager
@inject IStringLocalizer<PrivacySettings> Loc

@if (_showNotification)
{
    <div class="auth-fixed auth-top-20 auth-right-4 auth-z-[10000] auth-px-4 auth-py-3 auth-rounded-lg auth-shadow-xl auth-max-w-sm auth-transform auth-transition-all auth-duration-300 @_notificationClass auth-animate-fade-in-down auth-border auth-border-white/10">
        <div class="auth-flex auth-items-center auth-font-medium">
            @if (_notificationClass.Contains("auth-bg-green")) { <i class="fa-solid fa-check-circle auth-mr-2"></i> }
            else if (_notificationClass.Contains("auth-bg-red")) { <i class="fa-solid fa-circle-xmark auth-mr-2"></i> }
            else { <i class="fa-solid fa-info-circle auth-mr-2"></i> }
            @_notificationMessage
        </div>
    </div>
}

<div class="auth-px-4 lg:auth-px-6 auth-py-4 sm:auth-py-6 lg:auth-py-8 auth-min-h-screen" style="background:var(--bg);">
    <div class="auth-max-w-7xl auth-space-y-6">
        <div class="auth-flex auth-flex-col sm:auth-flex-row sm:auth-items-center auth-justify-between auth-gap-4">
            <div>
                <h1 class="heading-4" style="color:var(--text-primary);">
                    @Loc["Title_Page"]
                </h1>
                <p class="auth-mt-1 auth-text-sm" style="color:var(--text-secondary);">
                    @Loc["Subtitle_Page"]
                </p>
            </div>
        </div>
        
        <div class="auth-mb-8 auth-rounded-xl auth-shadow-sm auth-border auth-overflow-hidden auth-transition-colors auth-duration-300" style="background:var(--bg-surface);border-color:var(--border);">

            <div class="auth-px-8 auth-py-6 auth-border-b" style="border-color:var(--border);">
                <div class="auth-flex auth-items-center auth-justify-between">
                    <div>
                        <h3 class="auth-text-lg auth-font-bold" style="color:var(--text-primary);">@Loc["Title_MainCard"]</h3>
                        <p class="auth-mt-1 auth-text-sm" style="color:var(--text-secondary);">@Loc["Text_MainCardDesc"]</p>
                    </div>
                    <div class="auth-flex-shrink-0">
                        <div class="auth-w-10 auth-h-10 auth-bg-emerald-50 dark:auth-bg-emerald-900/20 auth-rounded-lg auth-flex auth-items-center auth-justify-center">
                            <svg class="auth-w-5 auth-h-5 auth-text-emerald-600 dark:auth-text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                            </svg>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="auth-px-8 auth-py-8 auth-space-y-8">
                
                <div class="auth-space-y-6">
                    <div class="auth-flex auth-items-center auth-space-x-3">
                        <div class="auth-w-8 auth-h-8 auth-bg-blue-50 dark:auth-bg-blue-900/20 auth-rounded-lg auth-flex auth-items-center auth-justify-center">
                            <svg class="auth-w-4 auth-h-4 auth-text-blue-600 dark:auth-text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                            </svg>
                        </div>
                        <div>
                            <h4 class="auth-text-base auth-font-semibold" style="color:var(--text-primary);">@Loc["Title_Export"]</h4>
                            <p class="auth-text-sm" style="color:var(--text-secondary);">@Loc["Text_ExportDesc"]</p>
                        </div>
                    </div>
                    
                    <div class="auth-bg-blue-50 dark:auth-bg-blue-900/10 auth-border auth-border-blue-100 dark:auth-border-blue-900/30 auth-rounded-xl auth-p-5">
                        <div class="auth-flex auth-items-start">
                            <svg class="auth-w-5 auth-h-5 auth-text-blue-500 dark:auth-text-blue-400 auth-mt-0.5 auth-mr-3" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
                            </svg>
                            <div class="auth-flex-1">
                                <h6 class="auth-text-sm auth-font-medium auth-text-blue-800 dark:auth-text-blue-300">@Loc["Title_ExportInfo"]</h6>
                                <ul class="auth-text-sm auth-text-blue-700 dark:auth-text-blue-400 auth-mt-2 auth-space-y-1 auth-list-disc auth-list-inside">
                                    <li>@Loc["List_Export_1"]</li>
                                    <li>@Loc["List_Export_2"]</li>
                                    <li>@Loc["List_Export_3"]</li>
                                    <li>@Loc["List_Export_4"]</li>
                                    <li>@Loc["List_Export_5"]</li>
                                </ul>
                                <p class="auth-text-xs auth-text-blue-600 dark:auth-text-blue-500 auth-mt-3">@Loc["Text_ExportNote"]</p>
                            </div>
                        </div>
                    </div>

                    <button @onclick="ExportData" disabled="@_isExporting" class="auth-w-full auth-flex auth-items-center auth-justify-center auth-px-6 auth-py-3 auth-text-sm auth-font-semibold auth-text-blue-700 auth-bg-white auth-border auth-border-blue-200 auth-rounded-xl hover:auth-bg-blue-50 hover:auth-border-blue-300 focus:auth-outline-none focus:auth-ring-2 focus:auth-ring-offset-2 focus:auth-ring-blue-500 auth-transition-all auth-duration-200 dark:auth-text-blue-400 dark:auth-bg-gray-900 dark:auth-border-blue-900 dark:hover:auth-bg-gray-800 dark:hover:auth-border-blue-800 dark:focus:auth-ring-offset-gray-900 disabled:auth-opacity-60 disabled:auth-cursor-not-allowed">
                        @if (_isExporting)
                        {
                            <i class="fa-solid fa-circle-notch fa-spin auth-mr-2"></i> <span>@Loc["Btn_Exporting"]</span>
                        }
                        else
                        {
                            <i class="fa-solid fa-download auth-mr-2"></i>
                            <span>@Loc["Btn_Export"]</span>
                        }
                    </button>
                </div>

                <div class="auth-border-t" style="border-color:var(--border);"></div>

                <div class="auth-space-y-6">
                    <div class="auth-flex auth-items-center auth-space-x-3">
                        <div class="auth-w-8 auth-h-8 auth-bg-yellow-50 dark:auth-bg-yellow-900/20 auth-rounded-lg auth-flex auth-items-center auth-justify-center">
                            <svg class="auth-w-4 auth-h-4 auth-text-yellow-600 dark:auth-text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
                            </svg>
                        </div>
                        <div>
                            <h4 class="auth-text-base auth-font-semibold" style="color:var(--text-primary);">@Loc["Title_Deactivate"]</h4>
                            <p class="auth-text-sm" style="color:var(--text-secondary);">@Loc["Text_DeactivateDesc"]</p>
                        </div>
                    </div>
                    
                    <div class="auth-bg-yellow-50 dark:auth-bg-yellow-900/10 auth-border auth-border-yellow-100 dark:auth-border-yellow-900/30 auth-rounded-xl auth-p-5">
                        <div class="auth-flex auth-items-start">
                            <svg class="auth-w-5 auth-h-5 auth-text-yellow-500 dark:auth-text-yellow-400 auth-mt-0.5 auth-mr-3" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
                            </svg>
                            <div class="auth-flex-1">
                                <h6 class="auth-text-sm auth-font-medium auth-text-yellow-800 dark:auth-text-yellow-300">@Loc["Title_DeactivateInfo"]</h6>
                                <ul class="auth-text-sm auth-text-yellow-700 dark:auth-text-yellow-400 auth-mt-2 auth-space-y-1 auth-list-disc auth-list-inside">
                                    <li>@Loc["List_Deactivate_1"]</li>
                                    <li>@Loc["List_Deactivate_2"]</li>
                                    <li>@Loc["List_Deactivate_3"]</li>
                                    <li>@Loc["List_Deactivate_4"]</li>
                                    <li>@Loc["List_Deactivate_5"]</li>
                                </ul>
                                <p class="auth-text-xs auth-text-yellow-600 dark:auth-text-yellow-500 auth-mt-3">@Loc["Text_DeactivateNote"]</p>
                            </div>
                        </div>
                    </div>

                    <button @onclick="OpenDeactivateModal" class="auth-w-full auth-flex auth-items-center auth-justify-center auth-px-6 auth-py-3 auth-text-sm auth-font-semibold auth-text-yellow-700 auth-bg-yellow-50 auth-border-2 auth-border-yellow-200 auth-rounded-xl hover:auth-bg-yellow-100 hover:auth-border-yellow-300 focus:auth-outline-none focus:auth-ring-2 focus:auth-ring-offset-2 focus:auth-ring-yellow-500 auth-transition-all auth-duration-200 dark:auth-text-yellow-400 dark:auth-bg-yellow-900/20 dark:auth-border-yellow-800/50 dark:hover:auth-bg-yellow-900/30 dark:hover:auth-border-yellow-700 dark:focus:auth-ring-offset-gray-900">
                        <i class="fa-solid fa-power-off auth-mr-2"></i>
                        @Loc["Btn_Deactivate"]
                    </button>
                </div>

                <div class="auth-border-t" style="border-color:var(--border);"></div>

                <div class="auth-space-y-6">
                    <div class="auth-flex auth-items-center auth-space-x-3">
                        <div class="auth-w-8 auth-h-8 auth-bg-red-50 dark:auth-bg-red-900/20 auth-rounded-lg auth-flex auth-items-center auth-justify-center">
                            <svg class="auth-w-4 auth-h-4 auth-text-red-600 dark:auth-text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                            </svg>
                        </div>
                        <div>
                            <h4 class="auth-text-base auth-font-semibold" style="color:var(--text-primary);">@Loc["Title_Delete"]</h4>
                            <p class="auth-text-sm" style="color:var(--text-secondary);">@Loc["Text_DeleteDesc"]</p>
                        </div>
                    </div>
                    
                    <div class="auth-bg-red-50 dark:auth-bg-red-900/10 auth-border auth-border-red-100 dark:auth-border-red-900/30 auth-rounded-xl auth-p-5">
                        <div class="auth-flex auth-items-start">
                            <svg class="auth-w-5 auth-h-5 auth-text-red-500 dark:auth-text-red-400 auth-mt-0.5 auth-mr-3" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
                            </svg>
                            <div class="auth-flex-1">
                                <h6 class="auth-text-sm auth-font-medium auth-text-red-800 dark:auth-text-red-300">@Loc["Title_DeleteInfo"]</h6>
                                <ul class="auth-text-sm auth-text-red-700 dark:auth-text-red-400 auth-mt-2 auth-space-y-1 auth-list-disc auth-list-inside">
                                    <li>@Loc["List_Delete_1"]</li>
                                    <li>@Loc["List_Delete_2"]</li>
                                    <li>@Loc["List_Delete_3"]</li>
                                    <li>@Loc["List_Delete_4"]</li>
                                    <li>@Loc["List_Delete_5"]</li>
                                </ul>
                                <p class="auth-text-xs auth-text-red-600 dark:auth-text-red-500 auth-mt-3 auth-font-medium">@Loc["Text_DeleteNote"]</p>
                            </div>
                        </div>
                    </div>

                    <button id="delete-account-btn" @onclick="OpenDeleteModal" class="auth-w-full auth-flex auth-items-center auth-justify-center auth-px-6 auth-py-3 auth-text-sm auth-font-bold auth-text-white auth-bg-red-600 auth-border auth-border-transparent auth-rounded-xl hover:auth-bg-red-700 focus:auth-outline-none focus:auth-ring-2 focus:auth-ring-offset-2 focus:auth-ring-red-500 auth-transform hover:auth-scale-[1.02] auth-transition-all auth-duration-200 auth-shadow-md hover:auth-shadow-lg dark:focus:auth-ring-offset-gray-900">
                        <i class="fa-solid fa-trash auth-mr-2"></i>
                        @Loc["Btn_DeletePermanently"]
                    </button>
                </div>

                <div class="auth-pt-8 auth-border-t" style="border-color:var(--border);">
                    <div class="auth-rounded-xl auth-p-5 auth-border" style="background:var(--bg-elevated);border-color:var(--border);">
                        <div class="auth-flex auth-items-center">
                            <svg class="auth-w-5 auth-h-5 auth-text-gray-400 auth-mr-3 dark:auth-text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                            <div>
                                <h5 class="auth-text-sm auth-font-semibold" style="color:var(--text-primary);">@Loc["Title_NeedHelp"]</h5>
                                <p class="auth-text-xs auth-mt-1" style="color:var(--text-secondary);">
                                    @Loc["Text_HelpDesc"] 
                                    <a href="#" class="auth-text-primary-600 hover:auth-text-primary-700 auth-font-medium dark:auth-text-primary-400 dark:hover:auth-text-primary-300">@Loc["Link_ContactSupport"]</a>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (_showDeactivateModal)
{
