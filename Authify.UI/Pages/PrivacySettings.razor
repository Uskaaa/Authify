        <div class="auth-flex auth-items-center auth-justify-center auth-min-h-screen auth-pt-4 auth-px-4 auth-pb-20 auth-text-center sm:auth-block sm:auth-p-0">
            <div class="auth-fixed auth-inset-0 auth-bg-gray-900/80 auth-backdrop-blur-sm auth-transition-opacity" @onclick="CloseDeactivateModal"></div>
            <span class="auth-hidden sm:auth-inline-block sm:auth-align-middle sm:auth-h-screen">&#8203;</span>
            <div class="auth-inline-block auth-align-bottom auth-rounded-xl auth-text-left auth-overflow-hidden auth-shadow-2xl auth-transform auth-transition-all sm:auth-my-8 sm:auth-align-middle sm:auth-max-w-lg sm:auth-w-full auth-border" style="background:var(--bg-surface);border-color:var(--border);">
                <div class="auth-px-4 auth-pt-5 auth-pb-4 sm:auth-p-6 sm:auth-pb-4" style="background:var(--bg-surface);">
                    <div class="sm:auth-flex sm:auth-items-start">
                        <div class="auth-mx-auto auth-flex-shrink-0 auth-flex auth-items-center auth-justify-center auth-h-12 auth-w-12 auth-rounded-full auth-bg-yellow-100 dark:auth-bg-yellow-900/30 sm:auth-mx-0 sm:auth-h-10 sm:auth-w-10">
                            <svg class="auth-h-6 auth-w-6 auth-text-yellow-600 dark:auth-text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
                            </svg>
                        </div>
                        <div class="auth-mt-3 auth-text-center sm:auth-mt-0 sm:auth-ml-4 sm:auth-text-left">
                            <h3 class="auth-text-lg auth-leading-6 auth-font-bold" style="color:var(--text-primary);">@Loc["Modal_Deactivate_Title"]</h3>
                            <div class="auth-mt-2">
                                <p class="auth-text-sm" style="color:var(--text-secondary);">
                                    @Loc["Modal_Deactivate_Text"]
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="auth-px-4 auth-py-3 sm:auth-px-6 sm:auth-flex sm:auth-flex-row-reverse auth-border-t" style="background:var(--bg-elevated);border-color:var(--border);">
                    <button type="button" @onclick="ConfirmDeactivate" class="auth-w-full auth-inline-flex auth-justify-center auth-rounded-lg auth-border auth-border-transparent auth-shadow-sm auth-px-4 auth-py-2 auth-bg-yellow-600 auth-text-base auth-font-medium auth-text-white hover:auth-bg-yellow-700 focus:auth-outline-none focus:auth-ring-2 focus:auth-ring-offset-2 focus:auth-ring-yellow-500 sm:auth-ml-3 sm:auth-w-auto sm:auth-text-sm dark:focus:auth-ring-offset-gray-900">
                        @Loc["Modal_Btn_Deactivate"]
                    </button>
                    <button type="button" @onclick="CloseDeactivateModal" class="auth-mt-3 auth-w-full auth-inline-flex auth-justify-center auth-rounded-lg auth-border auth-shadow-sm auth-px-4 auth-py-2 auth-text-base auth-font-medium focus:auth-outline-none focus:auth-ring-2 focus:auth-ring-offset-2 focus:auth-ring-primary-500 sm:auth-mt-0 sm:auth-ml-3 sm:auth-w-auto sm:auth-text-sm" style="background:transparent;border:1px solid var(--border);color:var(--text-primary);">
                        @Loc["Modal_Btn_Cancel"]
                    </button>
                </div>
            </div>
        </div>
    </div>
}

