@page "/accept-invitation"
@using Authify.Core.Features
@using Authify.Core.Interfaces
@using Authify.Core.Models.Teams
@using Microsoft.AspNetCore.WebUtilities

@inject ITeamDataService TeamDataService
@inject TeamFeatureOptions TeamFeature
@inject NavigationManager NavigationManager

<div style="min-height:100dvh;background:var(--bg);display:flex;align-items:center;justify-content:center;font-family:'DM Sans',system-ui,sans-serif;padding:2rem 1rem;">
    <div style="width:min(420px,100%);">

        <div style="background:var(--bg-surface);border:1px solid var(--border);border-radius:12px;padding:2rem;">

            @if (!TeamFeature.IsEnabled)
            {
                <div style="margin-bottom:1.75rem;">
                    <h1 style="font-family:'Syne',system-ui,sans-serif;font-weight:400;font-size:1.5rem;color:var(--text-primary);margin:0;">Team-Features deaktiviert</h1>
                </div>
                return;
            }

            @if (_isCheckingToken)
            {
                <div style="text-align:center;padding:2rem 0;">
                    <i class="fa-solid fa-spinner fa-spin" style="font-size:2rem;color:var(--text-muted);"></i>
                    <p style="margin-top:1rem;font-size:0.875rem;color:var(--text-secondary);">Einladung wird geprüft...</p>
                </div>
            }
            else if (_tokenError != null)
            {
                <div style="margin-bottom:1.75rem;">
                    <h1 style="font-family:'Syne',system-ui,sans-serif;font-weight:400;font-size:1.5rem;color:var(--text-primary);margin:0 0 0.25rem;">Ungültige Einladung</h1>
                    <p style="font-size:0.875rem;color:var(--text-secondary);margin:0;">Dieser Einladungslink ist nicht mehr gültig.</p>
                </div>
                <div style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.25);color:#ef4444;padding:0.75rem 1rem;border-radius:8px;font-size:0.875rem;margin-bottom:1.25rem;">
                    @_tokenError
                </div>
                <p style="text-align:center;margin-top:1.5rem;font-size:0.875rem;color:var(--text-secondary);">
                    <a href="login" style="color:var(--text-primary);font-weight:500;text-decoration:none;">Zur Anmeldung</a>
                </p>
            }
            else
            {
                <div style="margin-bottom:1.75rem;">
                    <h1 style="font-family:'Syne',system-ui,sans-serif;font-weight:400;font-size:1.5rem;color:var(--text-primary);margin:0 0 0.25rem;">Einladung annehmen</h1>
                    @if (_invitation != null)
                    {
                        <p style="font-size:0.875rem;color:var(--text-secondary);margin:0;">Du wurdest eingeladen, dem Team <strong style="color:var(--text-primary);">@_invitation.TeamName</strong> beizutreten.</p>
                    }
                    else
                    {
                        <p style="font-size:0.875rem;color:var(--text-secondary);margin:0;">Registriere dich um dem Team beizutreten.</p>
                    }
                </div>

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.25);color:#ef4444;padding:0.75rem 1rem;border-radius:8px;font-size:0.875rem;margin-bottom:1.25rem;">
                        @_errorMessage
                    </div>
                }

                <EditForm Model="_acceptRequest" OnValidSubmit="HandleAccept" FormName="AcceptInvitationForm">
                    <DataAnnotationsValidator />

                    <div style="display:flex;flex-direction:column;gap:1rem;">

                        <div>
                            <label style="display:block;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--text-secondary);margin-bottom:0.375rem;">Vollständiger Name</label>
                            <InputText id="fullName" @bind-Value="_acceptRequest.FullName"
                                       style="width:100%;background:var(--bg-elevated);border:1px solid var(--border);border-radius:8px;padding:0.75rem 1rem;font-size:0.875rem;color:var(--text-primary);outline:none;box-sizing:border-box;font-family:inherit;" />
                            <ValidationMessage For="@(() => _acceptRequest.FullName)" />
                        </div>

                        <div>
                            <label style="display:block;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--text-secondary);margin-bottom:0.375rem;">E-Mail-Adresse</label>
                            <InputText id="email" @bind-Value="_acceptRequest.Email" type="email"
                                       disabled="@(_emailPrefilled)"
                                       style="width:100%;background:var(--bg-elevated);border:1px solid var(--border);border-radius:8px;padding:0.75rem 1rem;font-size:0.875rem;color:var(--text-primary);outline:none;box-sizing:border-box;font-family:inherit;opacity:@(_emailPrefilled ? "0.6" : "1");" />
                            <ValidationMessage For="@(() => _acceptRequest.Email)" />
                        </div>

                        <div>
                            <label style="display:block;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--text-secondary);margin-bottom:0.375rem;">Passwort</label>
                            <div style="position:relative;">
                                <InputText id="password" @bind-Value="_acceptRequest.Password"
                                           type="@(_showPassword ? "text" : "password")"
                                           style="width:100%;background:var(--bg-elevated);border:1px solid var(--border);border-radius:8px;padding:0.75rem 3rem 0.75rem 1rem;font-size:0.875rem;color:var(--text-primary);outline:none;box-sizing:border-box;font-family:inherit;" />
                                <button type="button" @onclick="() => _showPassword = !_showPassword" tabindex="-1"
                                        style="position:absolute;right:0.75rem;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--text-muted);cursor:pointer;padding:0;line-height:1;">
                                    <i class="fas @(_showPassword ? "fa-eye-slash" : "fa-eye")"></i>
                                </button>
                            </div>
                            <ValidationMessage For="@(() => _acceptRequest.Password)" />
                        </div>

                        <div>
                            <label style="display:block;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--text-secondary);margin-bottom:0.375rem;">Passwort bestätigen</label>
                            <div style="position:relative;">
                                <InputText id="confirmPassword" @bind-Value="_acceptRequest.ConfirmPassword"
                                           type="@(_showConfirmPassword ? "text" : "password")"
                                           style="width:100%;background:var(--bg-elevated);border:1px solid var(--border);border-radius:8px;padding:0.75rem 3rem 0.75rem 1rem;font-size:0.875rem;color:var(--text-primary);outline:none;box-sizing:border-box;font-family:inherit;" />
                                <button type="button" @onclick="() => _showConfirmPassword = !_showConfirmPassword" tabindex="-1"
                                        style="position:absolute;right:0.75rem;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--text-muted);cursor:pointer;padding:0;line-height:1;">
                                    <i class="fas @(_showConfirmPassword ? "fa-eye-slash" : "fa-eye")"></i>
                                </button>
                            </div>
                            <ValidationMessage For="@(() => _acceptRequest.ConfirmPassword)" />
                        </div>

                        <button type="submit" disabled="@_isSubmitting"
                                style="width:100%;background:var(--text-primary);color:var(--bg);border:none;border-radius:100px;padding:0.75rem;font-size:0.875rem;font-weight:500;cursor:pointer;font-family:inherit;display:flex;align-items:center;justify-content:center;gap:0.5rem;opacity:@(_isSubmitting ? "0.6" : "1");">
                            @if (_isSubmitting)
                            {
                                <i class="fas fa-spinner fa-spin"></i>
                                <span>Beitreten...</span>
                            }
                            else
                            {
                                <span>Team beitreten</span>
                            }
                        </button>

                    </div>
                </EditForm>

                <p style="text-align:center;margin-top:1.5rem;font-size:0.875rem;color:var(--text-secondary);">
                    Bereits ein Konto? <a href="login" style="color:var(--text-primary);font-weight:500;text-decoration:none;">Anmelden</a>
                </p>
            }

        </div>
    </div>
</div>

@code {
    private TeamInvitationDto? _invitation;
    private AcceptInvitationRequest _acceptRequest = new();
    private string? _token;
    private string? _tokenError;
    private string? _errorMessage;
    private bool _isCheckingToken = true;
    private bool _isSubmitting;
    private bool _emailPrefilled;
    private bool _showPassword;
    private bool _showConfirmPassword;

    protected override async Task OnInitializedAsync()
    {
        if (!TeamFeature.IsEnabled)
        {
            _isCheckingToken = false;
            return;
        }

        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);
        _token = query.GetValueOrDefault("token").ToString();

        if (string.IsNullOrWhiteSpace(_token))
        {
            _tokenError = "Kein Einladungstoken angegeben.";
            _isCheckingToken = false;
            return;
        }

        _acceptRequest.Token = _token;

        var result = await TeamDataService.GetInvitationByTokenAsync(_token);
        _isCheckingToken = false;

        if (!result.Success || result.Data == null)
        {
            _tokenError = result.ErrorMessage ?? "Dieser Einladungslink ist ungültig oder abgelaufen.";
            return;
        }

        _invitation = result.Data;

        if (!string.IsNullOrEmpty(_invitation.Email))
        {
            _acceptRequest.Email = _invitation.Email;
            _emailPrefilled = true;
        }
    }

    private async Task HandleAccept()
    {
        _isSubmitting = true;
        _errorMessage = null;

        var result = await TeamDataService.AcceptInvitationAsync(_acceptRequest);
        _isSubmitting = false;

        if (result.Success && result.Data != null)
            NavigationManager.NavigateTo("/" + result.Data, forceLoad: true);
        else
            _errorMessage = result.ErrorMessage ?? "Fehler beim Beitreten des Teams.";
    }
}
