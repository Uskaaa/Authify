@page "/forgot-password"
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using Microsoft.Extensions.Localization

@inject IAuthifyDataService DataService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject IStringLocalizer<ForgotPassword> Loc

<RedirectToHomeIfAuthenticated />

<div style="min-height:100dvh;background:var(--bg);display:flex;align-items:center;justify-content:center;font-family:'DM Sans',system-ui,sans-serif;padding:2rem 1rem;">
    <div style="width:min(420px,100%);">

        <div style="background:var(--bg-surface);border:1px solid var(--border);border-radius:12px;padding:2rem;">

            @if (!_emailSent)
            {
                <div style="margin-bottom:1.75rem;">
                    <h1 style="font-family:'Syne',system-ui,sans-serif;font-weight:400;font-size:1.5rem;color:var(--text-primary);margin:0 0 0.25rem;">@Loc["Title_ForgotPassword"]</h1>
                    <p style="font-size:0.875rem;color:var(--text-secondary);margin:0;">@Loc["Subtitle_EnterEmail"]</p>
                </div>

                <EditForm Model="_request" OnValidSubmit="HandleValidSubmit" FormName="ForgotPasswordForm" method="post">
                    <DataAnnotationsValidator />

                    <div style="display:flex;flex-direction:column;gap:1rem;">

                        <div>
                            <label style="display:block;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--text-secondary);margin-bottom:0.375rem;">@Loc["Label_Email"]</label>
                            <InputText id="email" @bind-Value="_request.Email"
                                       style="width:100%;background:var(--bg-elevated);border:1px solid var(--border);border-radius:8px;padding:0.75rem 1rem;font-size:0.875rem;color:var(--text-primary);outline:none;box-sizing:border-box;font-family:inherit;" />
                            <ValidationMessage For="@(() => _request.Email)" />
                        </div>

                        <button type="submit" disabled="@_isLoading"
                                style="width:100%;background:var(--text-primary);color:var(--bg);border:none;border-radius:100px;padding:0.75rem;font-size:0.875rem;font-weight:500;cursor:pointer;font-family:inherit;display:flex;align-items:center;justify-content:center;gap:0.5rem;opacity:@(_isLoading ? "0.6" : "1");">
                            @if (_isLoading)
                            {
                                <i class="fas fa-spinner fa-spin"></i>
                            }
                            <span>@(_isLoading ? Loc["Btn_Sending"] : Loc["Btn_SendLink"])</span>
                        </button>

                    </div>
                </EditForm>
            }
            else
            {
                <div style="text-align:center;padding:1rem 0;">
                    <div style="width:4rem;height:4rem;border-radius:50%;background:rgba(16,185,129,0.15);display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;">
                        <i class="fas fa-check-circle" style="font-size:1.5rem;color:#10b981;"></i>
                    </div>
                    <h1 style="font-family:'Syne',system-ui,sans-serif;font-weight:400;font-size:1.5rem;color:var(--text-primary);margin:0 0 0.5rem;">@Loc["Title_Success"]</h1>
                    <p style="font-size:0.875rem;color:var(--text-secondary);margin:0;">@Loc["Text_Success"]</p>
                </div>
            }

            <p style="text-align:center;margin-top:1.5rem;font-size:0.875rem;color:var(--text-secondary);">
                @Loc["Footer_Remember"] <a href="login" style="color:var(--text-primary);font-weight:500;text-decoration:none;">@Loc["Link_Login"]</a>
            </p>

        </div>
    </div>
</div>

@code {
    private ForgotPasswordRequest _request = new();
    private bool _emailSent = false;
    private bool _isLoading = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("applyTheme");
    }

    private async Task HandleValidSubmit()
    {
        _isLoading = true;
        var result = await DataService.ForgotPasswordAsync(_request);
        if (result.Success) _emailSent = true;
        _isLoading = false;
    }
}
