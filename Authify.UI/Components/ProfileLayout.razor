@using Microsoft.JSInterop
@using Authify.UI.Models.Branding
@inherits LayoutComponentBase
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<AuthifyThemeStyle />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400..800&family=DM+Sans:ital,opsz,wght@0,9..40,300..700;1,9..40,300..400&display=swap" rel="stylesheet" />

<div style="font-family:'DM Sans',system-ui,sans-serif;color:var(--text-primary);min-height:100dvh;background:var(--bg);" class="auth-transition-colors auth-duration-300">

    <input type="checkbox" id="mobile-menu-toggle" class="auth-hidden" />

    <label for="mobile-menu-toggle" id="profile-mobile-backdrop"
           class="auth-fixed auth-inset-0 auth-z-40 auth-hidden auth-pointer-events-none lg:auth-hidden auth-transition-opacity"
           style="background:rgba(0,0,0,0.6);backdrop-filter:blur(4px);"
           aria-label="Close mobile menu">
    </label>

    <aside id="profile-mobile-sidebar"
           class="auth-fixed auth-inset-y-0 auth-left-0 auth-z-50 auth-w-64 auth-flex auth-flex-col auth-transition-transform auth-duration-300 auth-ease-in-out -auth-translate-x-full lg:auth-translate-x-0 auth-shadow-2xl lg:auth-shadow-none"
           style="background:var(--bg-surface);border-right:1px solid var(--border);">

        <div class="auth-h-16 auth-flex auth-items-center auth-justify-between lg:auth-justify-center auth-px-6 auth-flex-shrink-0"
             style="border-bottom:1px solid var(--border);">
            <AuthifyLogo />
            <label for="mobile-menu-toggle"
                   class="lg:auth-hidden auth-p-2 auth-cursor-pointer auth-transition-colors"
                   style="color:var(--text-muted);"
                   aria-label="Close menu">
                <i class="fa-solid fa-xmark auth-text-lg"></i>
            </label>
        </div>

        <ProfileNavMenu />

    </aside>

    <header class="auth-fixed auth-top-0 auth-right-0 auth-left-0 lg:auth-left-64 auth-h-16 auth-flex auth-items-center auth-justify-between auth-px-4 auth-z-30 lg:auth-hidden"
            style="background:var(--bg-surface);border-bottom:1px solid var(--border);">
        <div class="auth-flex auth-items-center auth-gap-3">
            <label for="mobile-menu-toggle"
                   class="auth-p-2 auth--ml-2 auth-rounded-lg auth-transition-colors auth-cursor-pointer"
                   style="color:var(--text-muted);"
                   aria-label="Open menu">
                <i class="fa-solid fa-bars auth-text-xl"></i>
            </label>
            <AuthifyLogo />
        </div>
    </header>

    <main class="lg:auth-ml-64 auth-pt-16 lg:auth-pt-0 auth-min-h-screen" style="background:var(--bg);">
        @Body
    </main>

</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { await JS.InvokeVoidAsync("applyTheme"); } catch { }
        }
    }
}

<style>
    #mobile-menu-toggle:checked ~ #profile-mobile-backdrop {
        opacity: 1;
        pointer-events: auto;
        display: block;
        cursor: pointer;
    }

    #mobile-menu-toggle:checked ~ #profile-mobile-sidebar {
        transform: translateX(0);
    }
</style>
