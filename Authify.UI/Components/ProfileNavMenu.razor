@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.JSInterop
@using Authify.Core.Features
@inject IJSRuntime JS
@inject TeamFeatureOptions TeamFeature
@inject LdapFeatureOptions LdapFeature
@inject ITeamDataService TeamDataService

<div class="auth-flex-1 auth-py-6 auth-px-4 auth-space-y-8 auth-overflow-y-auto custom-scrollbar">
    
    <div>
        <div class="auth-px-3 auth-mb-2 auth-text-[10px] auth-font-bold auth-uppercase auth-tracking-wider" style="color:var(--text-muted);">
            Account Settings
        </div>
        <div class="auth-space-y-0.5">
            @NavItem("profile-settings", "fa-solid fa-user", "Profile")
            @NavItem("security-settings", "fa-solid fa-shield-halved", "Security")
            @if (!_isTeamMember)
            {
                @NavItem("privacy-settings", "fa-solid fa-lock", "Privacy")
            }
        </div>
    </div>

    @if (!_isTeamMember)
    {
        <div>
            <div class="auth-px-3 auth-mb-2 auth-text-[10px] auth-font-bold auth-uppercase auth-tracking-wider" style="color:var(--text-muted);">
                Subscription
            </div>
            <div class="auth-space-y-0.5">
                @NavItem("billing-overview", "fa-solid fa-receipt", "Billing & Usage")
            </div>
        </div>
    }

    @if (TeamFeature.IsEnabled && !_isTeamMember)
    {
        <div>
            <div class="auth-px-3 auth-mb-2 auth-text-[10px] auth-font-bold auth-uppercase auth-tracking-wider" style="color:var(--text-muted);">
                Admin-Einstellungen
            </div>
            <div class="auth-space-y-0.5">
                @NavItem("admin/team-settings", "fa-solid fa-building", "Team-Account")
                @if (_isTeamAdmin)
                {
                    @NavItem("admin/team-members", "fa-solid fa-users", "Mitarbeiter")
                    @NavItem("admin/team-invitations", "fa-solid fa-envelope-open-text", "Einladungslinks")
                    @if (LdapFeature.IsEnabled)
                    {
                        @NavItem("admin/ldap", "fa-solid fa-server", "LDAP / Active Directory")
                    }
                }
            </div>
        </div>
    }

</div>

<div class="auth-p-4 auth-border-t" style="background:var(--bg-surface);border-color:var(--border);">
    <a href="/dashboard" class="auth-flex auth-items-center auth-gap-3 auth-p-2.5 auth-rounded-xl auth-text-sm auth-font-medium auth-transition-colors auth-group" style="color:var(--text-secondary);text-decoration:none;">
        <i class="fa-solid fa-arrow-left auth-text-xs group-hover:-auth-translate-x-0.5 auth-transition-transform"></i>
        <span>Back to Dashboard</span>
    </a>
</div>

@code {
    private bool _isTeamAdmin;
    private bool _isTeamMember;

    protected override async Task OnInitializedAsync()
    {
        if (TeamFeature.IsEnabled)
        {
            try
            {
                var adminResult = await TeamDataService.IsTeamAdminAsync();
                _isTeamAdmin = adminResult.Success && adminResult.Data;

                var memberResult = await TeamDataService.IsTeamMemberAsync();
                // "Mitglied" im Sinne von: nicht-admin Mitglied eines Teams
                _isTeamMember = memberResult.Success && memberResult.Data && !_isTeamAdmin;
            }
            catch
            {
                // Ignorieren falls Service nicht verfügbar
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { await JS.InvokeVoidAsync("applyTheme"); } catch { }
        }
    }
    
    private RenderFragment NavItem(string href, string icon, string text) => __builder =>
    {
        <NavLink href="@href" Match="NavLinkMatch.Prefix" class="nav-item auth-group auth-relative auth-flex auth-items-center auth-gap-3 auth-px-3 auth-py-2 auth-rounded-lg auth-text-sm auth-font-medium auth-transition-all" style="color:var(--text-secondary);text-decoration:none;">

            <i class="@icon auth-w-5 auth-text-center auth-transition-colors auth-text-xs" style="color:var(--text-muted);"></i>

            <span class="auth-relative auth-z-10">@text</span>

            <div class="active-indicator auth-absolute auth-left-0 auth-top-1/2 auth--translate-y-1/2 auth-h-5 auth-w-1 auth-rounded-r-full auth-opacity-0 auth-transition-opacity" style="background:var(--text-primary);"></div>
        </NavLink>
    };
}

<style>
    .nav-item.active {
        background-color: var(--bg-elevated);
        color: var(--text-primary) !important;
    }

    .nav-item.active i {
        color: var(--text-primary) !important;
    }

    .nav-item.active .active-indicator {
        opacity: 1;
    }

    .nav-item:hover {
        background-color: var(--bg-elevated);
        color: var(--text-primary) !important;
    }

    .nav-item:hover i {
        color: var(--text-secondary) !important;
    }
</style>