@page "/register"
@using System.ComponentModel.DataAnnotations
@using Authify.Core.Server.Models
@using Microsoft.AspNetCore.Components.Forms
@inject IUserService UserService
@inject NavigationManager NavigationManager

<div class="register-container">
    <div class="auth-card">
        <div class="auth-header">
            <h1>Create Account</h1>
            <p>Please fill in your details to register</p>
        </div>
        <EditForm Model="_request" OnValidSubmit="HandleValidSubmit" class="auth-form">
            <DataAnnotationsValidator />
            <div class="form-group">
                <label for="fullName">Full Name</label>
                <InputText id="fullName" class="form-control" @bind-Value="_request.Username" />
                <ValidationMessage For="@(() => _request.Username)" />
            </div>
            <div class="form-group">
                <label for="email">Email</label>
                <InputText id="email" class="form-control" @bind-Value="_request.Email" />
                <ValidationMessage For="@(() => _request.Email)" />
            </div>
            <div class="form-group">
                <label for="password">Password</label>
                <div class="password-input">
                    <InputText id="password" class="form-control" @bind-Value="_request.Password" type="@(_showPassword ? "text" : "password")" />
                    <button type="button" class="toggle-password" @onclick="TogglePasswordVisibility" tabindex="-1">
                        <i class="fas @(_showPassword ? "fa-eye-slash" : "fa-eye")"></i>
                    </button>
                </div>
                <ValidationMessage For="@(() => _request.Password)" />
            </div>
            <div class="form-group">
                <label for="confirmPassword">Confirm Password</label>
                <div class="password-input">
                    <InputText id="confirmPassword" class="form-control" @bind-Value="_request.ConfirmPassword" type="@(_showConfirmPassword ? "text" : "password")" />
                    <button type="button" class="toggle-password" @onclick="ToggleConfirmPasswordVisibility" tabindex="-1">
                        <i class="fas @(_showConfirmPassword ? "fa-eye-slash" : "fa-eye")"></i>
                    </button>
                </div>
                <ValidationMessage For="@(() => _request.ConfirmPassword)" />
            </div>
            <div class="form-options">
                <label class="terms">
                    <InputCheckbox @bind-Value="_request.TermsAccepted" />
                    <span>I agree to the <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a></span>
                </label>
                <ValidationMessage For="@(() => _request.TermsAccepted)" />
            </div>
            <button type="submit" class="btn btn-primary" disabled="@(_isLoading)">
                @if (_isLoading)
                {
                    <i class="fas fa-spinner fa-spin"></i>
                }
                else
                {
                    <span>Create Account</span>
                }
            </button>
        </EditForm>
        <div class="divider">
            <span>or continue with</span>
        </div>
        <div class="oauth-buttons">
            <button class="btn btn-oauth google" @onclick="GoogleOAuth">
                <i class="fab fa-google"></i>
                <span>Sign up with Google</span>
            </button>
            <button class="btn btn-oauth github" @onclick="GitHubOAuth">
                <i class="fab fa-github"></i>
                <span>Sign up with GitHub</span>
            </button>
        </div>
        <p class="auth-footer">
            Already have an account? <a href="login">Sign in</a>
        </p>
    </div>
</div>

@code {
    private RegisterRequest _request = new();
    private bool _isLoading = false;
    private bool _showPassword = false;
    private bool _showConfirmPassword = false;

    private async Task HandleValidSubmit()
    {
        _isLoading = true;
        var result = await UserService.RegisterAsync(_request);
        _isLoading = false;
        if (result.Success)
        {
            NavigationManager.NavigateTo("/confirm-email");
        }
        else
        {
            Console.WriteLine($"Registration failed: {result.ErrorMessage}");
        }
    }

    private void TogglePasswordVisibility()
    {
        _showPassword = !_showPassword;
    }

    private void ToggleConfirmPasswordVisibility()
    {
        _showConfirmPassword = !_showConfirmPassword;
    }

    private void GoogleOAuth()
    {
        // Platzhalter für Google OAuth
    }

    private void GitHubOAuth()
    {
        // Platzhalter für GitHub OAuth
    }
} 