@page "/otp"
@using System.ComponentModel.DataAnnotations
@using Microsoft.JSInterop
@inject IJSRuntime JS
@implements IAsyncDisposable
@inject NavigationManager NavigationManager
@inject IAuthServiceJwt AuthServiceJwt

<div @ref="_containerRef" class="otp-container">
    <div class="auth-card">
        <div class="auth-header">
            <h1>Verify Your Email</h1>
            <p>Enter the 6-digit code sent to your email</p>
        </div>
        
        <EditForm Model="this" OnValidSubmit="HandleValidSubmit" class="auth-form">
            <input type="hidden" @bind="OtpCode" />

            <div class="otp-inputs">
                @for (int i = 0; i < 6; i++)
                {
                    <input class="form-control otp-input" maxlength="1" inputmode="numeric" pattern="[0-9]" />
                }
            </div>
            
            <ValidationMessage For="@(() => OtpCode)" />
            <button type="submit" class="btn btn-primary" disabled="@(_isVerifying || OtpCode?.Length != 6)">
                @if (_isVerifying) { <i class="fas fa-spinner fa-spin"></i> } else { <span>Verify</span> }
            </button>
        </EditForm>
        
        <p>Eingegebener Code (zur Demo): <strong>@OtpCode</strong></p>
    </div>
</div>

@code {
    private ElementReference _containerRef;
    private DotNetObjectReference<Otp>? _objRef;

    [Required(ErrorMessage = "Der Code ist erforderlich.")]
    [StringLength(6, MinimumLength = 6, ErrorMessage = "Der Code muss 6-stellig sein.")]
    private string OtpCode { get; set; }

    private OtpVerificationRequest _request = new OtpVerificationRequest();
    private bool _isVerifying = false;
    private bool _error = false;

    protected override Task OnInitializedAsync()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        _request.Token = query.GetValueOrDefault("token")!;
        return base.OnInitializedAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _objRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("initializeOtpHandler", _containerRef, _objRef);
        }
    }

    [JSInvokable]
    public void OnOtpCompleted(string otp)
    {
        
        Console.WriteLine($"OTP vollständig: {otp}. Löst Validierung aus.");
        _ = HandleValidSubmit();
        StateHasChanged();
    }

    private async Task HandleValidSubmit()
    {
        _isVerifying = true;
        _request.OtpCode = OtpCode;
        var result = await AuthServiceJwt.VerifyOtpAsync(_request);
        Console.WriteLine($"Verifiziere Code: {OtpCode}");
        _isVerifying = false;
        if (result.Success)
        {
            _error = false;
            NavigationManager.NavigateTo("/");
        }
        else
        {
            _error = true;
        }
    }

    public async ValueTask DisposeAsync()
    {
        _objRef?.Dispose();
    }
}