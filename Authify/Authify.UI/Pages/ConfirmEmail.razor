@page "/confirm-email"
@using Microsoft.JSInterop
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject NavigationManager NavigationManager
@inject IAuthifyDataService DataService
@inject IJSRuntime JS

<RedirectToHomeIfAuthenticated />

<div class="confirm-container">
    <div class="content-wrapper">
        <div class="auth-card">
            
            @switch (_status)
            {
                case ConfirmStatus.Instruction:
                    <div class="status-content">
                        <div class="icon-wrapper info">
                            <i class="fas fa-envelope"></i>
                        </div>
                        <h1>Verify your email</h1>
                        <p>
                            We've sent a verification email to <br />
                            <span class="email-highlight">@_email</span>
                        </p>
                        <p class="sub-text">
                            Click the link in the email to confirm your account. 
                            If you can't find it, check your spam folder.
                        </p>
                        <div class="auth-stack">
                            <a href="login" class="btn btn-outline">Back to Login</a>
                        </div>
                    </div>
                    break;

                case ConfirmStatus.Verifying:
                    <div class="status-content">
                        <div class="icon-wrapper loading">
                            <i class="fas fa-spinner fa-spin"></i>
                        </div>
                        <h1>Verifying...</h1>
                        <p>Please wait while we verify your email address.</p>
                    </div>
                    break;

                case ConfirmStatus.Success:
                    <div class="status-content">
                        <div class="icon-wrapper success">
                            <i class="fas fa-check-circle"></i>
                        </div>
                        <h1>Email Verified!</h1>
                        <p>Your email has been successfully verified. You can now login.</p>
                        <div class="auth-stack">
                            <button class="btn btn-primary" @onclick="NavigateToLogin">Go to Login</button>
                        </div>
                    </div>
                    break;

                case ConfirmStatus.Error:
                    <div class="status-content">
                        <div class="icon-wrapper error">
                            <i class="fas fa-times-circle"></i>
                        </div>
                        <h1>Verification Failed</h1>
                        <p>We couldn't verify your email. The link might be invalid or expired.</p>
                        <div class="auth-stack">
                            <a href="register" class="btn btn-primary">Try Registering Again</a>
                        </div>
                    </div>
                    break;
            }
            
        </div>
    </div>
</div>

@code {
    private enum ConfirmStatus { Instruction, Verifying, Success, Error }
    
    private ConfirmStatus _status = ConfirmStatus.Instruction;
    private string _email = "";
    private EmailConfirmationRequest _request = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("applyTheme");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        
        // 1. Parameter auslesen
        var userId = query.GetValueOrDefault("userId").ToString();
        var token = query.GetValueOrDefault("token").ToString();
        _email = query.GetValueOrDefault("email").ToString() ?? "your email";

        // 2. Entscheidung: Instruktion oder Verifikation?
        if (string.IsNullOrEmpty(userId) || string.IsNullOrEmpty(token))
        {
            // Keine Tokens da -> Wir kommen wohl gerade vom Registrieren
            _status = ConfirmStatus.Instruction;
        }
        else
        {
            // Tokens da -> Wir kommen aus der E-Mail
            _status = ConfirmStatus.Verifying;
            _request.UserId = userId;
            _request.Token = token;
            
            // Kurz warten für UX (damit man den Spinner sieht und es nicht flackert)
            await Task.Delay(800); 
            await VerifyEmail();
        }
    }

    private async Task VerifyEmail()
    {
        var result = await DataService.ConfirmEmailAsync(_request);
        
        if (result.Success)
        {
            _status = ConfirmStatus.Success;
            // Automatischer Redirect nach 3 Sekunden optional
            // await Task.Delay(3000);
            // NavigateToLogin();
        }
        else
        {
            _status = ConfirmStatus.Error;
        }
    }

    private void NavigateToLogin()
    {
        NavigationManager.NavigateTo("/login");
    }
}