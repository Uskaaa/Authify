@page "/confirm-email"
@using Microsoft.JSInterop
@using Microsoft.Extensions.Localization

@inject NavigationManager NavigationManager
@inject IAuthifyDataService DataService
@inject IJSRuntime JS
@inject IStringLocalizer<ConfirmEmail> Loc

<RedirectToHomeIfAuthenticated />

<div class="auth-fixed auth-inset-0 auth-flex auth-items-center auth-justify-center auth-z-[1000] auth-overflow-y-auto" style="background: var(--bg); color: var(--text-primary);">
    <div class="auth-w-full auth-max-w-sm auth-p-4">
        <div class="auth-bg-token-surface auth-border auth-border-token auth-rounded-lg auth-p-8 auth-shadow-md auth-transition-transform hover:auth--translate-y-1">
            
            @switch (_status)
            {
                case ConfirmStatus.Instruction:
                    <div class="auth-text-center">
                        <div class="auth-text-4xl auth-mb-4" style="color: var(--text-primary);">
                            <i class="fas fa-envelope"></i>
                        </div>
                        <h1 class="auth-heading-2 auth-mb-2">@Loc["Title_VerifyEmail"]</h1>
                        <p class="auth-text-sm auth-mb-3" style="color: var(--text-secondary);">
                            @Loc["Text_SentTo"] <br />
                            <span class="auth-font-medium" style="color: var(--text-primary);">@_email</span>
                        </p>
                        <p class="auth-text-xs auth-mb-6" style="color: var(--text-muted);">
                            @Loc["Text_Instruction"]
                        </p>
                        <a href="@("login" + (!string.IsNullOrEmpty(_returnUrl) ? "?returnUrl=" + Uri.EscapeDataString(_returnUrl) : ""))" class="auth-btn-ghost auth-w-full">@Loc["Btn_BackToLogin"]</a>
                    </div>
                    break;

                case ConfirmStatus.Verifying:
                    <div class="auth-text-center auth-py-8">
                        <div class="auth-text-4xl auth-mb-4" style="color: var(--text-primary);">
                            <i class="fas fa-spinner fa-spin"></i>
                        </div>
                        <h1 class="auth-heading-2 auth-mb-2">@Loc["Title_Verifying"]</h1>
                        <p class="auth-text-sm" style="color: var(--text-secondary);">@Loc["Text_Verifying"]</p>
                    </div>
                    break;

                case ConfirmStatus.Success:
                    <div class="auth-text-center auth-py-8">
                        <div class="auth-text-4xl auth-mb-4" style="color: #10b981;">
                            <i class="fas fa-check-circle"></i>
                        </div>
                        <h1 class="auth-heading-2 auth-mb-2">@Loc["Title_Success"]</h1>
                        <p class="auth-text-sm auth-mb-6" style="color: var(--text-secondary);">@Loc["Text_Success"]</p>
                        <button class="auth-btn-primary auth-w-full" @onclick="NavigateToLogin">@Loc["Btn_GoToLogin"]</button>
                    </div>
                    break;

                case ConfirmStatus.Error:
                    <div class="auth-text-center auth-py-8">
                        <div class="auth-text-4xl auth-mb-4" style="color: #ef4444;">
                            <i class="fas fa-times-circle"></i>
                        </div>
                        <h1 class="auth-heading-2 auth-mb-2">@Loc["Title_Error"]</h1>
                        <p class="auth-text-sm auth-mb-6" style="color: var(--text-secondary);">@Loc["Text_Error"]</p>
                        <a href="register" class="auth-btn-primary auth-w-full auth-inline-block">@Loc["Btn_RetryRegister"]</a>
                    </div>
                    break;
            }
            
        </div>
    </div>
</div>

@code {
    private enum ConfirmStatus { Instruction, Verifying, Success, Error }
    
    private ConfirmStatus _status = ConfirmStatus.Instruction;
    private string _email = "";
    private EmailConfirmationRequest _request = new();
    private string? _returnUrl;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("applyTheme");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        
        // 1. Parameter auslesen
        var userId = query.GetValueOrDefault("userId").ToString();
        var token = query.GetValueOrDefault("token").ToString();
        _email = query.GetValueOrDefault("email").ToString() ?? "your email";
        _returnUrl = query.GetValueOrDefault("returnUrl").ToString();
        if (string.IsNullOrEmpty(_returnUrl)) _returnUrl = null;

        // 2. Entscheidung: Instruktion oder Verifikation?
        if (string.IsNullOrEmpty(userId) || string.IsNullOrEmpty(token))
        {
            // Keine Tokens da -> Wir kommen wohl gerade vom Registrieren
            _status = ConfirmStatus.Instruction;
        }
        else
        {
            // Tokens da -> Wir kommen aus der E-Mail
            _status = ConfirmStatus.Verifying;
            _request.UserId = userId;
            _request.Token = token;
            
            // Kurz warten für UX (damit man den Spinner sieht und es nicht flackert)
            await Task.Delay(800); 
            await VerifyEmail();
        }
    }

    private async Task VerifyEmail()
    {
        var result = await DataService.ConfirmEmailAsync(_request);
        
        if (result.Success)
        {
            _status = ConfirmStatus.Success;
            // Automatischer Redirect nach 3 Sekunden optional
            // await Task.Delay(3000);
            // NavigateToLogin();
        }
        else
        {
            _status = ConfirmStatus.Error;
        }
    }

    private void NavigateToLogin()
    {
        var loginUrl = "/login";
        if (!string.IsNullOrEmpty(_returnUrl))
            loginUrl += "?returnUrl=" + Uri.EscapeDataString(_returnUrl);
        NavigationManager.NavigateTo(loginUrl);
    }
}