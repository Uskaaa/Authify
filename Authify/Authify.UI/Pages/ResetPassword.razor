@page "/reset-password"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.WebUtilities
@inject NavigationManager NavigationManager
@inject IAuthifyDataService DataService
@inject IJSRuntime JS

<RedirectToHomeIfAuthenticated />

<div class="reset-container">
    <div class="content-wrapper">
        <div class="auth-card">
            <div class="auth-header">
                <h1>Reset Password</h1>
                <p>Enter your new password</p>
            </div>
            
            @if (!_isSuccess)
            {
                <EditForm Model="_request" OnValidSubmit="HandleValidSubmit">
                    <DataAnnotationsValidator />
                    
                    <!-- Versteckte Felder für Email und Token, falls sie für Debugging im DOM sein sollen, 
                         aber eigentlich reicht es, sie im C# Model zu haben. -->
                    
                    <!-- Wrapper für Flexbox Gap -->
                    <div class="auth-stack">
                        
                        @if (string.IsNullOrEmpty(_request.Email) || string.IsNullOrEmpty(_request.Token))
                        {
                            <div class="alert alert-danger" style="color: var(--auth-error); background: rgba(239, 68, 68, 0.1); padding: 0.75rem; border-radius: 0.5rem; font-size: 0.875rem;">
                                Invalid password reset link. Missing information.
                            </div>
                        }
                        
                        @if (!string.IsNullOrEmpty(_errorMessage))
                        {
                            <div class="alert alert-danger">
                                @_errorMessage
                            </div>
                        }

                        <div class="form-group">
                            <label for="password">New Password</label>
                            <div class="password-input">
                                <InputText id="password" @bind-Value="_request.NewPassword" type="@(_showPassword ? "text" : "password")" placeholder="New password" />
                                <button type="button" class="toggle-password" @onclick="TogglePasswordVisibility" tabindex="-1">
                                    <i class="fas @(_showPassword ? "fa-eye-slash" : "fa-eye")"></i>
                                </button>
                            </div>
                            <div class="validation-wrapper">
                                <ValidationMessage For="@(() => _request.NewPassword)" />
                            </div>
                        </div>
                        
                        <div class="form-group">
                            <label for="confirmPassword">Confirm New Password</label>
                            <div class="password-input">
                                <InputText id="confirmPassword" @bind-Value="_request.ConfirmNewPassword" type="@(_showConfirmPassword ? "text" : "password")" placeholder="Confirm new password" />
                                <button type="button" class="toggle-password" @onclick="ToggleConfirmPasswordVisibility" tabindex="-1">
                                    <i class="fas @(_showConfirmPassword ? "fa-eye-slash" : "fa-eye")"></i>
                                </button>
                            </div>
                            <div class="validation-wrapper">
                                <ValidationMessage For="@(() => _request.ConfirmNewPassword)" />
                            </div>
                        </div>
                        
                        <button type="submit" class="btn btn-primary" disabled="@(_isLoading || string.IsNullOrEmpty(_request.Token))">
                            @if (_isLoading)
                            {
                                <i class="fas fa-spinner fa-spin"></i> <span>Resetting...</span>
                            }
                            else
                            {
                                <span>Reset Password</span>
                            }
                        </button>
                    </div> <!-- Ende auth-stack -->
                </EditForm>
            }
            else
            {
                <div class="success-message">
                    <div class="success-icon">
                        <i class="fas fa-check-circle"></i>
                    </div>
                    <h2>Password Reset!</h2>
                    <p>Your password has been successfully reset. You can now login with your new password.</p>
                    <!-- Wrapper div für den Button im Success Screen, falls nötig, oder direkt stylen -->
                    <div class="auth-stack">
                        <a @onclick="NavigateToLogin" class="btn btn-primary">Go to Login</a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private ResetPasswordRequest _request = new();
    private bool _isLoading = false;
    private bool _isSuccess = false;
    private bool _showPassword = false;
    private bool _showConfirmPassword = false;
    private string? _errorMessage;

    protected override void OnInitialized()
    {
        // Parameter aus der URL extrahieren (Query String)
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("email", out var email))
        {
            _request.Email = email!;
        }

        if (query.TryGetValue("token", out var token))
        {
            _request.Token = token!;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("applyTheme");
        }
    }
    
    private async Task HandleValidSubmit()
    {
        // Sicherheitscheck
        if (string.IsNullOrEmpty(_request.Email) || string.IsNullOrEmpty(_request.Token))
        {
            Console.WriteLine("Fehler: Email oder Token fehlen.");
            return;
        }

        _isLoading = true;
        var result = await DataService.ResetPasswordAsync(_request);
        _isLoading = false;
        
        if (result.Success) 
        {
            _isSuccess = true;
        }
        else
        {
            _errorMessage = result.ErrorMessage;
            Console.WriteLine($"Reset failed: {result.ErrorMessage}");
        }
    }

    private void TogglePasswordVisibility()
    {
        _showPassword = !_showPassword;
    }

    private void ToggleConfirmPasswordVisibility()
    {
        _showConfirmPassword = !_showConfirmPassword;
    }
    
    private Task NavigateToLogin()
    {
        NavigationManager.NavigateTo("/login");
        return Task.CompletedTask;
    }
}