@page "/register"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@inject IAuthifyDataService DataService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<RedirectToHomeIfAuthenticated />

<div class="register-container">
    <div class="content-wrapper">
        <div class="auth-card">
            <div class="auth-header">
                <h1>Create Account</h1>
                <p>Please fill in your details to register</p>
            </div>
            
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert alert-danger">
                    @_errorMessage
                </div>
            }
            
            <EditForm Model="_request" OnValidSubmit="HandleValidSubmit">
                <DataAnnotationsValidator />
                
                <!-- WICHTIG: Wrapper für Flexbox Gap -->
                <div class="auth-stack">
                    
                    <div class="form-group">
                        <label for="fullName">Full Name</label>
                        <InputText id="fullName" @bind-Value="_request.FullName" placeholder="John Doe" />
                        <div class="validation-wrapper">
                            <ValidationMessage For="@(() => _request.FullName)" />
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label for="email">Email</label>
                        <InputText id="email" @bind-Value="_request.Email" placeholder="name@example.com" />
                        <div class="validation-wrapper">
                            <ValidationMessage For="@(() => _request.Email)" />
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label for="password">Password</label>
                        <div class="password-input">
                            <InputText id="password" @bind-Value="_request.Password" type="@(_showPassword ? "text" : "password")" placeholder="Create a password" />
                            <button type="button" class="toggle-password" @onclick="TogglePasswordVisibility" tabindex="-1">
                                <i class="fas @(_showPassword ? "fa-eye-slash" : "fa-eye")"></i>
                            </button>
                        </div>
                        <div class="validation-wrapper">
                            <ValidationMessage For="@(() => _request.Password)" />
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label for="confirmPassword">Confirm Password</label>
                        <div class="password-input">
                            <InputText id="confirmPassword" @bind-Value="_request.ConfirmPassword" type="@(_showConfirmPassword ? "text" : "password")" placeholder="Confirm your password" />
                            <button type="button" class="toggle-password" @onclick="ToggleConfirmPasswordVisibility" tabindex="-1">
                                <i class="fas @(_showConfirmPassword ? "fa-eye-slash" : "fa-eye")"></i>
                            </button>
                        </div>
                        <div class="validation-wrapper">
                            <ValidationMessage For="@(() => _request.ConfirmPassword)" />
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label class="terms">
                            <InputCheckbox @bind-Value="_request.TermsAccepted" />
                            <span>I agree to the <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a></span>
                        </label>
                        <div class="validation-wrapper">
                            <ValidationMessage For="@(() => _request.TermsAccepted)" />
                        </div>
                    </div>
                    
                    <button type="submit" class="btn btn-primary" disabled="@(_isLoading)">
                        @if (_isLoading)
                        {
                            <i class="fas fa-spinner fa-spin"></i> <span>Creating account...</span>
                        }
                        else
                        {
                            <span>Create Account</span>
                        }
                    </button>
                    
                </div> <!-- Ende auth-stack -->
            </EditForm>
            
            <div class="divider">
                <span>or continue with</span>
            </div>
            
            <div class="oauth-buttons">
                <button class="btn btn-oauth google" @onclick="GoogleOAuth">
                    <i class="fab fa-google"></i>
                    <span>Sign up with Google</span>
                </button>
                <button class="btn btn-oauth github" @onclick="GitHubOAuth">
                    <i class="fab fa-github"></i>
                    <span>Sign up with GitHub</span>
                </button>
            </div>
            
            <p class="auth-footer">
                Already have an account? <a href="login">Sign in</a>
            </p>
        </div>
    </div>
</div>

@code {
    private RegisterRequest _request = new();
    private bool _isLoading = false;
    private bool _showPassword = false;
    private bool _showConfirmPassword = false;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        
        if (uri.Fragment.Length > 1)
        {
            var fragmentString = uri.Fragment.Substring(1); 
            var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(fragmentString);

            var accessToken = query.GetValueOrDefault("access").ToString();
            var refreshToken = query.GetValueOrDefault("refresh").ToString();

            if (string.IsNullOrEmpty(refreshToken))
            {
                NavigationManager.NavigateTo("/otp?token=" + (accessToken ?? ""));
            }
            
            if (!string.IsNullOrEmpty(accessToken) && !string.IsNullOrEmpty(refreshToken))
            {
                await DataService.StoreTokensFromExternalAuth(accessToken, refreshToken);
                
                NavigationManager.NavigateTo("/", forceLoad: true);
            }
        }
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("applyTheme");
    }
    
    private async Task HandleValidSubmit()
    {
        _isLoading = true;
        var result = await DataService.RegisterAsync(_request);
        _isLoading = false;
        _errorMessage = null;
        if (result.Success)
        {
            NavigationManager.NavigateTo($"/confirm-email?email={Uri.EscapeDataString(_request.Email)}");
        }
        else
        {
            Console.WriteLine("Registration failed: " + (result.ErrorMessage ?? "Unknown error"));
            _errorMessage = result.ErrorMessage ?? "Register failed.";
        }
    }

    private void TogglePasswordVisibility()
    {
        _showPassword = !_showPassword;
    }

    private void ToggleConfirmPasswordVisibility()
    {
        _showConfirmPassword = !_showConfirmPassword;
    }

    private void GoogleOAuth()
    {
        NavigationManager.NavigateTo("/auth/external-login?provider=Google&returnUrl=/register&mode=register", forceLoad: true);
    }

    private void GitHubOAuth()
    {
        NavigationManager.NavigateTo("/auth/external-login?provider=GitHub&returnUrl=/register&mode=register", forceLoad: true);
    }
}