@page "/register"
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using Microsoft.Extensions.Localization
@inject IAuthifyDataService DataService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject IStringLocalizer<Register> Loc

<RedirectToHomeIfAuthenticated RedirectUrl="@(_returnUrl ?? "/")" />

<div class="register-container">
    <div class="content-wrapper">
        <div class="auth-card">
            <div class="auth-header">
                <h1>@Loc["Title_CreateAccount"]</h1>
                <p>@Loc["Subtitle_FillDetails"]</p>
            </div>
            
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert alert-danger">
                    @_errorMessage
                </div>
            }
            
            <EditForm Model="_request" OnValidSubmit="HandleValidSubmit" FormName="RegisterForm" method="post">
                <DataAnnotationsValidator />
                
                <div class="auth-stack">
                    
                    <div class="form-group">
                        <label for="fullName">@Loc["Label_FullName"]</label>
                        <InputText id="fullName" @bind-Value="_request.FullName" placeholder="@Loc["Placeholder_FullName"]" />
                        <div class="validation-wrapper">
                            <ValidationMessage For="@(() => _request.FullName)" />
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label for="email">@Loc["Label_Email"]</label>
                        <InputText id="email" @bind-Value="_request.Email" placeholder="@Loc["Placeholder_Email"]" />
                        <div class="validation-wrapper">
                            <ValidationMessage For="@(() => _request.Email)" />
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label for="password">@Loc["Label_Password"]</label>
                        <div class="password-input">
                            <InputText id="password" @bind-Value="_request.Password" type="@(_showPassword ? "text" : "password")" placeholder="@Loc["Placeholder_Password"]" />
                            <button type="button" class="toggle-password" @onclick="TogglePasswordVisibility" tabindex="-1">
                                <i class="fas @(_showPassword ? "fa-eye-slash" : "fa-eye")"></i>
                            </button>
                        </div>
                        <div class="validation-wrapper">
                            <ValidationMessage For="@(() => _request.Password)" />
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label for="confirmPassword">@Loc["Label_ConfirmPassword"]</label>
                        <div class="password-input">
                            <InputText id="confirmPassword" @bind-Value="_request.ConfirmPassword" type="@(_showConfirmPassword ? "text" : "password")" placeholder="@Loc["Placeholder_ConfirmPassword"]" />
                            <button type="button" class="toggle-password" @onclick="ToggleConfirmPasswordVisibility" tabindex="-1">
                                <i class="fas @(_showConfirmPassword ? "fa-eye-slash" : "fa-eye")"></i>
                            </button>
                        </div>
                        <div class="validation-wrapper">
                            <ValidationMessage For="@(() => _request.ConfirmPassword)" />
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label class="terms">
                            <InputCheckbox @bind-Value="_request.TermsAccepted" />
                            <span>@Loc["Text_AgreeTo"] <a href="#">@Loc["Link_Terms"]</a> @Loc["Text_And"] <a href="#">@Loc["Link_Privacy"]</a></span>
                        </label>
                        <div class="validation-wrapper">
                            <ValidationMessage For="@(() => _request.TermsAccepted)" />
                        </div>
                    </div>
                    
                    <button type="submit" class="btn btn-primary" disabled="@(_isLoading)">
                        @if (_isLoading)
                        {
                            <i class="fas fa-spinner fa-spin"></i> <span>@Loc["Btn_Register_Loading"]</span>
                        }
                        else
                        {
                            <span>@Loc["Btn_Register"]</span>
                        }
                    </button>
                    
                </div> </EditForm>
            
            <div class="divider">
                <span>@Loc["Divider_Or"]</span>
            </div>
            
            <div class="oauth-buttons">
                <button class="btn btn-oauth google" @onclick="GoogleOAuth">
                    <i class="fab fa-google"></i>
                    <span>@Loc["Btn_Google"]</span>
                </button>
                <button class="btn btn-oauth github" @onclick="GitHubOAuth">
                    <i class="fab fa-github"></i>
                    <span>@Loc["Btn_GitHub"]</span>
                </button>
            </div>
            
            <p class="auth-footer">
                @Loc["Footer_HaveAccount"] <a href="login">@Loc["Link_Login"]</a>
            </p>
        </div>
    </div>
</div>

@code {
    private RegisterRequest _request = new();
    private bool _isLoading = false;
    private bool _showPassword = false;
    private bool _showConfirmPassword = false;
    private string? _errorMessage;
    private string? _returnUrl;

    protected override async Task OnInitializedAsync()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var queryParams = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        _returnUrl = queryParams.GetValueOrDefault("returnUrl").ToString();
        if (string.IsNullOrEmpty(_returnUrl)) _returnUrl = null;

        if (uri.Fragment.Length > 1)
        {
            var fragmentString = uri.Fragment.Substring(1); 
            var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(fragmentString);

            var accessToken = query.GetValueOrDefault("access").ToString();
            var refreshToken = query.GetValueOrDefault("refresh").ToString();

            if (string.IsNullOrEmpty(refreshToken))
            {
                var otpUrl = "/otp?token=" + (accessToken ?? "");
                if (!string.IsNullOrEmpty(_returnUrl))
                    otpUrl += "&returnUrl=" + Uri.EscapeDataString(_returnUrl);
                NavigationManager.NavigateTo(otpUrl);
            }
            
            if (!string.IsNullOrEmpty(accessToken) && !string.IsNullOrEmpty(refreshToken))
            {
                await DataService.StoreTokensFromExternalAuth(accessToken, refreshToken);
                
                NavigationManager.NavigateTo(_returnUrl ?? "/", forceLoad: true);
            }
        }
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("applyTheme");
    }
    
    private async Task HandleValidSubmit()
    {
        _isLoading = true;
        var result = await DataService.RegisterAsync(_request);
        _isLoading = false;
        _errorMessage = null;
        if (result.Success)
        {
            var confirmUrl = $"/confirm-email?email={Uri.EscapeDataString(_request.Email)}";
            if (!string.IsNullOrEmpty(_returnUrl))
                confirmUrl += "&returnUrl=" + Uri.EscapeDataString(_returnUrl);
            NavigationManager.NavigateTo(confirmUrl);
        }
        else
        {
            Console.WriteLine("Registration failed: " + (result.ErrorMessage ?? "Unknown error"));
            _errorMessage = result.ErrorMessage ?? Loc["Error_RegisterFailed"];
        }
    }

    private void TogglePasswordVisibility()
    {
        _showPassword = !_showPassword;
    }

    private void ToggleConfirmPasswordVisibility()
    {
        _showConfirmPassword = !_showConfirmPassword;
    }

    private void GoogleOAuth()
    {
        var callbackUrl = "/register" + (!string.IsNullOrEmpty(_returnUrl) ? "?returnUrl=" + Uri.EscapeDataString(_returnUrl) : "");
        NavigationManager.NavigateTo($"/auth/external-login?provider=Google&returnUrl={Uri.EscapeDataString(callbackUrl)}&mode=register", forceLoad: true);
    }

    private void GitHubOAuth()
    {
        var callbackUrl = "/register" + (!string.IsNullOrEmpty(_returnUrl) ? "?returnUrl=" + Uri.EscapeDataString(_returnUrl) : "");
        NavigationManager.NavigateTo($"/auth/external-login?provider=GitHub&returnUrl={Uri.EscapeDataString(callbackUrl)}&mode=register", forceLoad: true);
    }
}