@page "/register"
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using Microsoft.Extensions.Localization
@using Authify.Core.Features
@inject IAuthifyDataService DataService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject IStringLocalizer<Register> Loc
@inject TeamFeatureOptions TeamFeature

<RedirectToHomeIfAuthenticated RedirectUrl="@(_returnUrl ?? "/")" />

<div class="auth-fixed auth-inset-0 auth-flex auth-items-center auth-justify-center auth-z-[1000] auth-overflow-y-auto" style="background: var(--bg); color: var(--text-primary);">
    <div class="auth-w-full auth-max-w-sm auth-p-4">
        <div class="auth-bg-token-surface auth-border auth-border-token auth-rounded-lg auth-p-8 auth-shadow-md auth-transition-transform hover:auth--translate-y-1">
            <div class="auth-text-center auth-mb-8">
                <h1 class="auth-heading-2 auth-mb-2">@Loc["Title_CreateAccount"]</h1>
                <p class="auth-text-sm" style="color: var(--text-secondary);">@Loc["Subtitle_FillDetails"]</p>
            </div>
            
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="auth-bg-red-500/10 auth-border auth-border-red-500 auth-text-red-600 auth-rounded-lg auth-p-3 auth-mb-6 auth-text-sm">
                    @_errorMessage
                </div>
            }
            
            <EditForm Model="_request" OnValidSubmit="HandleValidSubmit" FormName="RegisterForm">
                <DataAnnotationsValidator />
                
                <div class="auth-flex auth-flex-col auth-gap-4">
                    
                    <div class="auth-flex auth-flex-col auth-gap-1">
                        <label for="fullName" class="auth-text-sm auth-font-medium" style="color: var(--text-primary);">@Loc["Label_FullName"]</label>
                        <InputText id="fullName" @bind-Value="_request.FullName" placeholder="@Loc["Placeholder_FullName"]" class="auth-input-field" />
                        <div class="auth-min-h-4 auth-text-xs" style="color: var(--text-muted);">
                            <ValidationMessage For="@(() => _request.FullName)" />
                        </div>
                    </div>
                    
                    <div class="auth-flex auth-flex-col auth-gap-1">
                        <label for="email" class="auth-text-sm auth-font-medium" style="color: var(--text-primary);">@Loc["Label_Email"]</label>
                        <InputText id="email" @bind-Value="_request.Email" placeholder="@Loc["Placeholder_Email"]" class="auth-input-field" />
                        <div class="auth-min-h-4 auth-text-xs" style="color: var(--text-muted);">
                            <ValidationMessage For="@(() => _request.Email)" />
                        </div>
                    </div>
                    
                    <div class="auth-flex auth-flex-col auth-gap-1">
                        <label for="password" class="auth-text-sm auth-font-medium" style="color: var(--text-primary);">@Loc["Label_Password"]</label>
                        <div class="auth-relative auth-w-full">
                            <InputText id="password" @bind-Value="_request.Password" type="@(_showPassword ? "text" : "password")" placeholder="@Loc["Placeholder_Password"]" class="auth-input-field" />
                            <button type="button" class="auth-absolute auth-right-3 auth-top-1/2 auth--translate-y-1/2 auth-bg-transparent auth-border-none" 
                                    style="color: var(--text-secondary); cursor: pointer; width: 1.5rem; height: 1.5rem; display: flex; align-items: center; justify-content: center;"
                                    @onclick="TogglePasswordVisibility" tabindex="-1">
                                <i class="fas @(_showPassword ? "fa-eye-slash" : "fa-eye")"></i>
                            </button>
                        </div>
                        <div class="auth-min-h-4 auth-text-xs" style="color: var(--text-muted);">
                            <ValidationMessage For="@(() => _request.Password)" />
                        </div>
                    </div>
                    
                    <div class="auth-flex auth-flex-col auth-gap-1">
                        <label for="confirmPassword" class="auth-text-sm auth-font-medium" style="color: var(--text-primary);">@Loc["Label_ConfirmPassword"]</label>
                        <div class="auth-relative auth-w-full">
                            <InputText id="confirmPassword" @bind-Value="_request.ConfirmPassword" type="@(_showConfirmPassword ? "text" : "password")" placeholder="@Loc["Placeholder_ConfirmPassword"]" class="auth-input-field" />
                            <button type="button" class="auth-absolute auth-right-3 auth-top-1/2 auth--translate-y-1/2 auth-bg-transparent auth-border-none" 
                                    style="color: var(--text-secondary); cursor: pointer; width: 1.5rem; height: 1.5rem; display: flex; align-items: center; justify-content: center;"
                                    @onclick="ToggleConfirmPasswordVisibility" tabindex="-1">
                                <i class="fas @(_showConfirmPassword ? "fa-eye-slash" : "fa-eye")"></i>
                            </button>
                        </div>
                        <div class="auth-min-h-4 auth-text-xs" style="color: var(--text-muted);">
                            <ValidationMessage For="@(() => _request.ConfirmPassword)" />
                        </div>
                    </div>
                    
                    <div class="auth-flex auth-items-start auth-gap-2">
                        <InputCheckbox id="terms" @bind-Value="_request.TermsAccepted" class="auth-mt-1" />
                        <label for="terms" class="auth-text-xs" style="color: var(--text-secondary);">
                            <span>@Loc["Text_AgreeTo"] <a href="#" class="auth-text-primary auth-no-underline hover:auth-underline">@Loc["Link_Terms"]</a> @Loc["Text_And"] <a href="#" class="auth-text-primary auth-no-underline hover:auth-underline">@Loc["Link_Privacy"]</a></span>
                        </label>
                    </div>
                    <div class="auth-min-h-4 auth-text-xs" style="color: var(--text-muted);">
                        <ValidationMessage For="@(() => _request.TermsAccepted)" />
                    </div>
                    
                    <button type="submit" class="auth-btn-primary auth-w-full auth-mt-2" disabled="@(_isLoading)">
                        @if (_isLoading)
                        {
                            <i class="fas fa-spinner fa-spin"></i> <span>@Loc["Btn_Register_Loading"]</span>
                        }
                        else
                        {
                            <span>@Loc["Btn_Register"]</span>
                        }
                    </button>
                    
                </div>
            </EditForm>
            
            <div class="auth-flex auth-items-center auth-gap-3 auth-my-6" style="color: var(--text-muted);">
                <div style="flex: 1; border-bottom: 1px solid var(--border);"></div>
                <span class="auth-text-xs">@Loc["Divider_Or"]</span>
                <div style="flex: 1; border-bottom: 1px solid var(--border);"></div>
            </div>
            
            <div class="auth-flex auth-flex-col auth-gap-3">
                <button type="button" class="auth-btn-ghost auth-w-full auth-flex auth-gap-2" @onclick="GoogleOAuth">
                    <i class="fab fa-google"></i>
                    <span>@Loc["Btn_Google"]</span>
                </button>
                <button type="button" class="auth-btn-ghost auth-w-full auth-flex auth-gap-2" @onclick="GitHubOAuth">
                    <i class="fab fa-github"></i>
                    <span>@Loc["Btn_GitHub"]</span>
                </button>
            </div>
            
            <p class="auth-text-center auth-mt-6 auth-text-sm" style="color: var(--text-secondary);">
                @Loc["Footer_HaveAccount"] <a href="login" class="auth-font-medium auth-no-underline auth-transition-colors hover:auth-underline" style="color: var(--text-primary);">@Loc["Link_Login"]</a>
            </p>
        </div>
    </div>
</div>

@code {
    private RegisterRequest _request = new();
    private bool _isLoading = false;
    private bool _showPassword = false;
    private bool _showConfirmPassword = false;
    private string? _errorMessage;
    private string? _returnUrl;

    protected override async Task OnInitializedAsync()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var queryParams = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        _returnUrl = queryParams.GetValueOrDefault("returnUrl").ToString();
        if (string.IsNullOrEmpty(_returnUrl)) _returnUrl = null;

        // Einladungstoken: Wenn vorhanden, zur AcceptInvitation-Seite weiterleiten
        if (TeamFeature.IsEnabled)
        {
            var invitationToken = queryParams.GetValueOrDefault("token").ToString();
            if (!string.IsNullOrEmpty(invitationToken))
            {
                NavigationManager.NavigateTo($"/accept-invitation?token={Uri.EscapeDataString(invitationToken)}");
                return;
            }
        }

        if (uri.Fragment.Length > 1)
        {
            var fragmentString = uri.Fragment.Substring(1); 
            var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(fragmentString);

            var accessToken = query.GetValueOrDefault("access").ToString();
            var refreshToken = query.GetValueOrDefault("refresh").ToString();

            if (string.IsNullOrEmpty(refreshToken))
            {
                var otpUrl = "/otp?token=" + (accessToken ?? "");
                if (!string.IsNullOrEmpty(_returnUrl))
                    otpUrl += "&returnUrl=" + Uri.EscapeDataString(_returnUrl);
                NavigationManager.NavigateTo(otpUrl);
            }
            
            if (!string.IsNullOrEmpty(accessToken) && !string.IsNullOrEmpty(refreshToken))
            {
                await DataService.StoreTokensFromExternalAuth(accessToken, refreshToken);
                
                NavigationManager.NavigateTo(_returnUrl ?? "/", forceLoad: true);
            }
        }
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("applyTheme");
    }
    
    private async Task HandleValidSubmit()
    {
        _isLoading = true;
        var result = await DataService.RegisterAsync(_request);
        _isLoading = false;
        _errorMessage = null;
        if (result.Success)
        {
            var confirmUrl = $"/confirm-email?email={Uri.EscapeDataString(_request.Email)}";
            if (!string.IsNullOrEmpty(_returnUrl))
                confirmUrl += "&returnUrl=" + Uri.EscapeDataString(_returnUrl);
            NavigationManager.NavigateTo(confirmUrl);
        }
        else
        {
            Console.WriteLine("Registration failed: " + (result.ErrorMessage ?? "Unknown error"));
            _errorMessage = result.ErrorMessage ?? Loc["Error_RegisterFailed"];
        }
    }

    private void TogglePasswordVisibility()
    {
        _showPassword = !_showPassword;
    }

    private void ToggleConfirmPasswordVisibility()
    {
        _showConfirmPassword = !_showConfirmPassword;
    }

    private void GoogleOAuth()
    {
        var callbackUrl = "/register" + (!string.IsNullOrEmpty(_returnUrl) ? "?returnUrl=" + Uri.EscapeDataString(_returnUrl) : "");
        NavigationManager.NavigateTo($"/auth/external-login?provider=Google&returnUrl={Uri.EscapeDataString(callbackUrl)}&mode=register", forceLoad: true);
    }

    private void GitHubOAuth()
    {
        var callbackUrl = "/register" + (!string.IsNullOrEmpty(_returnUrl) ? "?returnUrl=" + Uri.EscapeDataString(_returnUrl) : "");
        NavigationManager.NavigateTo($"/auth/external-login?provider=GitHub&returnUrl={Uri.EscapeDataString(callbackUrl)}&mode=register", forceLoad: true);
    }
}