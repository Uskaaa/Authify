@page "/accept-invitation"
@using Authify.Core.Features
@using Authify.Core.Interfaces
@using Authify.Core.Models.Teams
@using Microsoft.AspNetCore.WebUtilities

@inject ITeamDataService TeamDataService
@inject TeamFeatureOptions TeamFeature
@inject NavigationManager NavigationManager

<div class="login-container">
    <div class="content-wrapper">
        <div class="auth-card">

            @if (!TeamFeature.IsEnabled)
            {
                <div class="auth-header">
                    <h1>Team-Features deaktiviert</h1>
                </div>
                return;
            }

            @if (_isCheckingToken)
            {
                <div class="auth-header">
                    <h1>Einladung wird geprüft...</h1>
                </div>
                <div class="auth-flex auth-items-center auth-justify-center auth-py-8">
                    <i class="fa-solid fa-spinner fa-spin auth-text-2xl auth-text-primary-500"></i>
                </div>
            }
            else if (_tokenError != null)
            {
                <div class="auth-header">
                    <h1>Ungültige Einladung</h1>
                    <p>Dieser Einladungslink ist nicht mehr gültig.</p>
                </div>
                <div class="alert alert-danger">@_tokenError</div>
                <p class="auth-footer">
                    <a href="login">Zur Anmeldung</a>
                </p>
            }
            else
            {
                <div class="auth-header">
                    <h1>Einladung annehmen</h1>
                    @if (_invitation != null)
                    {
                        <p>Du wurdest eingeladen, dem Team <strong>@_invitation.TeamName</strong> beizutreten.</p>
                    }
                    else
                    {
                        <p>Registriere dich um dem Team beizutreten.</p>
                    }
                </div>

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="alert alert-danger">@_errorMessage</div>
                }

                <EditForm Model="_acceptRequest" OnValidSubmit="HandleAccept" FormName="AcceptInvitationForm">
                    <DataAnnotationsValidator />

                    <div class="auth-stack">

                        <div class="form-group">
                            <label for="fullName">Vollständiger Name</label>
                            <InputText id="fullName" @bind-Value="_acceptRequest.FullName" placeholder="Max Mustermann" />
                            <div class="validation-wrapper">
                                <ValidationMessage For="@(() => _acceptRequest.FullName)" />
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="email">E-Mail-Adresse</label>
                            <InputText id="email" @bind-Value="_acceptRequest.Email" type="email"
                                       disabled="@(_emailPrefilled)"
                                       placeholder="deine@email.de" />
                            <div class="validation-wrapper">
                                <ValidationMessage For="@(() => _acceptRequest.Email)" />
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="password">Passwort</label>
                            <div class="password-input">
                                <InputText id="password" @bind-Value="_acceptRequest.Password"
                                           type="@(_showPassword ? "text" : "password")"
                                           placeholder="Sicheres Passwort" />
                                <button type="button" class="toggle-password" @onclick="() => _showPassword = !_showPassword" tabindex="-1">
                                    <i class="fas @(_showPassword ? "fa-eye-slash" : "fa-eye")"></i>
                                </button>
                            </div>
                            <div class="validation-wrapper">
                                <ValidationMessage For="@(() => _acceptRequest.Password)" />
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="confirmPassword">Passwort bestätigen</label>
                            <div class="password-input">
                                <InputText id="confirmPassword" @bind-Value="_acceptRequest.ConfirmPassword"
                                           type="@(_showConfirmPassword ? "text" : "password")"
                                           placeholder="Passwort wiederholen" />
                                <button type="button" class="toggle-password" @onclick="() => _showConfirmPassword = !_showConfirmPassword" tabindex="-1">
                                    <i class="fas @(_showConfirmPassword ? "fa-eye-slash" : "fa-eye")"></i>
                                </button>
                            </div>
                            <div class="validation-wrapper">
                                <ValidationMessage For="@(() => _acceptRequest.ConfirmPassword)" />
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary" disabled="@_isSubmitting">
                            @if (_isSubmitting)
                            {
                                <i class="fas fa-spinner fa-spin"></i> <span>Beitreten...</span>
                            }
                            else
                            {
                                <span>Team beitreten</span>
                            }
                        </button>

                    </div>
                </EditForm>

                <p class="auth-footer">
                    Bereits ein Konto? <a href="login">Anmelden</a>
                </p>
            }
        </div>
    </div>
</div>

@code {
    private TeamInvitationDto? _invitation;
    private AcceptInvitationRequest _acceptRequest = new();
    private string? _token;
    private string? _tokenError;
    private string? _errorMessage;
    private bool _isCheckingToken = true;
    private bool _isSubmitting;
    private bool _emailPrefilled;
    private bool _showPassword;
    private bool _showConfirmPassword;

    protected override async Task OnInitializedAsync()
    {
        if (!TeamFeature.IsEnabled)
        {
            _isCheckingToken = false;
            return;
        }

        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);
        _token = query.GetValueOrDefault("token").ToString();

        if (string.IsNullOrWhiteSpace(_token))
        {
            _tokenError = "Kein Einladungstoken angegeben.";
            _isCheckingToken = false;
            return;
        }

        _acceptRequest.Token = _token;

        var result = await TeamDataService.GetInvitationByTokenAsync(_token);
        _isCheckingToken = false;

        if (!result.Success || result.Data == null)
        {
            _tokenError = result.ErrorMessage ?? "Dieser Einladungslink ist ungültig oder abgelaufen.";
            return;
        }

        _invitation = result.Data;

        // Bei persönlicher Einladung E-Mail vorbelegen
        if (!string.IsNullOrEmpty(_invitation.Email))
        {
            _acceptRequest.Email = _invitation.Email;
            _emailPrefilled = true;
        }
    }

    private async Task HandleAccept()
    {
        _isSubmitting = true;
        _errorMessage = null;

        var result = await TeamDataService.AcceptInvitationAsync(_acceptRequest);
        _isSubmitting = false;

        if (result.Success && result.Data != null)
        {
            // result.Data enthält den Redirect-Pfad (z.B. "reset-password?email=...&token=...&invited=true")
            NavigationManager.NavigateTo("/" + result.Data, forceLoad: true);
        }
        else
        {
            _errorMessage = result.ErrorMessage ?? "Fehler beim Beitreten des Teams.";
        }
    }
}
