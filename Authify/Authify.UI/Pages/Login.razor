@page "/login"
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using Microsoft.Extensions.Localization

@inject IAuthifyDataService DataService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject IStringLocalizer<Login> Loc

<RedirectToHomeIfAuthenticated RedirectUrl="@(_returnUrl ?? "/")" />

<div class="login-container">
    <div class="content-wrapper">
        <div class="auth-card">
            <div class="auth-header">
                <h1>@Loc["Title_Welcome"]</h1>
                <p>@Loc["Subtitle_Credentials"]</p>
            </div>
            
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert alert-danger">
                    @_errorMessage
                </div>
            }
            
            <EditForm Model="_request" OnValidSubmit="HandleValidSubmit" FormName="LoginForm" method="post">
                <DataAnnotationsValidator />
                
                <div class="auth-stack">
                    
                    <div class="form-group">
                        <label for="email">@Loc["Label_Email"]</label>
                        <InputText id="email" @bind-Value="_request.UsernameOrEmail" />
                        <div class="validation-wrapper">
                            <ValidationMessage For="@(() => _request.UsernameOrEmail)" />
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label for="password">@Loc["Label_Password"]</label>
                        <div class="password-input">
                            <InputText id="password" @bind-Value="_request.Password" type="@(_showPassword ? "text" : "password")" />
                            <button type="button" class="toggle-password" @onclick="TogglePasswordVisibility" tabindex="-1">
                                <i class="fas @(_showPassword ? "fa-eye-slash" : "fa-eye")"></i>
                            </button>
                        </div>
                        <div class="validation-wrapper">
                            <ValidationMessage For="@(() => _request.Password)" />
                        </div>
                    </div>
                    
                    <div class="form-options">
                        <label class="remember-me">
                            <InputCheckbox @bind-Value="_request.RememberMe" />
                            <span>@Loc["Label_RememberMe"]</span>
                        </label>
                        <a href="forgot-password" class="forgot-password">@Loc["Link_ForgotPassword"]</a>
                    </div>
                    
                    <button type="submit" class="btn btn-primary" disabled="@(_isLoading)">
                        @if (_isLoading)
                        {
                            <i class="fas fa-spinner fa-spin"></i> <span>@Loc["Btn_Login_Loading"]</span>
                        }
                        else
                        {
                            <span>@Loc["Btn_Login"]</span>
                        }
                    </button>
                    
                </div> </EditForm>
            
            <div class="divider">
                <span>@Loc["Divider_Or"]</span>
            </div>
            
            <div class="oauth-buttons">
                <button class="btn btn-oauth google" @onclick="GoogleOAuth">
                    <i class="fab fa-google"></i>
                    <span>@Loc["Btn_Google"]</span>
                </button>
                <button class="btn btn-oauth github" @onclick="GitHubOAuth">
                    <i class="fab fa-github"></i>
                    <span>@Loc["Btn_GitHub"]</span>
                </button>
            </div>
            
            <p class="auth-footer">
                @Loc["Footer_NoAccount"] <a href="register">@Loc["Link_Register"]</a>
            </p>
        </div>
    </div>
</div>

@code {
    private LoginRequest _request = new();
    private bool _isLoading;
    private bool _showPassword;
    private string? _errorMessage;
    private string? _returnUrl;

    protected override async Task OnInitializedAsync()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var queryParams = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        _returnUrl = queryParams.GetValueOrDefault("returnUrl").ToString();
        if (string.IsNullOrEmpty(_returnUrl)) _returnUrl = null;

        if (uri.Fragment.Length > 1)
        {
            var fragmentString = uri.Fragment.Substring(1); 
            var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(fragmentString);

            var accessToken = query.GetValueOrDefault("access").ToString();
            var refreshToken = query.GetValueOrDefault("refresh").ToString();

            if (string.IsNullOrEmpty(refreshToken))
            {
                var otpUrl = "/otp?token=" + (accessToken ?? "");
                if (!string.IsNullOrEmpty(_returnUrl))
                    otpUrl += "&returnUrl=" + Uri.EscapeDataString(_returnUrl);
                NavigationManager.NavigateTo(otpUrl);
            }
            
            if (!string.IsNullOrEmpty(accessToken) && !string.IsNullOrEmpty(refreshToken))
            {
                await DataService.StoreTokensFromExternalAuth(accessToken, refreshToken);
                
                NavigationManager.NavigateTo(_returnUrl ?? "/", forceLoad: true);
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("applyTheme");
    }
    
    private async Task HandleValidSubmit()
    {
        _isLoading = true;
        _errorMessage = null;
        var result = await DataService.LoginAsync(_request);
        _isLoading = false;
        
        if (result.Success && result.Data != null)
        {
            var loginResponse = result.Data;
            
            if (loginResponse.ResultKind == LoginResultKind.Jwt)
            {
                if (string.IsNullOrEmpty(loginResponse.RefreshToken))
                {
                    var otpUrl = "/otp?token=" + (loginResponse.AccessToken ?? "");
                    if (!string.IsNullOrEmpty(_returnUrl))
                        otpUrl += "&returnUrl=" + Uri.EscapeDataString(_returnUrl);
                    NavigationManager.NavigateTo(otpUrl);
                }
                else
                {
                    NavigationManager.NavigateTo(_returnUrl ?? "/", forceLoad: !string.IsNullOrEmpty(_returnUrl));
                }
            }
            else if (loginResponse.ResultKind == LoginResultKind.Cookie)
            {
                if (!loginResponse.CookieSet && !string.IsNullOrEmpty(loginResponse.AccessToken))
                {
                    var otpUrl = "/otp?token=" + loginResponse.AccessToken;
                    if (!string.IsNullOrEmpty(_returnUrl))
                        otpUrl += "&returnUrl=" + Uri.EscapeDataString(_returnUrl);
                    NavigationManager.NavigateTo(otpUrl);
                }
                else
                {
                    NavigationManager.NavigateTo(_returnUrl ?? "/", forceLoad: !string.IsNullOrEmpty(_returnUrl));
                }
            }
        }
        else
        {
            // Hier nutzen wir den Localizer Key für "Login failed", falls keine spezifische API-Meldung kommt
            _errorMessage = result.ErrorMessage ?? Loc["Error_LoginFailed"];
        }
    }

    private void TogglePasswordVisibility()
    {
        _showPassword = !_showPassword;
    }

    private void GoogleOAuth()
    {
        var callbackUrl = "/login" + (!string.IsNullOrEmpty(_returnUrl) ? "?returnUrl=" + Uri.EscapeDataString(_returnUrl) : "");
        NavigationManager.NavigateTo($"/auth/external-login?provider=Google&returnUrl={Uri.EscapeDataString(callbackUrl)}&mode=login", forceLoad: true);
    }

    private void GitHubOAuth()
    {
        var callbackUrl = "/login" + (!string.IsNullOrEmpty(_returnUrl) ? "?returnUrl=" + Uri.EscapeDataString(_returnUrl) : "");
        NavigationManager.NavigateTo($"/auth/external-login?provider=GitHub&returnUrl={Uri.EscapeDataString(callbackUrl)}&mode=login", forceLoad: true);
    }
}