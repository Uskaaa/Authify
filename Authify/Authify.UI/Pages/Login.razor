@page "/login"
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using Microsoft.Extensions.Localization
@using Authify.Core.Features

@inject IAuthifyDataService DataService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject IStringLocalizer<Login> Loc
@inject TeamFeatureOptions TeamFeature

<RedirectToHomeIfAuthenticated RedirectUrl="@(_returnUrl ?? "/")" />

<div class="auth-fixed auth-inset-0 auth-flex auth-items-center auth-justify-center auth-z-[1000] auth-overflow-y-auto" style="background: var(--bg); color: var(--text-primary);">
    <div class="auth-w-full auth-max-w-sm auth-p-4">
        <div class="auth-bg-token-surface auth-border auth-border-token auth-rounded-lg auth-p-8 auth-shadow-md auth-transition-transform hover:auth--translate-y-1">
            <div class="auth-text-center auth-mb-8">
                <h1 class="auth-heading-2 auth-mb-2">@Loc["Title_Welcome"]</h1>
                <p class="auth-text-sm" style="color: var(--text-secondary);">@Loc["Subtitle_Credentials"]</p>
            </div>
            
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="auth-bg-red-500/10 auth-border auth-border-red-500 auth-text-red-600 auth-rounded-lg auth-p-3 auth-mb-6 auth-text-sm">
                    @_errorMessage
                </div>
            }
            
            <EditForm Model="_request" OnValidSubmit="HandleValidSubmit" FormName="LoginForm">
                <DataAnnotationsValidator />
                
                <div class="auth-flex auth-flex-col auth-gap-4">
                    
                    <div class="auth-flex auth-flex-col auth-gap-1">
                        <label for="email" class="auth-text-sm auth-font-medium" style="color: var(--text-primary);">@Loc["Label_Email"]</label>
                        <InputText id="email" @bind-Value="_request.UsernameOrEmail" class="auth-input-field" />
                        <div class="auth-min-h-4 auth-text-xs" style="color: var(--text-muted);">
                            <ValidationMessage For="@(() => _request.UsernameOrEmail)" />
                        </div>
                    </div>
                    
                    <div class="auth-flex auth-flex-col auth-gap-1">
                        <label for="password" class="auth-text-sm auth-font-medium" style="color: var(--text-primary);">@Loc["Label_Password"]</label>
                        <div class="auth-relative auth-w-full">
                            <InputText id="password" @bind-Value="_request.Password" type="@(_showPassword ? "text" : "password")" class="auth-input-field" />
                            <button type="button" class="auth-absolute auth-right-3 auth-top-1/2 auth--translate-y-1/2 auth-bg-transparent auth-border-none" 
                                    style="color: var(--text-secondary); cursor: pointer; width: 1.5rem; height: 1.5rem; display: flex; align-items: center; justify-content: center;"
                                    @onclick="TogglePasswordVisibility" tabindex="-1">
                                <i class="fas @(_showPassword ? "fa-eye-slash" : "fa-eye")"></i>
                            </button>
                        </div>
                        <div class="auth-min-h-4 auth-text-xs" style="color: var(--text-muted);">
                            <ValidationMessage For="@(() => _request.Password)" />
                        </div>
                    </div>
                    
                    <div class="auth-flex auth-justify-between auth-items-center auth-text-sm">
                        <label class="auth-flex auth-items-center auth-gap-2" style="color: var(--text-secondary); cursor: pointer;">
                            <InputCheckbox @bind-Value="_request.RememberMe" />
                            <span>@Loc["Label_RememberMe"]</span>
                        </label>
                        <a href="forgot-password" class="auth-text-sm auth-no-underline auth-transition-colors hover:auth-underline" style="color: var(--text-primary);">@Loc["Link_ForgotPassword"]</a>
                    </div>
                    
                    <button type="submit" class="auth-btn-primary auth-w-full" disabled="@(_isLoading)">
                        @if (_isLoading)
                        {
                            <i class="fas fa-spinner fa-spin"></i> <span>@Loc["Btn_Login_Loading"]</span>
                        }
                        else
                        {
                            <span>@Loc["Btn_Login"]</span>
                        }
                    </button>
                    
                </div>
            </EditForm>
            
            <div class="auth-flex auth-items-center auth-gap-3 auth-my-6" style="color: var(--text-muted);">
                <div style="flex: 1; border-bottom: 1px solid var(--border);"></div>
                <span class="auth-text-xs">@Loc["Divider_Or"]</span>
                <div style="flex: 1; border-bottom: 1px solid var(--border);"></div>
            </div>
            
            <div class="auth-flex auth-flex-col auth-gap-3">
                <button type="button" class="auth-btn-ghost auth-w-full auth-flex auth-gap-2" @onclick="GoogleOAuth">
                    <i class="fab fa-google"></i>
                    <span>@Loc["Btn_Google"]</span>
                </button>
                <button type="button" class="auth-btn-ghost auth-w-full auth-flex auth-gap-2" @onclick="GitHubOAuth">
                    <i class="fab fa-github"></i>
                    <span>@Loc["Btn_GitHub"]</span>
                </button>
            </div>
            
            <p class="auth-text-center auth-mt-6 auth-text-sm" style="color: var(--text-secondary);">
                @Loc["Footer_NoAccount"] <a href="register" class="auth-font-medium auth-no-underline auth-transition-colors hover:auth-underline" style="color: var(--text-primary);">@Loc["Link_Register"]</a>
            </p>

            @if (TeamFeature.IsEnabled)
            {
                <p class="auth-text-center auth-mt-3 auth-text-xs">
                    <a href="admin/team-settings" class="auth-font-medium auth-no-underline auth-transition-colors hover:auth-underline" style="color: var(--text-muted);">Team-Account erstellen</a>
                </p>
            }
        </div>
    </div>
</div>

@code {
    private LoginRequest _request = new();
    private bool _isLoading;
    private bool _showPassword;
    private string? _errorMessage;
    private string? _returnUrl;

    protected override async Task OnInitializedAsync()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var queryParams = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        _returnUrl = queryParams.GetValueOrDefault("returnUrl").ToString();
        if (string.IsNullOrEmpty(_returnUrl)) _returnUrl = null;

        if (uri.Fragment.Length > 1)
        {
            var fragmentString = uri.Fragment.Substring(1); 
            var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(fragmentString);

            var accessToken = query.GetValueOrDefault("access").ToString();
            var refreshToken = query.GetValueOrDefault("refresh").ToString();

            if (string.IsNullOrEmpty(refreshToken))
            {
                var otpUrl = "/otp?token=" + (accessToken ?? "");
                if (!string.IsNullOrEmpty(_returnUrl))
                    otpUrl += "&returnUrl=" + Uri.EscapeDataString(_returnUrl);
                NavigationManager.NavigateTo(otpUrl);
            }
            
            if (!string.IsNullOrEmpty(accessToken) && !string.IsNullOrEmpty(refreshToken))
            {
                await DataService.StoreTokensFromExternalAuth(accessToken, refreshToken);
                
                NavigationManager.NavigateTo(_returnUrl ?? "/", forceLoad: true);
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("applyTheme");
    }
    
    private async Task HandleValidSubmit()
    {
        _isLoading = true;
        _errorMessage = null;
        var result = await DataService.LoginAsync(_request);
        _isLoading = false;
        
        if (result.Success && result.Data != null)
        {
            var loginResponse = result.Data;
            
            if (loginResponse.ResultKind == LoginResultKind.Jwt)
            {
                if (string.IsNullOrEmpty(loginResponse.RefreshToken))
                {
                    var otpUrl = "/otp?token=" + (loginResponse.AccessToken ?? "");
                    if (!string.IsNullOrEmpty(_returnUrl))
                        otpUrl += "&returnUrl=" + Uri.EscapeDataString(_returnUrl);
                    NavigationManager.NavigateTo(otpUrl);
                }
                else
                {
                    NavigationManager.NavigateTo(_returnUrl ?? "/", forceLoad: true);
                }
            }
            else if (loginResponse.ResultKind == LoginResultKind.Cookie)
            {
                if (!string.IsNullOrEmpty(loginResponse.RedirectUrl))
                {
                    // Redirect to the complete-login HTTP endpoint so SignInManager can
                    // write the HttpOnly auth cookie to a real HTTP response (not WebSocket).
                    var redirectUrl = loginResponse.RedirectUrl;
                    if (!string.IsNullOrEmpty(_returnUrl))
                        redirectUrl += "&returnUrl=" + Uri.EscapeDataString(_returnUrl);
                    NavigationManager.NavigateTo(redirectUrl, forceLoad: true);
                }
                else if (!loginResponse.CookieSet && !string.IsNullOrEmpty(loginResponse.AccessToken))
                {
                    var otpUrl = "/otp?token=" + loginResponse.AccessToken;
                    if (!string.IsNullOrEmpty(_returnUrl))
                        otpUrl += "&returnUrl=" + Uri.EscapeDataString(_returnUrl);
                    NavigationManager.NavigateTo(otpUrl);
                }
                else
                {
                    NavigationManager.NavigateTo(_returnUrl ?? "/", forceLoad: true);
                }
            }
        }
        else
        {
            // Hier nutzen wir den Localizer Key für "Login failed", falls keine spezifische API-Meldung kommt
            _errorMessage = result.ErrorMessage ?? Loc["Error_LoginFailed"];
        }
    }

    private void TogglePasswordVisibility()
    {
        _showPassword = !_showPassword;
    }

    private void GoogleOAuth()
    {
        var callbackUrl = "/login" + (!string.IsNullOrEmpty(_returnUrl) ? "?returnUrl=" + Uri.EscapeDataString(_returnUrl) : "");
        NavigationManager.NavigateTo($"/auth/external-login?provider=Google&returnUrl={Uri.EscapeDataString(callbackUrl)}&mode=login", forceLoad: true);
    }

    private void GitHubOAuth()
    {
        var callbackUrl = "/login" + (!string.IsNullOrEmpty(_returnUrl) ? "?returnUrl=" + Uri.EscapeDataString(_returnUrl) : "");
        NavigationManager.NavigateTo($"/auth/external-login?provider=GitHub&returnUrl={Uri.EscapeDataString(callbackUrl)}&mode=login", forceLoad: true);
    }
}