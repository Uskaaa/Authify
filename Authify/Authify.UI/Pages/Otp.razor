@page "/otp"
@rendermode @(new InteractiveAutoRenderMode(prerender: false))
@using System.ComponentModel.DataAnnotations
@using Microsoft.JSInterop
@using Microsoft.Extensions.Localization

@implements IAsyncDisposable
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject IAuthifyDataService DataService
@inject IStringLocalizer<Otp> Loc

<RedirectToHomeIfAuthenticated />

<div @ref="_otpContainer" class="otp-container">
    <div class="content-wrapper">
        <div class="auth-card">
            <div class="auth-header">
                <h1>@Loc["Title_VerifyEmail"]</h1>
                <p>@Loc["Subtitle_EnterCode"]</p>
            </div>
            
            <EditForm Model="this" OnValidSubmit="HandleValidSubmit">
                <div class="auth-stack">
                    
                    <input type="hidden" @bind="OtpCode" />

                    <div class="otp-inputs">
                        @for (int i = 0; i < 6; i++)
                        {
                            <input class="otp-input" maxlength="1" inputmode="numeric" pattern="[0-9]" />
                        }
                    </div>
                    
                    <div class="validation-wrapper">
                        <ValidationMessage For="@(() => OtpCode)" />
                        @if (_error)
                        {
                            <div class="validation-message">@Loc["Error_VerificationFailed"]</div>
                        }
                    </div>

                    <div class="otp-timer-section">
                        @if (_timeLeft > 0)
                        {
                            <span class="timer-text">@Loc["Text_ResendCodeIn"] <span class="time-value">@FormatTime(_timeLeft)</span></span>
                        }
                        else
                        {
                            <span class="timer-text">@Loc["Text_NoCode"]</span>
                            <button type="button" class="btn-link" @onclick="ResendOtp" disabled="@_isResending">
                                @if (_isResending)
                                {
                                    <span>@Loc["Btn_Sending"]</span>
                                }
                                else
                                {
                                    <span>@Loc["Btn_Resend"]</span>
                                }
                            </button>
                        }
                    </div>

                    <button type="submit" class="btn btn-primary" disabled="@(_isVerifying || OtpCode?.Length != 6)">
                        @if (_isVerifying) 
                        { 
                            <i class="fas fa-spinner fa-spin"></i> <span>@Loc["Btn_Verifying"]</span>
                        } 
                        else 
                        { 
                            <span>@Loc["Btn_Verify"]</span> 
                        }
                    </button>
                    
                </div> </EditForm>
            
            <p class="auth-footer">
                <a href="@("login" + (!string.IsNullOrEmpty(_returnUrl) ? "?returnUrl=" + Uri.EscapeDataString(_returnUrl) : ""))">@Loc["Link_BackToLogin"]</a>
            </p>
        </div>
    </div>
</div>

@code {
    private ElementReference _otpContainer;
    private IJSObjectReference? _module;
    private DotNetObjectReference<Otp>? _objRef;
    private System.Threading.Timer? _timer;

    // DataAnnotations Attribute benötigen Konstanten, daher hier fest auf Deutsch (Default) gesetzt.
    // Für volle dynamische Lokalisierung der ValidationAttributes wäre ein komplexerer DataAnnotationsLocalizerProvider nötig.
    [Required(ErrorMessage = "Der Code ist erforderlich.")]
    [StringLength(6, MinimumLength = 6, ErrorMessage = "Bitte geben Sie den vollständigen 6-stelligen Code ein.")]
    private string OtpCode { get; set; } = string.Empty;

    private OtpVerificationRequest _request = new OtpVerificationRequest();
    private bool _isVerifying = false;
    private bool _isResending = false;
    private bool _error = false;
    private int _timeLeft = 60; // Sekunden für Countdown
    private string? _returnUrl;

    protected override Task OnInitializedAsync()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        _request.Token = query.GetValueOrDefault("token")!;
        _returnUrl = query.GetValueOrDefault("returnUrl").ToString();
        if (string.IsNullOrEmpty(_returnUrl)) _returnUrl = null;
        
        StartTimer();
        
        return base.OnInitializedAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("applyTheme");
        
        if (firstRender)
        {
            try 
            {
                _module = await JS.InvokeAsync<IJSObjectReference>(
                    "import", "./_content/Authify.UI/js/otp.js");

                _objRef = DotNetObjectReference.Create(this);

                await _module.InvokeVoidAsync("initializeOtpHandler", _otpContainer, _objRef);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Fehler beim Laden des OTP-Scripts: {ex.Message}");
            }
        }
    }

    [JSInvokable]
    public void OnOtpCompleted(string otp)
    {
         // Optional: Auto-Submit wenn voll
         OtpCode = otp;
         StateHasChanged();
    }

    private void StartTimer()
    {
        _timeLeft = 60;
        _timer?.Dispose();
        _timer = new System.Threading.Timer(OnTimerElapsed, null, 1000, 1000);
    }

    private async void OnTimerElapsed(object? state)
    {
        if (_timeLeft > 0)
        {
            _timeLeft--;
            await InvokeAsync(StateHasChanged);
        }
        else
        {
            _timer?.Dispose();
        }
    }

    private string FormatTime(int seconds)
    {
        TimeSpan time = TimeSpan.FromSeconds(seconds);
        return time.ToString(@"mm\:ss");
    }

    private async Task ResendOtp()
    {
        _isResending = true;
        
        // Simuliere API Aufruf - hier würdest du DataService.ResendOtpAsync(_request.Token) aufrufen
        await Task.Delay(1000); 
        
        // Reset Timer
        StartTimer();
        _isResending = false;
    }

    private async Task HandleValidSubmit()
    {
        _isVerifying = true;
        _request.OtpCode = OtpCode;
        
        var jwtResult = await DataService.JwtVerifyOtpAsync(_request);
        
        if (jwtResult.Success)
        {
            _error = false;
            NavigationManager.NavigateTo(_returnUrl ?? "/", forceLoad: true);
        }
        else
        {
            var cookieResult = await DataService.CookieVerifyOtpAsync(_request);
            
            if (cookieResult.Success)
            {
                _error = false;
                NavigationManager.NavigateTo(_returnUrl ?? "/", forceLoad: !string.IsNullOrEmpty(_returnUrl));
            }
            else
            {
                _error = true;
            }
        }
        
        _isVerifying = false;
    }

    public async ValueTask DisposeAsync()
    {
        _timer?.Dispose();
        _objRef?.Dispose();
        
        if (_module is not null)
        {
            await _module.DisposeAsync();
        }
    }
}