@page "/forgot-password"
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using Microsoft.Extensions.Localization

@inject IAuthifyDataService DataService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject IStringLocalizer<ForgotPassword> Loc

<RedirectToHomeIfAuthenticated />

<div class="auth-fixed auth-inset-0 auth-flex auth-items-center auth-justify-center auth-z-[1000] auth-overflow-y-auto" style="background: var(--bg); color: var(--text-primary);">
    <div class="auth-w-full auth-max-w-sm auth-p-4">
        <div class="auth-bg-token-surface auth-border auth-border-token auth-rounded-lg auth-p-8 auth-shadow-md auth-transition-transform hover:auth--translate-y-1">
            <div class="auth-text-center auth-mb-8">
                <h1 class="auth-heading-2 auth-mb-2">@Loc["Title_ForgotPassword"]</h1>
                <p class="auth-text-sm" style="color: var(--text-secondary);">@Loc["Subtitle_EnterEmail"]</p>
            </div>
            
            @if (!_emailSent)
            {
                <EditForm Model="_request" OnValidSubmit="HandleValidSubmit" FormName="ForgotPasswordForm" method="post">
                    <DataAnnotationsValidator />
                    
                    <div class="auth-flex auth-flex-col auth-gap-4">
                        <div class="auth-flex auth-flex-col auth-gap-1">
                            <label for="email" class="auth-text-sm auth-font-medium" style="color: var(--text-primary);">@Loc["Label_Email"]</label>
                            <InputText id="email" @bind-Value="_request.Email" placeholder="@Loc["Placeholder_Email"]" class="auth-input-field" />
                            <div class="auth-min-h-4 auth-text-xs" style="color: var(--text-muted);">
                                <ValidationMessage For="@(() => _request.Email)" />
                            </div>
                        </div>
                        
                        <button type="submit" class="auth-btn-primary auth-w-full" disabled="@(_isLoading)">
                            @if (_isLoading)
                            {
                                <i class="fas fa-spinner fa-spin"></i> <span>@Loc["Btn_Sending"]</span>
                            }
                            else
                            {
                                <span>@Loc["Btn_SendLink"]</span>
                            }
                        </button>
                    </div>
                </EditForm>
            }
            else
            {
                <div class="auth-text-center auth-py-8">
                    <div class="auth-text-4xl auth-mb-4" style="color: var(--text-primary);">
                        <i class="fas fa-check-circle"></i>
                    </div>
                    <h2 class="auth-heading-3 auth-mb-3">@Loc["Title_Success"]</h2>
                    <p class="auth-text-sm" style="color: var(--text-secondary);">@Loc["Text_Success"]</p>
                </div>
            }
            
            <p class="auth-text-center auth-mt-6 auth-text-sm" style="color: var(--text-secondary);">
                @Loc["Footer_Remember"] <a href="login" class="auth-text-primary auth-font-medium auth-no-underline hover:auth-underline">@Loc["Link_Login"]</a>
            </p>
        </div>
    </div>
</div>

@code {
    private ForgotPasswordRequest _request = new();
    private bool _emailSent = false;
    private bool _isLoading = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("applyTheme");
    }
    
    private async Task HandleValidSubmit()
    {
        _isLoading = true;
        var result = await DataService.ForgotPasswordAsync(_request);
        if (result.Success) _emailSent = true;
        _isLoading = false;
    }
}