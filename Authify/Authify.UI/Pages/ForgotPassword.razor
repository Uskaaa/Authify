@page "/forgot-password"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@inject IAuthifyDataService DataService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<RedirectToHomeIfAuthenticated />

<div class="forgot-container">
    <div class="content-wrapper">
        <div class="auth-card">
            <div class="auth-header">
                <h1>Forgot Password</h1>
                <p>Enter your email to reset your password</p>
            </div>
            
            @if (!_emailSent)
            {
                <EditForm Model="_request" OnValidSubmit="HandleValidSubmit">
                    <DataAnnotationsValidator />
                    
                    <!-- Wrapper für korrekte Abstände (Flex-Gap) -->
                    <div class="auth-stack">
                        <div class="form-group">
                            <label for="email">Email</label>
                            <InputText id="email" @bind-Value="_request.Email" placeholder="name@example.com" />
                            <div class="validation-wrapper">
                                <ValidationMessage For="@(() => _request.Email)" />
                            </div>
                        </div>
                        
                        <button type="submit" class="btn btn-primary" disabled="@(_isLoading)">
                            @if (_isLoading)
                            {
                                <i class="fas fa-spinner fa-spin"></i> <span>Sending...</span>
                            }
                            else
                            {
                                <span>Send Reset Link</span>
                            }
                        </button>
                    </div>
                </EditForm>
            }
            else
            {
                <div class="success-message">
                    <div class="success-icon">
                        <i class="fas fa-check-circle"></i>
                    </div>
                    <h2>Email Sent!</h2>
                    <p>We've sent you an email with instructions to reset your password.</p>
                </div>
            }
            
            <p class="auth-footer">
                Remember your password? <a href="login">Sign in</a>
            </p>
        </div>
    </div>
</div>

@code {
    private ForgotPasswordRequest _request = new();
    private bool _emailSent = false;
    private bool _isLoading = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("applyTheme");
    }
    
    private async Task HandleValidSubmit()
    {
        _isLoading = true;
        var result = await DataService.ForgotPasswordAsync(_request);
        if (result.Success) _emailSent = true;
        _isLoading = false;
    }
}