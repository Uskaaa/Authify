@page "/forgot-password"
@rendermode @(new InteractiveAutoRenderMode(prerender: false))
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using Microsoft.Extensions.Localization

@inject IAuthifyDataService DataService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject IStringLocalizer<ForgotPassword> Loc

<RedirectToHomeIfAuthenticated />

<div class="forgot-container">
    <div class="content-wrapper">
        <div class="auth-card">
            <div class="auth-header">
                <h1>@Loc["Title_ForgotPassword"]</h1>
                <p>@Loc["Subtitle_EnterEmail"]</p>
            </div>
            
            @if (!_emailSent)
            {
                <EditForm Model="_request" OnValidSubmit="HandleValidSubmit">
                    <DataAnnotationsValidator />
                    
                    <div class="auth-stack">
                        <div class="form-group">
                            <label for="email">@Loc["Label_Email"]</label>
                            <InputText id="email" @bind-Value="_request.Email" placeholder="@Loc["Placeholder_Email"]" />
                            <div class="validation-wrapper">
                                <ValidationMessage For="@(() => _request.Email)" />
                            </div>
                        </div>
                        
                        <button type="submit" class="btn btn-primary" disabled="@(_isLoading)">
                            @if (_isLoading)
                            {
                                <i class="fas fa-spinner fa-spin"></i> <span>@Loc["Btn_Sending"]</span>
                            }
                            else
                            {
                                <span>@Loc["Btn_SendLink"]</span>
                            }
                        </button>
                    </div>
                </EditForm>
            }
            else
            {
                <div class="success-message">
                    <div class="success-icon">
                        <i class="fas fa-check-circle"></i>
                    </div>
                    <h2>@Loc["Title_Success"]</h2>
                    <p>@Loc["Text_Success"]</p>
                </div>
            }
            
            <p class="auth-footer">
                @Loc["Footer_Remember"] <a href="login">@Loc["Link_Login"]</a>
            </p>
        </div>
    </div>
</div>

@code {
    private ForgotPasswordRequest _request = new();
    private bool _emailSent = false;
    private bool _isLoading = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("applyTheme");
    }
    
    private async Task HandleValidSubmit()
    {
        _isLoading = true;
        var result = await DataService.ForgotPasswordAsync(_request);
        if (result.Success) _emailSent = true;
        _isLoading = false;
    }
}