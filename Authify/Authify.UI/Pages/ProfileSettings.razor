@page "/profile-settings"
@using Microsoft.AspNetCore.Components.Forms
@using System.ComponentModel.DataAnnotations
@using Microsoft.JSInterop
@using Microsoft.Extensions.Localization

@layout ProfileLayout
@inject IJSRuntime JS
@inject IAuthifyDataService DataService
@inject IStringLocalizer<ProfileSettings> Loc
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<header class="auth-bg-white dark:auth-bg-dark-card auth-border-b auth-border-gray-200 dark:auth-border-dark-border auth-pt-16 lg:auth-pt-0 auth-transition-colors auth-duration-300">
    <div class="auth-px-4 auth-py-6 sm:auth-px-6 lg:auth-px-8">
        <div class="auth-flex auth-flex-col lg:auth-flex-row lg:auth-items-center lg:auth-justify-between">
            <div>
                <h1 class="auth-text-3xl auth-font-bold auth-leading-tight auth-text-gray-900 dark:auth-text-dark-text">@Loc["Title_Page"]</h1>
                <p class="auth-mt-2 auth-text-sm auth-text-gray-600 dark:auth-text-dark-muted">@Loc["Subtitle_Page"]</p>
            </div>
            <div class="auth-flex auth-flex-col sm:auth-flex-row auth-items-start sm:auth-items-center auth-space-y-3 sm:auth-space-y-0 sm:auth-space-x-3 auth-mt-4 lg:auth-mt-0">
                <button class="auth-inline-flex auth-items-center auth-px-4 auth-py-2 auth-text-sm auth-font-medium auth-text-gray-700 dark:auth-text-dark-text auth-bg-white dark:auth-bg-dark-card auth-border auth-border-gray-300 dark:auth-border-dark-border auth-rounded-md hover:auth-bg-gray-50 dark:hover:auth-bg-gray-700 focus:auth-outline-none auth-transition-all auth-duration-200">
                    <svg class="auth-w-4 auth-h-4 auth-mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path>
                    </svg>
                    @Loc["Btn_ExportData"]
                </button>
                <button @onclick="SaveProfile" disabled="@_isSaving" class="auth-inline-flex auth-items-center auth-px-4 auth-py-2 auth-text-sm auth-font-medium auth-text-white auth-bg-primary-600 auth-border auth-border-transparent auth-rounded-md hover:auth-bg-primary-700 focus:auth-outline-none auth-transition-all auth-duration-200 disabled:auth-opacity-50 disabled:auth-cursor-not-allowed">
                    @if (_isSaving)
                    {
                        <i class="fa-solid fa-circle-notch fa-spin auth-mr-2"></i>
                        <span>@Loc["Btn_Saving"]</span>
                    }
                    else
                    {
                        <span>@Loc["Btn_SaveChanges"]</span>
                    }
                </button>
            </div>
        </div>
    </div>
</header>

@if (_showNotification)
{
    <div class="auth-fixed auth-top-4 auth-right-4 auth-z-[10000] auth-px-4 auth-py-3 auth-rounded-md auth-shadow-lg auth-max-w-sm auth-transform auth-transition-all auth-duration-300 @_notificationClass auth-animate-fade-in-down">
        <div class="auth-flex auth-items-center">
            @if (_notificationClass.Contains("auth-bg-green"))
            {
                <i class="fa-solid fa-check-circle auth-mr-2"></i>
            }
            else
            {
                <i class="fa-solid fa-circle-exclamation auth-mr-2"></i>
            }
            @_notificationMessage
        </div>
    </div>
}

<div class="auth-px-4 auth-py-6 sm:auth-px-6 lg:auth-px-8 auth-bg-gray-50 dark:auth-bg-dark-bg auth-min-h-screen">
    <div class="auth-max-w-4xl auth-mx-auto" @ref="_rootElement">
        
        @if (_isLoading)
        {
            <div class="auth-flex auth-justify-center auth-items-center auth-h-64">
                <i class="fa-solid fa-circle-notch fa-spin auth-text-3xl auth-text-primary-500"></i>
            </div>
        }
        else
        {
            <div class="auth-mb-8 auth-bg-white dark:auth-bg-dark-card auth-rounded-xl auth-shadow-sm auth-border auth-border-gray-100 dark:auth-border-dark-border auth-overflow-hidden auth-transition-colors auth-duration-300">
                <div class="auth-px-8 auth-py-6 auth-border-b auth-border-gray-100 dark:auth-border-dark-border auth-bg-gray-50/50 dark:auth-bg-gray-800/50">
                    <div class="auth-flex auth-items-center auth-justify-between">
                        <div>
                            <h3 class="auth-text-xl auth-font-semibold auth-text-gray-900 dark:auth-text-dark-text">@Loc["Title_PersonalInfo"]</h3>
                            <p class="auth-mt-2 auth-text-sm auth-text-gray-600 dark:auth-text-dark-muted">@Loc["Text_PersonalInfoDesc"]</p>
                        </div>
                        <div class="auth-flex-shrink-0">
                            <div class="auth-w-12 auth-h-12 auth-bg-primary-100 dark:auth-bg-primary-900/50 auth-rounded-xl auth-flex auth-items-center auth-justify-center">
                                <svg class="auth-w-6 auth-h-6 auth-text-primary-600 dark:auth-text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                                </svg>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="auth-px-8 auth-py-8">
                    <EditForm Model="@_profileModel" OnValidSubmit="SaveProfile">
                        <DataAnnotationsValidator/>

                        <div class="auth-grid auth-grid-cols-1 auth-gap-8 lg:auth-grid-cols-2">
                            <div class="lg:auth-col-span-2">
                                <label class="auth-block auth-text-sm auth-font-semibold auth-text-gray-900 dark:auth-text-dark-text auth-mb-3">
                                    @Loc["Label_FullName"] <span class="auth-text-red-500 auth-ml-1">*</span>
                                </label>
                                <InputText @bind-Value="_profileModel.FullName"
                                           class="auth-block auth-w-full auth-px-4 auth-py-3 auth-text-gray-900 dark:auth-text-dark-text auth-placeholder-gray-500 dark:auth-placeholder-dark-muted auth-border auth-border-gray-200 dark:auth-border-dark-border auth-bg-white dark:auth-bg-gray-700 auth-rounded-xl auth-shadow-sm auth-transition-all auth-duration-200 focus:auth-outline-none focus:auth-ring-2 focus:auth-ring-primary-500 focus:auth-border-primary-500 hover:auth-border-gray-300 dark:hover:auth-border-gray-500"
                                           placeholder="@Loc["Placeholder_FullName"]"/>
                                <ValidationMessage For="@(() => _profileModel.FullName)" class="auth-text-red-500 auth-text-xs auth-mt-1"/>
                            </div>

                            <div>
                                <label class="auth-block auth-text-sm auth-font-semibold auth-text-gray-900 dark:auth-text-dark-text auth-mb-3">
                                    @Loc["Label_Email"] <span class="auth-text-red-500 auth-ml-1">*</span>
                                </label>
                                <div class="auth-relative">
                                    <div class="auth-absolute auth-inset-y-0 auth-left-0 auth-pl-4 auth-flex auth-items-center auth-pointer-events-none">
                                        <svg class="auth-h-5 auth-w-5 auth-text-gray-400 dark:auth-text-dark-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207"></path>
                                        </svg>
                                    </div>
                                    <InputText @bind-Value="_profileModel.Email"
                                               class="auth-block auth-w-full auth-pl-12 auth-pr-4 auth-py-3 auth-text-gray-500 dark:auth-text-gray-400 auth-bg-gray-100 dark:auth-bg-gray-800 auth-border auth-border-gray-200 dark:auth-border-dark-border auth-rounded-xl auth-shadow-sm auth-cursor-not-allowed"
                                               disabled placeholder="@Loc["Placeholder_Email"]"/>
                                </div>
                                <p class="auth-text-xs auth-text-gray-400 auth-mt-1">@Loc["Text_EmailChange"]</p>
                            </div>

                            <div>
                                <label class="auth-block auth-text-sm auth-font-semibold auth-text-gray-900 dark:auth-text-dark-text auth-mb-3">@Loc["Label_Phone"]</label>
                                <div class="auth-relative">
                                    <div class="auth-absolute auth-inset-y-0 auth-left-0 auth-pl-4 auth-flex auth-items-center auth-pointer-events-none">
                                        <svg class="auth-h-5 auth-w-5 auth-text-gray-400 dark:auth-text-dark-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                                        </svg>
                                    </div>
                                    <InputText @bind-Value="_profileModel.PhoneNumber"
                                               class="auth-block auth-w-full auth-pl-12 auth-pr-4 auth-py-3 auth-text-gray-900 dark:auth-text-dark-text auth-placeholder-gray-500 dark:auth-placeholder-dark-muted auth-border auth-border-gray-200 dark:auth-border-dark-border auth-bg-white dark:auth-bg-gray-700 auth-rounded-xl auth-shadow-sm auth-transition-all auth-duration-200 focus:auth-outline-none focus:auth-ring-2 focus:auth-ring-primary-500 focus:auth-border-primary-500 hover:auth-border-gray-300 dark:hover:auth-border-gray-500"
                                               placeholder="@Loc["Placeholder_Phone"]"/>
                                </div>
                            </div>

                            <div>
                                <label class="auth-block auth-text-sm auth-font-semibold auth-text-gray-900 dark:auth-text-dark-text auth-mb-3">@Loc["Label_JobTitle"]</label>
                                <InputText @bind-Value="_profileModel.JobTitle"
                                           class="auth-block auth-w-full auth-px-4 auth-py-3 auth-text-gray-900 dark:auth-text-dark-text auth-placeholder-gray-500 dark:auth-placeholder-dark-muted auth-border auth-border-gray-200 dark:auth-border-dark-border auth-bg-white dark:auth-bg-gray-700 auth-rounded-xl auth-shadow-sm auth-transition-all auth-duration-200 focus:auth-outline-none focus:auth-ring-2 focus:auth-ring-primary-500 focus:auth-border-primary-500 hover:auth-border-gray-300 dark:hover:auth-border-gray-500"
                                           placeholder="@Loc["Placeholder_JobTitle"]"/>
                            </div>

                            <div>
                                <label class="auth-block auth-text-sm auth-font-semibold auth-text-gray-900 dark:auth-text-dark-text auth-mb-3">@Loc["Label_Company"]</label>
                                <InputText @bind-Value="_profileModel.Company"
                                           class="auth-block auth-w-full auth-px-4 auth-py-3 auth-text-gray-900 dark:auth-text-dark-text auth-placeholder-gray-500 dark:auth-placeholder-dark-muted auth-border auth-border-gray-200 dark:auth-border-dark-border auth-bg-white dark:auth-bg-gray-700 auth-rounded-xl auth-shadow-sm auth-transition-all auth-duration-200 focus:auth-outline-none focus:auth-ring-2 focus:auth-ring-primary-500 focus:auth-border-primary-500 hover:auth-border-gray-300 dark:hover:auth-border-gray-500"
                                           placeholder="@Loc["Placeholder_Company"]"/>
                            </div>

                            <div class="lg:auth-col-span-2">
                                <label class="auth-block auth-text-sm auth-font-semibold auth-text-gray-900 dark:auth-text-dark-text auth-mb-3">@Loc["Label_Bio"]</label>
                                <InputTextArea @bind-Value="_profileModel.Bio" rows="4"
                                               class="auth-block auth-w-full auth-px-4 auth-py-3 auth-text-gray-900 dark:auth-text-dark-text auth-placeholder-gray-500 dark:auth-placeholder-dark-muted auth-border auth-border-gray-200 dark:auth-border-dark-border auth-bg-white dark:auth-bg-gray-700 auth-rounded-xl auth-shadow-sm auth-transition-all auth-duration-200 focus:auth-outline-none focus:auth-ring-2 focus:auth-ring-primary-500 focus:auth-border-primary-500 hover:auth-border-gray-300 dark:hover:auth-border-gray-500 auth-resize-none"
                                               placeholder="@Loc["Placeholder_Bio"]"/>
                                <p class="auth-mt-2 auth-text-xs auth-text-gray-500 dark:auth-text-dark-muted">@Loc["Text_BioLimit"]</p>
                            </div>
                        </div>

                        <div class="auth-flex auth-flex-col sm:auth-flex-row sm:auth-items-center sm:auth-justify-between auth-pt-6 auth-border-t auth-border-gray-100 dark:auth-border-dark-border auth-mt-8">
                            <div class="auth-flex auth-items-center auth-text-sm auth-text-gray-500 dark:auth-text-dark-muted auth-mb-4 sm:auth-mb-0">
                                <svg class="auth-w-4 auth-h-4 auth-mr-2 auth-text-green-500" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                                </svg>
                                @Loc["Text_AutoSave"]
                            </div>
                            <div class="auth-flex auth-flex-col sm:auth-flex-row sm:auth-items-center auth-space-y-3 sm:auth-space-y-0 sm:auth-space-x-3 auth-w-full sm:auth-w-auto">
                                <button type="button" @onclick="ReloadProfile" class="auth-w-full sm:auth-w-auto auth-px-6 auth-py-3 auth-text-sm auth-font-medium auth-text-gray-700 dark:auth-text-dark-text auth-bg-white dark:auth-bg-dark-card auth-border auth-border-gray-200 dark:auth-border-dark-border auth-rounded-xl hover:auth-bg-gray-50 dark:hover:auth-bg-gray-700 auth-transition-all auth-duration-200">
                                    @Loc["Btn_Reset"]
                                </button>
                                <button type="submit" disabled="@_isSaving" class="auth-w-full sm:auth-w-auto auth-px-8 auth-py-3 auth-text-sm auth-font-semibold auth-text-white auth-bg-primary-600 auth-border auth-border-transparent auth-rounded-xl hover:auth-bg-primary-700 focus:auth-outline-none focus:auth-ring-2 focus:auth-ring-offset-2 focus:auth-ring-primary-500 dark:focus:auth-ring-offset-gray-800 auth-transform hover:auth-scale-105 auth-transition-all auth-duration-200 auth-shadow-lg disabled:auth-opacity-50">
                                    @if (_isSaving)
                                    {
                                        <span>@Loc["Btn_Saving"]</span>
                                    }
                                    else
                                    {
                                        <span>@Loc["Btn_SaveChanges"]</span>
                                    }
                                </button>
                            </div>
                        </div>
                    </EditForm>
                </div>
            </div>

            <div class="auth-mb-8 auth-overflow-hidden auth-bg-white dark:auth-bg-dark-card auth-rounded-lg auth-shadow auth-border auth-border-gray-100 dark:auth-border-dark-border auth-transition-colors auth-duration-300">
                <div class="auth-px-6 auth-py-4 auth-border-b auth-border-gray-200 dark:auth-border-dark-border">
                    <h3 class="auth-text-lg auth-font-medium auth-leading-6 auth-text-gray-900 dark:auth-text-dark-text">@Loc["Title_ProfilePic"]</h3>
                    <p class="auth-mt-1 auth-text-sm auth-text-gray-500 dark:auth-text-dark-muted">@Loc["Text_ProfilePicDesc"]</p>
                </div>
                <div class="auth-px-6 auth-py-6">
                    <div class="auth-flex auth-items-center auth-space-x-6">
                        <div class="auth-flex-shrink-0">
                            <img id="profile-image" class="auth-w-20 auth-h-20 auth-rounded-full auth-object-cover" src="@_currentProfileImage" alt="Current profile photo">
                        </div>
                        <div class="auth-flex-1">
                            <div class="auth-flex auth-items-center auth-space-x-3">
                                <input type="file" id="profile-file-input" accept="image/jpeg,image/png,image/gif" class="auth-hidden"/>

                                <button id="change-profile-btn" type="button" class="auth-px-4 auth-py-2 auth-text-sm auth-font-medium auth-text-primary-600 dark:auth-text-primary-400 auth-bg-white dark:auth-bg-gray-700 auth-border auth-border-primary-300 dark:auth-border-primary-500 auth-rounded-md hover:auth-bg-primary-50 dark:hover:auth-bg-gray-600 auth-transition-colors auth-duration-200">
                                    @Loc["Btn_Change"]
                                </button>
                                <button id="remove-profile-btn" type="button" class="auth-px-4 auth-py-2 auth-text-sm auth-font-medium auth-text-red-600 dark:auth-text-red-400 auth-bg-white dark:auth-bg-gray-700 auth-border auth-border-red-300 dark:auth-border-red-600 auth-rounded-md hover:auth-bg-red-50 dark:hover:auth-bg-gray-600 auth-transition-colors auth-duration-200">
                                    @Loc["Btn_Remove"]
                                </button>
                            </div>
                            <p class="auth-mt-2 auth-text-sm auth-text-gray-500 dark:auth-text-dark-muted">@Loc["Text_FileSpecs"]</p>
                        </div>
                    </div>
                </div>
            </div>
        }
        
        <div id="crop-dialog" class="auth-fixed auth-inset-0 auth-z-[9999] auth-overflow-y-auto auth-hidden" role="dialog" aria-modal="true">
            <div class="auth-flex auth-items-center auth-justify-center auth-min-h-screen auth-p-4">
                <div class="auth-fixed auth-inset-0 auth-bg-gray-900 auth-bg-opacity-75 dark:auth-bg-black dark:auth-bg-opacity-85 auth-transition-opacity" aria-hidden="true"></div>
                <div class="auth-relative auth-bg-white dark:auth-bg-dark-card auth-rounded-lg auth-shadow-xl auth-max-w-lg auth-w-full auth-border auth-border-gray-200 dark:auth-border-dark-border">
                    <div class="auth-p-6">
                        <h3 class="auth-text-lg auth-font-medium auth-text-gray-900 dark:auth-text-dark-text auth-mb-4" id="crop-dialog-title">
                            @Loc["Title_Crop"]
                        </h3>
                        <div class="auth-flex auth-flex-col auth-items-center auth-space-y-4">
                            <div class="auth-relative auth-bg-gray-50 dark:auth-bg-gray-700 auth-rounded-lg auth-p-3">
                                <canvas id="crop-canvas" width="350" height="350" class="auth-border auth-border-gray-300 dark:auth-border-gray-600 auth-rounded auth-cursor-crosshair"></canvas>
                            </div>
                            <div class="auth-text-xs auth-text-gray-500 dark:auth-text-dark-muted auth-text-center">
                                @Loc["Text_CropInstruction"]
                            </div>
                        </div>
                    </div>
                    <div class="auth-bg-gray-50 dark:auth-bg-gray-700 auth-px-6 auth-py-3 auth-flex auth-justify-end auth-space-x-3 auth-border-t auth-border-gray-200 dark:auth-border-dark-border">
                        <button id="crop-cancel-btn" type="button" class="auth-px-4 auth-py-2 auth-text-sm auth-font-medium auth-text-gray-700 dark:auth-text-dark-text auth-bg-white dark:auth-bg-gray-600 auth-border auth-border-gray-300 dark:auth-border-gray-500 auth-rounded-md hover:auth-bg-gray-50 dark:hover:auth-bg-gray-500 auth-transition-colors auth-duration-200">
                            @Loc["Btn_Cancel"]
                        </button>
                        <button id="crop-apply-btn" type="button" class="auth-px-4 auth-py-2 auth-text-sm font-medium auth-text-white auth-bg-primary-600 auth-border auth-border-transparent auth-rounded-md hover:auth-bg-primary-700 auth-transition-colors auth-duration-200">
                            @Loc["Btn_Apply"]
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private PersonalInformationUpdateRequest _profileModel = new();
    private string _currentProfileImage = "https://api.dicebear.com/7.x/avataaars/svg?seed";

    private bool _isLoading = true;
    private bool _isSaving = false;
    private bool _showNotification = false;
    private string _notificationMessage = "";
    // Hier auch Prefix angepasst:
    private string _notificationClass = "auth-bg-green-500 auth-text-white";

    private IJSObjectReference? _module;
    private DotNetObjectReference<ProfileSettings>? _objRef;
    private ElementReference _rootElement;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JS.InvokeVoidAsync("applyTheme");
                _module = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/Authify.UI/js/profile-settings.js");
                _objRef = DotNetObjectReference.Create(this);
                await _module.InvokeVoidAsync("init", _rootElement, _objRef);
            }
            catch (Exception e)
            {
                Console.WriteLine("JS Init failed: " + e.Message);
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        await LoadProfileData();
        _isLoading = false;
    }
    
    private async Task LoadProfileData()
    {
        var result = await DataService.GetProfileAsync();
        if (result.Success && result.Data != null)
        {
            var data = result.Data;
            _profileModel = new PersonalInformationUpdateRequest
            {
                FullName = data.FullName,
                Email = data.Email,
                PhoneNumber = data.PhoneNumber,
                JobTitle = data.JobTitle,
                Company = data.Company,
                Bio = data.Bio
            };

            if (data.ProfileImage != null && data.ProfileImage.Length > 0)
            {
                var base64 = Convert.ToBase64String(data.ProfileImage);
                _currentProfileImage = $"data:image/png;base64,{base64}";
            }
        }
    }

    private async Task SaveProfile()
    {
        _isSaving = true;
        var result = await DataService.UpdatePersonalInformationAsync(_profileModel);
        // Auch hier die Strings mit Prefix angepasst:
        if (result.Success) ShowNotification(Loc["Msg_ProfileUpdated"], "auth-bg-green-500");
        else ShowNotification(result.ErrorMessage ?? Loc["Msg_UpdateFailed"], "auth-bg-red-500");
        _isSaving = false;
    }
    
    private async Task ReloadProfile()
    {
        _isLoading = true;
        await LoadProfileData();
        _isLoading = false;
        // Prefix angepasst:
        ShowNotification(Loc["Msg_Reset"], "auth-bg-gray-500");
    }

    [JSInvokable]
    public async Task UpdateProfileImage(string base64DataUrl)
    {
        _currentProfileImage = base64DataUrl;
        StateHasChanged();

        var base64 = base64DataUrl.Substring(base64DataUrl.IndexOf(",") + 1);
        var bytes = Convert.FromBase64String(base64);
        var request = new ProfileImageUpdateRequest { Image = bytes };
        var result = await DataService.UpdateProfileImageAsync(request);
        
        // Prefix angepasst:
        if (result.Success) ShowNotification(Loc["Msg_PicUpdated"], "auth-bg-green-500");
        else ShowNotification(Loc["Msg_PicUploadFailed"], "auth-bg-red-500");
    }

    [JSInvokable]
    public async Task RemoveProfileImage()
    {
        _currentProfileImage = "https://api.dicebear.com/7.x/avataaars/svg?seed";
        StateHasChanged();
        
        var request = new ProfileImageUpdateRequest { Image = null };
        var result = await DataService.UpdateProfileImageAsync(request);
        
        // Prefix angepasst:
        if (result.Success) ShowNotification(Loc["Msg_PicRemoved"], "auth-bg-blue-500");
        else ShowNotification(Loc["Msg_PicRemoveFailed"], "auth-bg-red-500");
    }

    private void ShowNotification(string message, string cssClass)
    {
        _notificationMessage = message;
        // String concatenation passt so, cssClass enthält bereits den Prefix
        _notificationClass = cssClass + " auth-text-white";
        _showNotification = true;
        StateHasChanged();
        var timer = new System.Threading.Timer((_) => { _showNotification = false; InvokeAsync(StateHasChanged); }, null, 3000, System.Threading.Timeout.Infinite);
    }
    
    public void Dispose()
    {
        _objRef?.Dispose();
    }
}