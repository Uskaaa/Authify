@page "/security-settings"
@using Microsoft.AspNetCore.Components.Forms
@using System.ComponentModel.DataAnnotations
@using Authify.UI.Common
@using Authify.UI.Models
@using Authify.UI.Models.Enums
@using Microsoft.JSInterop
@using Microsoft.Extensions.Localization

@layout ProfileLayout
@inject IJSRuntime JS
@inject IAuthifyDataService DataService
@inject NavigationManager NavigationManager
@inject IStringLocalizer<SecuritySettings> Loc
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<header class="bg-white dark:bg-dark-card border-b border-gray-200 dark:border-dark-border pt-16 lg:pt-0 transition-colors duration-300">
    <div class="px-4 py-6 sm:px-6 lg:px-8">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between">
            <div>
                <h1 class="text-3xl font-bold leading-tight text-gray-900 dark:text-dark-text">@Loc["Title_Page"]</h1>
                <p class="mt-2 text-sm text-gray-600 dark:text-dark-muted">@Loc["Subtitle_Page"]</p>
            </div>
            <div class="flex flex-col sm:flex-row items-start sm:items-center space-y-3 sm:space-y-0 sm:space-x-3 mt-4 lg:mt-0">
                <button class="inline-flex items-center px-4 py-2 text-sm font-medium text-gray-700 dark:text-dark-text bg-white dark:bg-dark-card border border-gray-300 dark:border-dark-border rounded-md hover:bg-gray-50 dark:hover:bg-gray-700 focus:outline-none transition-all duration-200">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path>
                    </svg>
                    @Loc["Btn_ExportReport"]
                </button>
                <button class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-primary-600 border border-transparent rounded-md hover:bg-primary-700 focus:outline-none transition-all duration-200">
                    @Loc["Btn_SaveChanges"]
                </button>
            </div>
        </div>
    </div>
</header>

@if (_showNotification)
{
    <div class="fixed top-4 right-4 z-[10000] px-4 py-3 rounded-md shadow-lg max-w-sm transform transition-all duration-300 @_notificationClass animate-fade-in-down">
        <div class="flex items-center">
            @if (_notificationClass.Contains("bg-green")) { <i class="fa-solid fa-check-circle mr-2"></i> }
            else { <i class="fa-solid fa-circle-info mr-2"></i> }
            @_notificationMessage
        </div>
    </div>
}

<div class="px-4 py-6 sm:px-6 lg:px-8 bg-gray-50 dark:bg-dark-bg min-h-screen">
    <div class="max-w-4xl mx-auto">
        
        <div class="mb-8 bg-white dark:bg-dark-card rounded-xl shadow-sm border border-gray-100 dark:border-dark-border overflow-hidden transition-colors duration-300">
            <div class="px-8 py-6 border-b border-gray-100 dark:border-dark-border bg-gray-50/50 dark:bg-gray-800/50">
                <div class="flex items-center justify-between">
                    <div>
                        <h3 class="text-xl font-semibold text-gray-900 dark:text-dark-text">@Loc["Title_ChangePassword"]</h3>
                        <p class="mt-2 text-sm text-gray-600 dark:text-dark-muted">@Loc["Text_ChangePasswordDesc"]</p>
                    </div>
                    <div class="flex-shrink-0">
                        <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900/50 rounded-xl flex items-center justify-center">
                            <svg class="w-6 h-6 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path>
                            </svg>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="px-8 py-8">
                <EditForm Model="@_passwordModel" OnValidSubmit="UpdatePassword">
                    <DataAnnotationsValidator />
                    
                    <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
                        <div>
                            <label class="block text-sm font-semibold text-gray-900 dark:text-dark-text mb-3">
                                @Loc["Label_CurrentPassword"] <span class="text-red-500 ml-1">*</span>
                            </label>
                            <div class="relative">
                                <input type="password" id="current-password" name="current-password"
                                       @bind="_passwordModel.CurrentPassword"
                                       class="block w-full px-4 py-3 text-gray-900 dark:text-dark-text placeholder-gray-500 dark:placeholder-dark-muted border border-gray-200 dark:border-dark-border bg-white dark:bg-gray-700 rounded-xl shadow-sm transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
                                       placeholder="@Loc["Placeholder_CurrentPassword"]" />
                            </div>
                            <ValidationMessage For="@(() => _passwordModel.CurrentPassword)" class="text-red-500 text-xs mt-1" />
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-gray-900 dark:text-dark-text mb-3">
                                @Loc["Label_NewPassword"] <span class="text-red-500 ml-1">*</span>
                            </label>
                            <div class="relative">
                                <input type="password" id="new-password" name="new-password"
                                       @bind="_passwordModel.NewPassword"
                                       class="block w-full px-4 py-3 text-gray-900 dark:text-dark-text placeholder-gray-500 dark:placeholder-dark-muted border border-gray-200 dark:border-dark-border bg-white dark:bg-gray-700 rounded-xl shadow-sm transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
                                       placeholder="@Loc["Placeholder_NewPassword"]" />
                            </div>
                            <ValidationMessage For="@(() => _passwordModel.NewPassword)" class="text-red-500 text-xs mt-1" />

                            <div class="mt-3 space-y-2">
                                <div class="flex justify-between text-xs">
                                    <span class="text-gray-500 dark:text-dark-muted">@Loc["Label_Strength"]</span>
                                    <span id="strength-text" class="font-medium text-gray-500 dark:text-dark-muted"></span>
                                </div>
                                <div class="w-full bg-gray-200 dark:bg-dark-border rounded-full h-2">
                                    <div id="strength-bar" class="bg-gray-300 dark:bg-dark-border h-2 rounded-full transition-all duration-300" style="width: 0%"></div>
                                </div>
                                <ul class="text-xs text-gray-500 dark:text-dark-muted space-y-1">
                                    <li id="length-check" class="flex items-center transition-colors duration-200">
                                        <svg class="w-3 h-3 mr-2 text-gray-300 dark:text-dark-muted" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
                                        @Loc["Check_Length"]
                                    </li>
                                    <li id="uppercase-check" class="flex items-center transition-colors duration-200">
                                        <svg class="w-3 h-3 mr-2 text-gray-300 dark:text-dark-muted" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
                                        @Loc["Check_Uppercase"]
                                    </li>
                                    <li id="special-check" class="flex items-center transition-colors duration-200">
                                        <svg class="w-3 h-3 mr-2 text-gray-300 dark:text-dark-muted" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
                                        @Loc["Check_Special"]
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    
                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between pt-6 border-t border-gray-100 dark:border-dark-border mt-6">
                        <div class="flex items-center text-sm text-gray-500 dark:text-dark-muted mb-4 sm:mb-0">
                            <svg class="w-4 h-4 mr-2 text-blue-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path></svg>
                            @Loc["Text_UpdateInfo"]
                        </div>
                        <div class="flex flex-col sm:flex-row sm:items-center space-y-3 sm:space-y-0 sm:space-x-3 w-full sm:w-auto">
                            <button type="button" class="w-full sm:w-auto px-6 py-3 text-sm font-medium text-gray-700 dark:text-dark-text bg-white dark:bg-dark-card border border-gray-200 dark:border-dark-border rounded-xl hover:bg-gray-50 dark:hover:bg-gray-700 transition-all duration-200">
                                @Loc["Btn_Cancel"]
                            </button>
                            <button type="submit" disabled="@_isSaving" class="w-full sm:w-auto px-8 py-3 text-sm font-semibold text-white bg-primary-600 border border-transparent rounded-xl hover:bg-primary-700 transform hover:scale-105 transition-all duration-200 shadow-lg disabled:opacity-50 disabled:cursor-not-allowed">
                                @if (_isSaving) { <span>@Loc["Btn_Updating"]</span> } else { <span>@Loc["Btn_UpdatePassword"]</span> }
                            </button>
                        </div>
                    </div>
                </EditForm>
            </div>
        </div>

        <div class="mb-8 bg-white dark:bg-dark-card rounded-xl shadow-sm border border-gray-100 dark:border-dark-border overflow-hidden transition-colors duration-300">
            <div class="px-8 py-6 border-b border-gray-100 dark:border-dark-border bg-gray-50/50 dark:bg-gray-800/50">
                <div class="flex items-center justify-between">
                    <div>
                        <h3 class="text-xl font-semibold text-gray-900 dark:text-dark-text">@Loc["Title_2FA"]</h3>
                        <p class="mt-2 text-sm text-gray-600 dark:text-dark-muted">@Loc["Text_2FADesc"]</p>
                    </div>
                    <div class="flex-shrink-0">
                        <div class="w-12 h-12 bg-green-100 dark:bg-green-900/50 rounded-xl flex items-center justify-center">
                            <svg class="w-6 h-6 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                            </svg>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="px-8 py-8 space-y-6">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between p-6 bg-gray-50 dark:bg-gray-700/50 rounded-xl">
                    <div class="flex-1 mb-4 sm:mb-0">
                        <h5 class="text-sm font-semibold text-gray-900 dark:text-dark-text">@Loc["Title_Enable2FA"]</h5>
                        <p class="text-sm text-gray-600 dark:text-dark-muted mt-1">@Loc["Text_Enable2FADesc"]</p>
                    </div>
                    <div class="flex-shrink-0 sm:ml-6">
                        <button @onclick="OpenTwoFaDialog" class="w-full sm:w-auto px-4 py-2 text-sm font-medium text-primary-700 dark:text-primary-300 bg-primary-100 dark:bg-primary-900/50 border border-primary-300 dark:border-primary-700 rounded-lg hover:bg-primary-200 dark:hover:bg-primary-900/70 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 dark:focus:ring-offset-gray-800 transition-all duration-200">
                            @Loc["Btn_Manage2FA"]
                        </button>
                    </div>
                </div>
                
                <div class="border rounded-xl p-4 @(_activeTwoFaMethods.Any() ? "bg-green-50 dark:bg-green-900/20 border-green-200 dark:border-green-800" : "bg-red-50 dark:bg-red-900/20 border-red-200 dark:border-red-800")">
                    <div class="flex items-start">
                        <svg class="w-5 h-5 mt-0.5 mr-3 @(_activeTwoFaMethods.Any() ? "text-green-500" : "text-red-500")" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                        </svg>
                        <div>
                            @if (_activeTwoFaMethods.Any())
                            {
                                <h6 class="text-sm font-medium text-green-800 dark:text-green-400">@Loc["Status_2FA_Enabled"]</h6>
                                <p class="text-sm text-green-700 dark:text-green-300 mt-1">@string.Format(Loc["Status_2FA_Enabled_Desc"], _activeTwoFaMethods.Count)</p>
                            }
                            else
                            {
                                <h6 class="text-sm font-medium text-red-800 dark:text-red-400">@Loc["Status_2FA_Disabled"]</h6>
                                <p class="text-sm text-red-700 dark:text-red-300 mt-1">@Loc["Status_2FA_Disabled_Desc"]</p>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mb-8 bg-white dark:bg-dark-card rounded-xl shadow-sm border border-gray-100 dark:border-dark-border overflow-hidden transition-colors duration-300">
            <div class="px-8 py-6 border-b border-gray-100 dark:border-dark-border bg-gray-50/50 dark:bg-gray-800/50">
                <div class="flex items-center justify-between">
                    <div>
                        <h3 class="text-xl font-semibold text-gray-900 dark:text-dark-text">@Loc["Title_Connected"]</h3>
                        <p class="mt-2 text-sm text-gray-600 dark:text-dark-muted">@Loc["Text_ConnectedDesc"]</p>
                    </div>
                    <div class="flex-shrink-0">
                        <div class="w-12 h-12 bg-indigo-100 dark:bg-indigo-900/50 rounded-xl flex items-center justify-center">
                            <svg class="w-6 h-6 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
                            </svg>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="px-8 py-8 space-y-4">
                @if (_isLoadingProviders)
                {
                    <div class="flex justify-center p-4">
                        <i class="fa-solid fa-circle-notch fa-spin text-primary-500"></i>
                    </div>
                }
                else
                {
                    @foreach (var provider in _providers)
                    {
                        <div class="flex items-center justify-between p-4 bg-white dark:bg-gray-700/50 border border-gray-200 dark:border-dark-border rounded-xl">
                            <div class="flex items-center space-x-4">
                                <div class="w-10 h-10 @provider.BgClass rounded-full flex items-center justify-center text-lg @provider.TextClass">
                                    <i class="@provider.Icon"></i>
                                </div>
                                <div>
                                    <h5 class="text-sm font-semibold text-gray-900 dark:text-dark-text">@provider.Name</h5>
                                    <p class="text-xs text-gray-500 dark:text-dark-muted">
                                        @(provider.IsConnected ? Loc["Status_Connected"] : Loc["Status_NotConnected"])
                                    </p>
                                </div>
                            </div>
                            <button @onclick="() => ToggleProvider(provider)" class="px-4 py-2 text-sm font-medium rounded-lg transition-all duration-200 @(provider.IsConnected ? "text-red-600 dark:text-red-400 border border-red-200 dark:border-red-900/50 hover:bg-red-50 dark:hover:bg-red-900/20" : "text-primary-600 dark:text-primary-400 border border-primary-200 dark:border-primary-900/50 hover:bg-primary-50 dark:hover:bg-primary-900/20")">
                                @(provider.IsConnected ? Loc["Btn_Disconnect"] : Loc["Btn_Connect"])
                            </button>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@if (_showTwoFaDialog)
{
    <div class="fixed inset-0 z-[9999] overflow-y-auto" role="dialog" aria-modal="true">
        <div class="flex items-center justify-center min-h-screen p-4 text-center">
            <div class="fixed inset-0 bg-gray-900 bg-opacity-75 dark:bg-black/85 backdrop-blur-sm transition-opacity" @onclick="CloseTwoFaDialog"></div>
            
            <div class="relative bg-white dark:bg-dark-card rounded-lg shadow-xl max-w-2xl w-full max-h-[90vh] overflow-hidden transition-colors duration-300">
                <div class="px-6 py-4 border-b border-gray-200 dark:border-dark-border flex justify-between items-center bg-gray-50 dark:bg-gray-700/50">
                    <h3 class="text-lg font-bold text-gray-900 dark:text-dark-text">@Loc["Dialog_2FA_Title"]</h3>
                    <button @onclick="CloseTwoFaDialog" class="text-gray-400 hover:text-gray-600 dark:hover:text-dark-text focus:outline-none rounded-md">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                </div>
                
                <div class="px-6 py-6 max-h-[60vh] overflow-y-auto space-y-6">
                    <div>
                        <h4 class="text-xs font-bold text-gray-500 dark:text-dark-muted uppercase tracking-wider mb-3">@Loc["Section_ActiveMethods"]</h4>
                        <div class="space-y-3">
                            @foreach(var method in _activeTwoFaMethods)
                            {
                                <div class="bg-white dark:bg-gray-700/50 border border-gray-200 dark:border-dark-border rounded-xl p-4 flex items-center justify-between shadow-sm">
                                    <div class="flex items-center gap-4">
                                        <div class="w-10 h-10 @method.BgClass rounded-full flex items-center justify-center @method.TextClass">
                                            @((MarkupString)method.IconSvg)
                                        </div>
                                        <div>
                                            <h5 class="text-sm font-bold text-gray-900 dark:text-dark-text">@Loc[method.NameKey]</h5>
                                            <p class="text-xs text-gray-500 dark:text-dark-muted">@Loc[method.DescKey]</p>
                                        </div>
                                    </div>
                                    
                                    <div class="flex items-center gap-2">
                                        @if(method.Priority == 0) // 0 = Default
                                        {
                                            <span class="hidden sm:inline-block px-2 py-1 text-xs font-medium bg-green-100 dark:bg-green-900/50 text-green-800 dark:text-green-300 rounded-full">@Loc["Badge_Default"]</span>
                                        }
                                        else if(_activeTwoFaMethods.Count > 1)
                                        {
                                            <button @onclick="() => SetDefaultTwoFa(method)" class="hidden sm:block text-xs font-medium text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300 px-3 py-1.5 rounded-lg hover:bg-primary-50 dark:hover:bg-primary-900/30 transition-colors">
                                                @Loc["Btn_SetDefault"]
                                            </button>
                                        }
                                        
                                        <button @onclick="() => RemoveTwoFa(method)" class="text-xs font-medium text-red-600 hover:text-red-700 dark:text-red-400 dark:hover:text-red-300 px-3 py-1.5 rounded-lg hover:bg-red-50 dark:hover:bg-red-900/30 transition-colors">
                                            @Loc["Btn_Remove"]
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    @if(_availableTwoFaMethods.Any())
                    {
                        <div>
                            <h4 class="text-xs font-bold text-gray-500 dark:text-dark-muted uppercase tracking-wider mb-3">@Loc["Section_AvailableMethods"]</h4>
                            <div class="space-y-3">
                                @foreach(var method in _availableTwoFaMethods)
                                {
                                    <div class="bg-gray-50 dark:bg-gray-700/30 border border-gray-200 dark:border-dark-border rounded-xl p-4 flex items-center justify-between">
                                        <div class="flex items-center gap-4">
                                            <div class="w-10 h-10 @method.BgClass rounded-full flex items-center justify-center @method.TextClass">
                                                @((MarkupString)method.IconSvg)
                                            </div>
                                            <div>
                                                <h5 class="text-sm font-bold text-gray-900 dark:text-dark-text">@Loc[method.NameKey]</h5>
                                                <p class="text-xs text-gray-500 dark:text-dark-muted">@Loc[method.DescKey]</p>
                                            </div>
                                        </div>
                                        <button @onclick="() => AddTwoFa(method)" class="text-xs font-bold text-primary-600 dark:text-primary-400 bg-white dark:bg-gray-800 border border-gray-200 dark:border-dark-border px-3 py-1.5 rounded-lg shadow-sm hover:bg-primary-50 dark:hover:bg-primary-900/20 transition-colors">
                                            @Loc["Btn_Add"]
                                        </button>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private ChangePasswordRequest _passwordModel = new();
    private bool _showTwoFaDialog = false;
    private IJSObjectReference? _module;
    private bool _isSaving = false;

    // Notification
    private bool _showNotification = false;
    private string _notificationMessage = "";
    private string _notificationClass = "bg-green-500 text-white";

    // Listen
    private List<SessionModel> _sessions = new();
    private List<ExternalProvider> _providers = new();
    private bool _isLoadingProviders = false;

    // 2FA Listen
    private List<TwoFaUiModel> _allSupportedMethods = new();
    private List<TwoFaUiModel> _activeTwoFaMethods = new();
    private List<TwoFaUiModel> _availableTwoFaMethods = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("applyTheme");
        
        if (firstRender)
        {
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/Authify.UI/js/security-page.js");
            await _module.InvokeVoidAsync("init");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        
        var provider = query.GetValueOrDefault("provider").ToString();
        var key = query.GetValueOrDefault("key").ToString();
        var displayName = query.GetValueOrDefault("display").ToString();
        var error = query.GetValueOrDefault("error").ToString();

        if (!string.IsNullOrEmpty(provider) && !string.IsNullOrEmpty(key) && !string.IsNullOrEmpty(displayName))
        {
            var externalProvider = new ConnectExternalLoginRequest
            {
                LoginProvider = provider,
                ProviderKey = key,
                ProviderDisplayName = displayName
            };
            
            var result = await DataService.ConnectProviderAsync(externalProvider);
            
            if (result.Success)
                NavigationManager.NavigateTo("/security-settings", replace: true);
        }
        else if (!string.IsNullOrEmpty(error))
        {
            ShowNotification(Loc["Msg_ConnectFailed"], "bg-red-500");
        }
        
        // Definition der unterstützten UI Modelle
