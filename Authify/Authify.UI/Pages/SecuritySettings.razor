    // --- PROVIDER LOGIC ---
    private async Task LoadExternalProviders()
    {
        _isLoadingProviders = true;
        _providers.Clear();
        _providers.Add(new ExternalProvider { Name = "Google",   LoginProvider = "Google",   Icon = "fa-brands fa-google",   BgClass = "bg-red-100 dark:bg-red-900/50",   TextClass = "text-red-600 dark:text-red-400" });
        _providers.Add(new ExternalProvider { Name = "GitHub",   LoginProvider = "GitHub",   Icon = "fa-brands fa-github",   BgClass = "bg-gray-100 dark:bg-gray-700",     TextClass = "text-gray-800 dark:text-gray-200" });
        _providers.Add(new ExternalProvider { Name = "Facebook", LoginProvider = "Facebook", Icon = "fa-brands fa-facebook", BgClass = "bg-blue-100 dark:bg-blue-900/50", TextClass = "text-blue-600 dark:text-blue-400" });

        var result = await DataService.GetConnectedProvidersAsync();

        if (result.Success && result.Data != null)
        {
            var connectedProviders = result.Data
                .Select(c => c.LoginProvider)
                .ToList();

            foreach (var p in _providers)
            {
                p.IsConnected = connectedProviders.Contains(p.LoginProvider);
            }
        }

        _isLoadingProviders = false;
        StateHasChanged();
    }

    private async Task ToggleProvider(ExternalProvider provider)
    {
        if (provider.IsConnected)
        {
            var result = await DataService.DisconnectProviderAsync(provider.LoginProvider);
            if (result.Success) 
            {
                provider.IsConnected = false;
                ShowNotification(string.Format(Loc["Msg_ProviderDisconnected"], provider.Name), "bg-blue-500");
            }
            else ShowNotification(result.ErrorMessage ?? Loc["Msg_DisconnectFailed"], "bg-red-500");
        }
        else
        {
            var accessToken = await DataService.GetAccessTokenAsync();
            NavigationManager.NavigateTo($"/auth/external-login?provider={provider.LoginProvider}&returnUrl=/security-settings&mode=connect&access_token={accessToken}", forceLoad: true);
        }
    }

    // --- 2FA LOGIC ---
    private async Task LoadTwoFaStatus()
    {
        var result = await DataService.GetAllAsync();
        _activeTwoFaMethods.Clear();
        _availableTwoFaMethods.Clear();

        if (result.Success && result.Data != null)
        {
            var user2fa = result.Data;

            foreach(var supported in _allSupportedMethods)
            {
                var active = user2fa.FirstOrDefault(u => u.Method == supported.MethodType && u.IsEnabled);
                var model = supported.Clone();
                if (active != null)
                {
                    model.Priority = active.Priority;
                    model.IsEnabled = true;
                    _activeTwoFaMethods.Add(model);
                }
                else
                {
                    model.IsEnabled = false;
                    _availableTwoFaMethods.Add(model);
                }
            }

            _activeTwoFaMethods.Sort((x, y) => x.Priority.CompareTo(y.Priority));
        }
        else
        {
            foreach (var m in _allSupportedMethods)
            {
                var model = m.Clone();
                model.IsEnabled = false;
                _availableTwoFaMethods.Add(model);
            }
        }
        await InvokeAsync(StateHasChanged);
    }


    private async Task AddTwoFa(TwoFaUiModel method)
    {
        var request = new TwoFactorRequest
        {
            TwoFactorMethod = method.MethodType,
            IsEnabled = true,
            Priority = 10
        };
        
        var result = await DataService.AddOrUpdateAsync(request);
        if(result.Success)
        {
            ShowNotification(Loc["Msg_MethodAdded"], "bg-green-500");
            await LoadTwoFaStatus();
        }
        else ShowNotification(result.ErrorMessage ?? Loc["Msg_AddFailed"], "bg-red-500");
    }

    private async Task RemoveTwoFa(TwoFaUiModel method)
    {
        var request = new TwoFactorRequest { TwoFactorMethod = method.MethodType };
        var result = await DataService.RemoveAsync(request);
        if(result.Success)
        {
             ShowNotification(Loc["Msg_MethodRemoved"], "bg-blue-500");
             await LoadTwoFaStatus();
        }
        else ShowNotification(result.ErrorMessage ?? Loc["Msg_RemoveFailed"], "bg-red-500");
    }

    private async Task SetDefaultTwoFa(TwoFaUiModel method)
    {
        var request = new TwoFactorRequest
        {
            TwoFactorMethod = method.MethodType,
            IsEnabled = true,
            Priority = 0
        };
        
        var result = await DataService.AddOrUpdateAsync(request);
        if(result.Success)
        {
             ShowNotification(Loc["Msg_DefaultUpdated"], "bg-green-500");
             await LoadTwoFaStatus();
        }
        else ShowNotification(result.ErrorMessage ?? Loc["Msg_DefaultFailed"], "bg-red-500");
    }

    // --- PASSWORD LOGIC ---
    private async Task UpdatePassword()
    {
        _isSaving = true;
        var result = await DataService.ChangePasswordAsync(_passwordModel);
        _isSaving = false;
        
        if (result.Success)
        {
            ShowNotification(Loc["Msg_PasswordUpdated"], "bg-green-500");
            _passwordModel = new();
        }
        else
        {
            ShowNotification(result.ErrorMessage ?? Loc["Msg_PasswordUpdateFailed"], "bg-red-500");
        }
    }

    // --- UI HELPERS ---
    private void OpenTwoFaDialog() => _showTwoFaDialog = true;
    private void CloseTwoFaDialog() => _showTwoFaDialog = false;

    private void ShowNotification(string message, string cssClass)
    {
        _notificationMessage = message;
        _notificationClass = cssClass + " text-white";
        _showNotification = true;
        StateHasChanged();
        var timer = new System.Threading.Timer((_) => { _showNotification = false; InvokeAsync(StateHasChanged); }, null, 3000, System.Threading.Timeout.Infinite);
    }
    
