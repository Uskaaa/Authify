@using Microsoft.JSInterop
@inherits LayoutComponentBase
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

@if (Theme is not null && (Theme.HasLightOverrides || Theme.HasDarkOverrides))
{
    <style>
        @if (Theme.HasLightOverrides)
        {
            <text>:root {</text>
            @if (Theme.Primary is not null)       { <text>--auth-primary: @Theme.Primary;</text>                   }
            @if (Theme.PrimaryHover is not null)  { <text>--auth-primary-hover: @Theme.PrimaryHover;</text>        }
            @if (Theme.Background is not null)    { <text>--auth-bg: @Theme.Background;</text>                     }
            @if (Theme.CardBackground is not null){ <text>--auth-card-bg: @Theme.CardBackground;</text>            }
            @if (Theme.Text is not null)          { <text>--auth-text: @Theme.Text;</text>                         }
            @if (Theme.TextMuted is not null)     { <text>--auth-text-muted: @Theme.TextMuted;</text>              }
            @if (Theme.InputBackground is not null){ <text>--auth-input-bg: @Theme.InputBackground;</text>         }
            @if (Theme.Border is not null)        { <text>--auth-border: @Theme.Border;</text>                     }
            @if (Theme.Error is not null)         { <text>--auth-error: @Theme.Error;</text>                       }
            @if (Theme.Success is not null)        { <text>--auth-success: @Theme.Success;</text>                   }
            @if (Theme.Shadow is not null)         { <text>--auth-shadow: @Theme.Shadow;</text>                     }
            <text>}</text>
        }
        @if (Theme.HasDarkOverrides)
        {
            <text>:root.dark {</text>
            @if (Theme.DarkPrimary is not null)      { <text>--auth-primary: @Theme.DarkPrimary;</text>            }
            @if (Theme.DarkPrimaryHover is not null) { <text>--auth-primary-hover: @Theme.DarkPrimaryHover;</text> }
            @if (Theme.DarkBackground is not null)   { <text>--auth-bg: @Theme.DarkBackground;</text>              }
            @if (Theme.DarkCardBackground is not null){ <text>--auth-card-bg: @Theme.DarkCardBackground;</text>    }
            @if (Theme.DarkText is not null)         { <text>--auth-text: @Theme.DarkText;</text>                  }
            @if (Theme.DarkTextMuted is not null)    { <text>--auth-text-muted: @Theme.DarkTextMuted;</text>       }
            @if (Theme.DarkInputBackground is not null){ <text>--auth-input-bg: @Theme.DarkInputBackground;</text> }
            @if (Theme.DarkBorder is not null)       { <text>--auth-border: @Theme.DarkBorder;</text>              }
            @if (Theme.DarkShadow is not null)       { <text>--auth-shadow: @Theme.DarkShadow;</text>              }
            <text>}</text>
        }
    </style>
}

<div class="auth-font-sans auth-text-gray-900 dark:auth-text-slate-100 auth-transition-colors auth-duration-300">

    <input type="checkbox" id="mobile-menu-toggle" class="auth-hidden" />

    <label for="mobile-menu-toggle" id="profile-mobile-backdrop"
           class="auth-fixed auth-inset-0 auth-z-40 auth-bg-slate-900/60 auth-backdrop-blur-sm auth-hidden auth-pointer-events-none lg:auth-hidden auth-transition-opacity"
           aria-label="Close mobile menu">
    </label>

    <aside id="profile-mobile-sidebar"
           class="auth-fixed auth-inset-y-0 auth-left-0 auth-z-50 auth-w-64 auth-bg-white dark:auth-bg-slate-900 auth-border-r auth-border-gray-200 dark:auth-border-slate-800 auth-transition-transform auth-duration-300 auth-ease-in-out -auth-translate-x-full lg:auth-translate-x-0 auth-flex auth-flex-col auth-shadow-2xl lg:auth-shadow-none">

        <div class="auth-h-16 auth-flex auth-items-center auth-justify-between lg:auth-justify-center auth-px-6 auth-border-b auth-border-gray-100 dark:auth-border-slate-800/50 auth-flex-shrink-0">
            <a href="/" class="auth-flex auth-items-center auth-gap-2.5 auth-cursor-pointer">
                @if (LogoImageUrl is not null)
                {
                    <img src="@SafeImageUrl(LogoImageUrl)" alt="@(AppName ?? "Logo")" class="auth-h-8 auth-w-auto auth-object-contain" />
                }
                else
                {
                    <div class="auth-w-8 auth-h-8 auth-bg-gradient-to-br auth-from-primary-500 auth-to-indigo-700 auth-rounded-lg auth-flex auth-items-center auth-justify-center auth-text-white auth-shadow-md auth-shadow-primary-500/20">
                        @if (IconImageUrl is not null)
                        {
                            <img src="@SafeImageUrl(IconImageUrl)" alt="@(AppName ?? "Icon")" class="auth-w-5 auth-h-5 auth-object-contain" />
                        }
                        else
                        {
                            <i class="@(IconCssClass ?? "fa-solid fa-server") auth-text-xs"></i>
                        }
                    </div>
                    @if (AppName is not null)
                    {
                        <span class="auth-font-bold auth-text-lg auth-tracking-tight auth-text-slate-900 dark:auth-text-white">
                            @AppName
                        </span>
                    }
                }
            </a>
            <label for="mobile-menu-toggle"
                   class="lg:auth-hidden auth-p-2 auth-text-slate-400 hover:auth-text-slate-600 dark:auth-text-slate-500 dark:hover:auth-text-slate-300 auth-cursor-pointer auth-transition-colors"
                   aria-label="Close menu">
                <i class="fa-solid fa-xmark auth-text-lg"></i>
            </label>
        </div>

        <ProfileNavMenu />

    </aside>

    <header class="auth-fixed auth-top-0 auth-right-0 auth-left-0 lg:auth-left-64 auth-h-16 auth-bg-white dark:auth-bg-slate-900 auth-border-b auth-border-gray-200 dark:auth-border-slate-800 auth-flex auth-items-center auth-justify-between auth-px-4 auth-z-30 lg:auth-hidden">
        <div class="auth-flex auth-items-center auth-gap-3">
            <label for="mobile-menu-toggle"
                   class="auth-p-2 auth--ml-2 auth-text-slate-500 hover:auth-text-slate-700 dark:auth-text-slate-400 dark:hover:auth-text-white auth-rounded-lg hover:auth-bg-slate-100 dark:hover:auth-bg-slate-800 auth-transition-colors auth-cursor-pointer"
                   aria-label="Open menu">
                <i class="fa-solid fa-bars auth-text-xl"></i>
            </label>
            @if (AppName is not null)
            {
                <span class="auth-font-semibold auth-text-slate-800 dark:auth-text-white auth-text-lg">
                    @AppName
                </span>
            }
        </div>
    </header>

    <main class="lg:auth-ml-64 auth-pt-16 lg:auth-pt-0 auth-min-h-screen auth-bg-gray-50 dark:auth-bg-slate-950">
        @Body
    </main>

</div>

@code {
    /// <summary>
    /// URL (or data URI) of a single combined logo image or SVG file.
    /// When set, replaces both the icon badge and the app-name text in the sidebar header.
    /// Supports PNG, SVG, or any image format the browser can render.
    /// </summary>
    [Parameter] public string? LogoImageUrl { get; set; }

    /// <summary>
    /// URL (or data URI) of an icon image (PNG or SVG) rendered inside the gradient badge.
    /// Takes precedence over <see cref="IconCssClass"/> when both are supplied.
    /// Ignored when <see cref="LogoImageUrl"/> is set.
    /// </summary>
    [Parameter] public string? IconImageUrl { get; set; }

    /// <summary>
    /// CSS class(es) for an icon rendered inside the gradient badge, e.g. a FontAwesome class
    /// such as <c>"fa-solid fa-shield-halved"</c>. Falls back to <c>"fa-solid fa-server"</c>
    /// when neither this nor <see cref="IconImageUrl"/> is provided.
    /// Ignored when <see cref="LogoImageUrl"/> is set.
    /// </summary>
    [Parameter] public string? IconCssClass { get; set; }

    /// <summary>
    /// Application name shown in the sidebar header and in the mobile top-bar.
    /// When <see cref="LogoImageUrl"/> is set this value is used only as the image's
    /// <c>alt</c> attribute. When null, no name text is rendered.
    /// </summary>
    [Parameter] public string? AppName { get; set; }

    /// <summary>
    /// Optional theme color overrides. Any property left null falls back to the
    /// defaults declared in <c>authify-theme.css</c>.
    /// </summary>
    [Parameter] public AuthifyTheme? Theme { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { await JS.InvokeVoidAsync("applyTheme"); } catch { }
        }
    }

    /// <summary>
    /// Returns the URL only when it uses a safe scheme, preventing XSS through
    /// malicious data URIs (e.g. <c>data:text/html,…</c>).
    /// Allowed schemes: https, http, relative paths, and <c>data:image/</c> URIs.
    /// </summary>
    private static string? SafeImageUrl(string? url)
    {
        if (url is null) return null;
        if (url.StartsWith("data:image/", StringComparison.OrdinalIgnoreCase)) return url;
        if (url.StartsWith("https://", StringComparison.OrdinalIgnoreCase)) return url;
        if (url.StartsWith("http://", StringComparison.OrdinalIgnoreCase)) return url;
        if (url.StartsWith('/') || url.StartsWith('.')) return url;
        return null;
    }
}

<style>
    #mobile-menu-toggle:checked ~ #profile-mobile-backdrop {
        opacity: 1;
        pointer-events: auto;
        display: block;
        cursor: pointer;
    }

    #mobile-menu-toggle:checked ~ #profile-mobile-sidebar {
        transform: translateX(0);
    }
</style>