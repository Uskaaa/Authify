@page "/reset-password"
@using System.ComponentModel.DataAnnotations

<div class="reset-container">
    <div class="auth-card">
        <div class="auth-header">
            <h1>Reset Password</h1>
            <p>Enter your new password</p>
        </div>
        @if (!isSuccess)
        {
            <EditForm Model="model" OnValidSubmit="HandleValidSubmit" class="auth-form">
                <DataAnnotationsValidator />
                <div class="form-group">
                    <label for="password">New Password</label>
                    <div class="password-input">
                        <InputText id="password" class="form-control" @bind-Value="model.Password" type="@(showPassword ? "text" : "password")" />
                        <button type="button" class="toggle-password" @onclick="TogglePasswordVisibility" tabindex="-1">
                            <i class="fas @(showPassword ? "fa-eye-slash" : "fa-eye")"></i>
                        </button>
                    </div>
                    <ValidationMessage For="@(() => model.Password)" />
                </div>
                <div class="form-group">
                    <label for="confirmPassword">Confirm New Password</label>
                    <div class="password-input">
                        <InputText id="confirmPassword" class="form-control" @bind-Value="model.ConfirmPassword" type="@(showConfirmPassword ? "text" : "password")" />
                        <button type="button" class="toggle-password" @onclick="ToggleConfirmPasswordVisibility" tabindex="-1">
                            <i class="fas @(showConfirmPassword ? "fa-eye-slash" : "fa-eye")"></i>
                        </button>
                    </div>
                    <ValidationMessage For="@(() => model.ConfirmPassword)" />
                </div>
                <button type="submit" class="btn btn-primary" disabled="@(isLoading)">
                    @if (isLoading)
                    {
                        <i class="fas fa-spinner fa-spin"></i>
                    }
                    else
                    {
                        <span>Reset Password</span>
                    }
                </button>
            </EditForm>
        }
        else
        {
            <div class="success-message">
                <div class="success-icon">
                    <i class="fas fa-check-circle"></i>
                </div>
                <h2>Password Reset!</h2>
                <p>Your password has been successfully reset. You can now login with your new password.</p>
                <a href="login" class="btn btn-primary">Go to Login</a>
            </div>
        }
    </div>
</div>

@code {
    private ResetPasswordModel model = new();
    private bool isLoading = false;
    private bool isSuccess = false;
    private bool showPassword = false;
    private bool showConfirmPassword = false;

    private async Task HandleValidSubmit()
    {
        isLoading = true;
        await Task.Delay(2000);
        isLoading = false;
        isSuccess = true;
    }

    private void TogglePasswordVisibility()
    {
        showPassword = !showPassword;
    }

    private void ToggleConfirmPasswordVisibility()
    {
        showConfirmPassword = !showConfirmPassword;
    }

    public class ResetPasswordModel : IValidatableObject
    {
        [Required(ErrorMessage = "Please enter your new password")]
        [MinLength(6, ErrorMessage = "Password must be at least 6 characters")]
        public string Password { get; set; }

        [Required(ErrorMessage = "Please confirm your new password")]
        public string ConfirmPassword { get; set; }

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            if (Password != ConfirmPassword)
            {
                yield return new ValidationResult("Passwords do not match", new[] { nameof(ConfirmPassword) });
            }
        }
    }
} 