@page "/otp"
@using System.ComponentModel.DataAnnotations
@using Microsoft.JSInterop
@inject IJSRuntime JS
@implements IAsyncDisposable

<div @ref="containerRef" class="otp-container">
    <div class="auth-card">
        <div class="auth-header">
            <h1>Verify Your Email</h1>
            <p>Enter the 6-digit code sent to your email</p>
        </div>
        
        <EditForm Model="this" OnValidSubmit="HandleValidSubmit" class="auth-form">
            <input type="hidden" @bind="OtpCode" />

            <div class="otp-inputs">
                @for (int i = 0; i < 6; i++)
                {
                    <input class="form-control otp-input" maxlength="1" inputmode="numeric" pattern="[0-9]" />
                }
            </div>
            
            <ValidationMessage For="@(() => OtpCode)" />
            <button type="submit" class="btn btn-primary" disabled="@(isVerifying || OtpCode?.Length != 6)">
                @if (isVerifying) { <i class="fas fa-spinner fa-spin"></i> } else { <span>Verify</span> }
            </button>
        </EditForm>
        
        <p>Eingegebener Code (zur Demo): <strong>@OtpCode</strong></p>
    </div>
</div>

@code {
    private ElementReference containerRef;
    private DotNetObjectReference<Otp> objRef;

    [Required(ErrorMessage = "Der Code ist erforderlich.")]
    [StringLength(6, MinimumLength = 6, ErrorMessage = "Der Code muss 6-stellig sein.")]
    private string OtpCode { get; set; }

    private bool isVerifying = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            objRef = DotNetObjectReference.Create(this);
            // Einmaliger Aufruf, um das JavaScript-Modul zu starten
            await JS.InvokeVoidAsync("initializeOtpHandler", containerRef, objRef);
        }
    }

    [JSInvokable]
    public void OnOtpCompleted(string otp)
    {
        // Diese Methode wird von JS aufgerufen, wenn der Code vollständig ist.
        // Sie könnten hier z.B. automatisch den Submit auslösen.
        Console.WriteLine($"OTP vollständig: {otp}. Löst Validierung aus.");
        StateHasChanged(); // UI aktualisieren, falls nötig
    }

    private async Task HandleValidSubmit()
    {
        isVerifying = true;
        await Task.Delay(1500); // Simuliert API-Aufruf
        Console.WriteLine($"Verifiziere Code: {OtpCode}");
        isVerifying = false;
    }

    public async ValueTask DisposeAsync()
    {
        objRef?.Dispose();
    }
}